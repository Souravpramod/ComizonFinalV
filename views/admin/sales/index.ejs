<%- include('../../partials/admin-head') %>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<body class="bg-black text-light">
  <%- include('../../partials/admin-sidebar') %>

  <div class="main-content">
    <%- include('../../partials/admin-header') %>

    <div class="admin-content p-4">

      <% if (locals.error) { %>
        <div class="alert alert-danger alert-dismissible fade show rounded-0">
          <%= error %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>

      <!-- Header -->
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
          <h4 class="mb-0" style="color:var(--admin-gold);">Sales Report</h4>
          <p class="text-muted small mb-0">Revenue, discounts and order analytics</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
          <a href="/admin/sales/download?format=excel&period=<%= period %>&startDate=<%= startDate||'' %>&endDate=<%= endDate||'' %>"
             class="btn btn-outline-success btn-sm rounded-0">
            <i class="fas fa-file-csv me-1"></i> Export CSV
          </a>
          <a href="/admin/sales/download?format=pdf&period=<%= period %>&startDate=<%= startDate||'' %>&endDate=<%= endDate||'' %>"
             class="btn btn-outline-danger btn-sm rounded-0" target="_blank">
            <i class="fas fa-file-pdf me-1"></i> Export PDF
          </a>
        </div>
      </div>

      <!-- Period Filter -->
      <form method="GET" action="/admin/sales" class="card bg-dark border-secondary rounded-0 p-3 mb-4">
        <div class="row g-3 align-items-end">
          <div class="col-md-3">
            <label class="form-label text-info small">Period</label>
            <select name="period" id="periodSelect" class="form-select bg-dark text-light border-secondary rounded-0">
              <option value="daily"  <%= period==='daily'  ?'selected':'' %>>Today</option>
              <option value="weekly" <%= period==='weekly' ?'selected':'' %>>Last 7 Days</option>
              <option value="yearly" <%= period==='yearly' ?'selected':'' %>>This Year</option>
              <option value="custom" <%= period==='custom' ?'selected':'' %>>Custom Range</option>
            </select>
          </div>
          <div class="col-md-3" id="startWrap" style="display:<%= period==='custom'?'':'none' %>;">
            <label class="form-label text-info small">Start Date</label>
            <input type="date" name="startDate" value="<%= startDate||'' %>"
              class="form-control bg-dark text-light border-secondary rounded-0">
          </div>
          <div class="col-md-3" id="endWrap" style="display:<%= period==='custom'?'':'none' %>;">
            <label class="form-label text-info small">End Date</label>
            <input type="date" name="endDate" value="<%= endDate||'' %>"
              class="form-control bg-dark text-light border-secondary rounded-0">
          </div>
          <div class="col-md-2">
            <button type="submit" class="btn btn-warning btn-sm w-100 rounded-0 fw-bold">Apply</button>
          </div>
        </div>
        <div class="text-muted small mt-2">
          Showing: <span style="color:var(--admin-gold);"><%= dateFrom %> → <%= dateTo %></span>
        </div>
      </form>

      <!-- Summary Cards -->
      <div class="row mb-4">
        <% const cards = [
          { label: 'Total Orders',    value: summary.totalOrders,                    icon: 'fa-shopping-cart',  color: 'var(--admin-gold)' },
          { label: 'Gross Revenue',   value: '$' + (summary.totalRevenue||0).toFixed(2),   icon: 'fa-dollar-sign', color: '#28a745' },
          { label: 'Total Discounts', value: '$' + Math.max(0,(summary.totalDiscount||0)).toFixed(2), icon: 'fa-tag',        color: '#fd9843' },
          { label: 'Avg Order Value', value: '$' + (summary.avgOrderValue||0).toFixed(2),  icon: 'fa-chart-bar',  color: '#17a2b8' },
        ]; %>
        <% cards.forEach(c => { %>
          <div class="col-lg-3 col-md-6 mb-3">
            <div class="admin-stat-card" style="border-left:3px solid <%= c.color %>;">
              <div class="d-flex align-items-center gap-3">
                <div class="stat-icon" style="background:rgba(255,255,255,.05);color:<%= c.color %>;"><i class="fas <%= c.icon %>"></i></div>
                <div>
                  <div class="stat-value" style="color:<%= c.color %>;"><%= c.value %></div>
                  <div class="stat-label text-muted small"><%= c.label %></div>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>

      <!-- Chart -->
      <% if (chartData.length > 0) { %>
        <div class="card bg-dark border-secondary rounded-0 mb-4">
          <div class="card-header border-secondary" style="color:var(--admin-gold);">Revenue & Discount Trend</div>
          <div class="card-body">
            <canvas id="salesChart" height="80"></canvas>
          </div>
        </div>
      <% } %>

      <!-- Orders Table -->
      <div class="card bg-dark border-secondary rounded-0">
        <div class="card-header border-secondary d-flex justify-content-between align-items-center">
          <span style="color:var(--admin-gold);">Order Breakdown</span>
          <span class="badge bg-secondary"><%= totalOrders %> orders</span>
        </div>
        <div class="card-body p-0">
          <% if (orders.length === 0) { %>
            <div class="text-center py-5 text-muted">
              <i class="fas fa-chart-bar fa-3x mb-3"></i>
              <p>No orders in this period.</p>
            </div>
          <% } else { %>
          <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 small">
              <thead style="color:var(--admin-gold);">
                <tr>
                  <th>Order ID</th><th>Customer</th><th>Date</th><th>Payment</th>
                  <th>Subtotal</th><th>Coupon Disc.</th><th>Shipping</th><th>Total</th><th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% orders.forEach(o => { %>
                  <% const sc = {pending:'warning',processing:'info',shipped:'primary',delivered:'success',cancelled:'danger',returned:'secondary'}; %>
                  <tr>
                    <td><a href="/admin/orders/<%= o._id %>" class="text-warning text-decoration-none"><%= o.orderId %></a></td>
                    <td><%= (o.userId?.firstName||'') + ' ' + (o.userId?.lastName||'') %></td>
                    <td><%= new Date(o.orderedAt).toLocaleDateString('en-IN') %></td>
                    <td>
                      <span class="badge bg-secondary"><%= o.paymentMethod.toUpperCase() %></span>
                      <% if (o.paymentStatus === 'refunded') { %><span class="badge bg-info ms-1">Refunded</span><% } %>
                    </td>
                    <td>$<%= o.subtotal.toFixed(2) %></td>
                    <td class="text-warning"><%= o.couponDiscount > 0 ? `$${o.couponDiscount.toFixed(2)}` : '—' %></td>
                    <td>$<%= o.shippingFee.toFixed(2) %></td>
                    <td class="fw-bold" style="color:#28a745;">$<%= o.total.toFixed(2) %></td>
                    <td><span class="badge bg-<%= sc[o.status]||'secondary' %>"><%= o.status %></span></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
        </div>
      </div>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>
        <nav class="mt-3">
          <ul class="pagination pagination-sm justify-content-center mb-0">
            <% for (let i = 1; i <= totalPages; i++) { %>
              <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                <a class="page-link bg-dark border-secondary text-light rounded-0"
                   href="/admin/sales?page=<%= i %>&period=<%= period %>&startDate=<%= startDate||'' %>&endDate=<%= endDate||'' %>">
                  <%= i %>
                </a>
              </li>
            <% } %>
          </ul>
        </nav>
      <% } %>

    </div>
  </div>
</body>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
// Period select → show/hide date pickers
document.getElementById('periodSelect').addEventListener('change', function() {
  const show = this.value === 'custom';
  document.getElementById('startWrap').style.display = show ? '' : 'none';
  document.getElementById('endWrap').style.display   = show ? '' : 'none';
});

// Chart
<% if (chartData.length > 0) { %>
const ctx = document.getElementById('salesChart').getContext('2d');
new Chart(ctx, {
  type: 'bar',
  data: {
    labels: <%- JSON.stringify(chartData.map(d => d._id)) %>,
    datasets: [
      {
        label: 'Revenue ($)',
        data: <%- JSON.stringify(chartData.map(d => d.revenue)) %>,
        backgroundColor: 'rgba(255,193,7,0.7)',
        borderColor: '#ffc107',
        borderWidth: 1,
        yAxisID: 'y',
      },
      {
        label: 'Discount ($)',
        data: <%- JSON.stringify(chartData.map(d => Math.max(0, d.discount))) %>,
        backgroundColor: 'rgba(253,152,67,0.5)',
        borderColor: '#fd9843',
        borderWidth: 1,
        yAxisID: 'y',
      },
      {
        label: 'Orders',
        data: <%- JSON.stringify(chartData.map(d => d.orders)) %>,
        type: 'line',
        borderColor: '#17a2b8',
        backgroundColor: 'transparent',
        pointBackgroundColor: '#17a2b8',
        yAxisID: 'y1',
      },
    ],
  },
  options: {
    responsive: true,
    interaction: { mode: 'index', intersect: false },
    scales: {
      x:  { ticks: { color: '#adb5bd' }, grid: { color: 'rgba(255,255,255,.05)' } },
      y:  { position: 'left',  ticks: { color: '#ffc107' }, grid: { color: 'rgba(255,255,255,.05)' } },
      y1: { position: 'right', ticks: { color: '#17a2b8' }, grid: { display: false } },
    },
    plugins: { legend: { labels: { color: '#adb5bd' } } },
  },
});
<% } %>
</script>