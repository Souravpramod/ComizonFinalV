function addEditProduct(id, name) {
  const container  = document.getElementById('editSelectedProductsContainer');
  const hiddenArea = document.getElementById('editHiddenProductInputs');
  if (document.getElementById('einput-' + id)) return;
  if (container.innerText.trim() === 'No products selected') container.innerHTML = '';
  container.innerHTML += `<span class="badge bg-warning text-dark p-2" id="epill-${id}">
    ${name} <i class="fas fa-times ms-2" style="cursor:pointer;" onclick="removeEditProduct('${id}')"></i>
  </span>`;
  hiddenArea.innerHTML += `<input type="hidden" name="productIds" value="${id}" id="einput-${id}">`;
