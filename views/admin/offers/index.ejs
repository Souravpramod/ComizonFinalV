// ══════════════════════════════════════════════════════════════════════════════
// ── LIVE VALIDATION (shared by both Create and Edit forms) ───────────────────
// ══════════════════════════════════════════════════════════════════════════════

function addErrDiv(inputEl) {
  if (!inputEl || inputEl.nextElementSibling?.classList.contains('lv-feedback')) return;
  const d = document.createElement('div');
  d.className = 'lv-feedback text-danger small mt-1';
  inputEl.after(d);
}

function setFieldError(inputEl, msg) {
  if (!inputEl) return;
  const fb = inputEl.nextElementSibling?.classList.contains('lv-feedback')
    ? inputEl.nextElementSibling : null;
  if (msg) {
    inputEl.classList.add('is-invalid');
    inputEl.classList.remove('is-valid');
    if (fb) fb.textContent = msg;
  } else {
    inputEl.classList.remove('is-invalid');
    inputEl.classList.add('is-valid');
    if (fb) fb.textContent = '';
  }
}

function clearField(inputEl) {
  if (!inputEl) return;
  inputEl.classList.remove('is-invalid', 'is-valid');
  const fb = inputEl.nextElementSibling?.classList.contains('lv-feedback')
    ? inputEl.nextElementSibling : null;
  if (fb) fb.textContent = '';
}

// ── Rules — mirror the backend exactly ───────────────────────────────────────
function validateTitle(val) {
  const v = (val || '').trim();
  if (!v || v.length < 3)   return 'Title must be at least 3 characters.';
  if (v.length > 100)        return 'Title must be under 100 characters.';
  return '';
}

function validateDiscountValue(val, discountType) {
  const dv = parseFloat(val);
  if (isNaN(dv) || dv < 0)                         return 'Discount value must be a non-negative number.';
  if (discountType === 'percent' && dv >= 100)       return 'Percentage discount must be less than 100%.';
  if (discountType === 'flat'    && dv <= 0)         return 'Flat discount value must be greater than 0.';
  return '';
}

function validateMaxDiscount(val) {
  if (!val && val !== 0) return '';  // optional field
  const v = parseFloat(val);
  if (!isNaN(v) && v <= 0) return 'Max discount cap must be a positive number.';
  return '';
}

function validateReferralReward(val) {
  const v = parseFloat(val) || 0;
  if (v < 0)   return 'Referral reward cannot be negative.';
  if (v > 100) return 'Referral reward cannot exceed $100.';
  return '';
}

function validateDates(startsAtVal, expiresAtVal) {
  const now    = new Date();
  const start  = startsAtVal  ? new Date(startsAtVal)  : null;
  const expiry = expiresAtVal ? new Date(expiresAtVal) : null;
  const errors = { startsAt: '', expiresAt: '' };
  if (expiry && expiry <= now)
    errors.expiresAt = 'Expiry date must be in the future.';
  if (start && expiry && start >= expiry)
    errors.startsAt = 'Start date must be before expiry date.';
  if (start && expiry && errors.startsAt === '' && (expiry - start) < 60 * 60 * 1000)
    errors.startsAt = 'Offer duration must be at least 1 hour.';
  return errors;
}

// ── Wire up CREATE form ───────────────────────────────────────────────────────
(function wireCreateForm() {
  const titleEl   = document.querySelector('#offerCreateForm [name="title"]');
  const dvEl      = document.querySelector('#offerCreateForm [name="discountValue"]');
  const mdEl      = document.querySelector('#offerCreateForm [name="maxDiscount"]');
  const rrEl      = document.querySelector('#offerCreateForm [name="referralReward"]');
  const startEl   = document.querySelector('#offerCreateForm [name="startsAt"]');
  const expiryEl  = document.querySelector('#offerCreateForm [name="expiresAt"]');
  const dtSelect  = document.getElementById('offerDiscountType');
  const typeSelect = document.getElementById('offerTypeSelect');

  [titleEl, dvEl, mdEl, rrEl, startEl, expiryEl].forEach(addErrDiv);

  if (titleEl) {
    titleEl.addEventListener('input', () => setFieldError(titleEl, validateTitle(titleEl.value)));
    titleEl.addEventListener('blur',  () => setFieldError(titleEl, validateTitle(titleEl.value)));
  }

  function revalidateDV() {
    if (dvEl) setFieldError(dvEl, validateDiscountValue(dvEl.value, dtSelect?.value));
  }
  if (dvEl) {
    dvEl.addEventListener('input', revalidateDV);
    dvEl.addEventListener('blur',  revalidateDV);
  }
  if (dtSelect) dtSelect.addEventListener('change', revalidateDV);

  if (mdEl) {
    mdEl.addEventListener('input', () => setFieldError(mdEl, validateMaxDiscount(mdEl.value)));
    mdEl.addEventListener('blur',  () => setFieldError(mdEl, validateMaxDiscount(mdEl.value)));
  }

  if (rrEl) {
    rrEl.addEventListener('input', () => setFieldError(rrEl, validateReferralReward(rrEl.value)));
    rrEl.addEventListener('blur',  () => setFieldError(rrEl, validateReferralReward(rrEl.value)));
  }

  function revalidateDates() {
    const errs = validateDates(startEl?.value, expiryEl?.value);
    if (startEl)  setFieldError(startEl,  errs.startsAt);
    if (expiryEl) setFieldError(expiryEl, errs.expiresAt);
  }
  if (startEl)  { startEl.addEventListener('change',  revalidateDates); startEl.addEventListener('blur', revalidateDates); }
  if (expiryEl) { expiryEl.addEventListener('change', revalidateDates); expiryEl.addEventListener('blur', revalidateDates); }

  // Clear product/category selector errors when selection changes
  if (typeSelect) typeSelect.addEventListener('change', () => {
    [titleEl, dvEl, mdEl, rrEl, startEl, expiryEl].forEach(clearField);
  });
})();

