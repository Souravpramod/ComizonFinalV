// ── Edit form submit ──────────────────────────────────────────────────────────
document.getElementById('editOfferForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const form      = e.target;
  const errorBox  = document.getElementById('editOfferModalError');
  const errorText = document.getElementById('editOfferModalErrorText');
  const submitBtn = document.getElementById('editOfferSubmitBtn');
  const btnText   = document.getElementById('editOfferBtnText');
  const btnSpin   = document.getElementById('editOfferBtnSpinner');

  // Trigger all live validations before submitting
  form.querySelectorAll('input[name], select[name]').forEach(el => el.dispatchEvent(new Event('blur')));
  if (hasLiveErrors(form)) return;

  errorBox.classList.add('d-none');
  errorText.textContent = '';
  submitBtn.disabled = true;
  btnText.classList.add('d-none');
  btnSpin.classList.remove('d-none');
 
  try {
    const fd  = new FormData(form);
    const obj = {};
    for (const [k, v] of fd.entries()) {
      obj[k] = obj[k] !== undefined ? [].concat(obj[k], v) : v;
    }
 
    const res  = await fetch(`/admin/offers/${editingOfferId}/edit`, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify(obj),
    });
    const data = await res.json();
 
    if (data.ok) {
      bootstrap.Modal.getInstance(document.getElementById('editOfferModal')).hide();
      window.location.reload();
    } else {
      errorText.textContent = data.message;
      errorBox.classList.remove('d-none');
      errorBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  } catch (err) {
    errorText.textContent = 'Network error. Please try again.';
    errorBox.classList.remove('d-none');
  } finally {
    submitBtn.disabled = false;
    btnText.classList.remove('d-none');
    btnSpin.classList.add('d-none');
  }
});
 
