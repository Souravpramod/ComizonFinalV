  errorBox.innerHTML     = '';
  submitBtn.disabled     = true;
  btnText.classList.add('d-none');
  btnSpin.classList.remove('d-none');
 
  try {
    const res  = await fetch(`/admin/coupons/${editingCouponId}/edit`, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify(Object.fromEntries(new FormData(this))),
    });
    const data = await res.json();
 
    if (data.ok) {
      window.location.reload();
    } else {
      errorBox.innerHTML     = data.errors.map(e => `<div>• ${e}</div>`).join('');
      errorBox.style.display = 'block';
      submitBtn.disabled     = false;
      btnText.classList.remove('d-none');
      btnSpin.classList.add('d-none');
    }
  } catch (err) {
    errorBox.innerHTML     = '<div>• Network error. Please try again.</div>';
    errorBox.style.display = 'block';
    submitBtn.disabled     = false;
    btnText.classList.remove('d-none');
    btnSpin.classList.add('d-none');
  }
});

// ═══════════════════════════════════════════════════════════════
//  LIVE BACKEND VALIDATION
//  Debounces form fields → hits your real create/edit endpoints
//  with the current form data → maps errors back to each field
// ═══════════════════════════════════════════════════════════════

// Fields that have their own error div (must match data-for attrs)
const VALIDATED_FIELDS = ['code','discountValue','maxDiscount','minOrderAmount',
                          'loyaltyThreshold','usageLimitTotal','usageLimitPerUser','expiresAt'];

// Which backend fields cross-affect others (re-validate these siblings too)
const CROSS = {
  discountType:     ['discountValue','maxDiscount','minOrderAmount'],
  discountValue:    ['minOrderAmount'],
  usageLimitTotal:  ['usageLimitPerUser'],
  usageLimitPerUser:['usageLimitTotal'],
  eligibility:      ['loyaltyThreshold'],
};

let _debounceTimers = {};

function setFieldError(form, fieldName, msg) {
  const errEl = form.querySelector(`.field-error[data-for="${fieldName}"]`);
  const input = form.querySelector(`[name="${fieldName}"]`);
  if (errEl) { errEl.textContent = msg || ''; errEl.style.display = msg ? 'block' : 'none'; }
  if (input)  input.classList.toggle('input-error', !!msg);
}

function clearAllFieldErrors(form) {
  form.querySelectorAll('.field-error').forEach(el => { el.textContent=''; el.style.display='none'; });
  form.querySelectorAll('.input-error').forEach(el => el.classList.remove('input-error'));
}

// Hit the real backend with current form data, get errors back, paint them per-field
async function validateFormLive(form, changedFieldName) {
  const isEdit   = form.id === 'editCouponForm';
  const url      = isEdit ? `/admin/coupons/${editingCouponId}/edit` : '/admin/coupons/add';
  const payload  = Object.fromEntries(new FormData(form));

  // Add a sentinel so the backend knows this is a validation-only probe.
  // If your backend doesn't support it, remove this line — errors still parse fine.
  payload._validateOnly = '1';

  try {
    const res  = await fetch(url, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify(payload),
    });
    const data = await res.json();

    if (data.ok) {
      // All good — clear errors for the changed field and its siblings
      const toClear = [changedFieldName, ...(CROSS[changedFieldName] || [])];
      toClear.forEach(f => setFieldError(form, f, null));
    } else {
      // Parse each error string and assign it to the matching field.
      // We only update the fields that were triggered (changed + cross-deps),
      // leaving unrelated fields untouched so you don't get cascading red on first load.
      const triggered = new Set([changedFieldName, ...(CROSS[changedFieldName] || [])]);

      // First clear the triggered fields, then re-paint whatever the backend returned
      triggered.forEach(f => setFieldError(form, f, null));

      (data.errors || []).forEach(msg => {
        const matched = VALIDATED_FIELDS.find(f => {
          if (!triggered.has(f)) return false;
          // Match error message to field by keyword
          const map = {
            code:             /coupon code/i,
            discountValue:    /discount value/i,
            maxDiscount:      /max discount|discount cap/i,
            minOrderAmount:   /min order|minimum order/i,
            loyaltyThreshold: /loyalty/i,
            usageLimitTotal:  /total usage/i,
            usageLimitPerUser:/per.?user/i,
            expiresAt:        /expir/i,
          };
          return map[f] && map[f].test(msg);
        });
        if (matched) setFieldError(form, matched, msg);
      });
    }
  } catch (_) {
    // Network error during live validation — fail silently, submit will catch it
  }
}

function debounceValidate(form, fieldName, delay = 400) {
  clearTimeout(_debounceTimers[fieldName]);
  _debounceTimers[fieldName] = setTimeout(() => validateFormLive(form, fieldName), delay);
}

function attachLiveValidation(form) {
  // text/number inputs
  VALIDATED_FIELDS.forEach(name => {
    const el = form.querySelector(`[name="${name}"]`);
    if (!el) return;
    el.addEventListener('input', () => debounceValidate(form, name));
    el.addEventListener('blur',  () => debounceValidate(form, name, 0));
  });

  // selects that cross-affect other fields
  Object.keys(CROSS).forEach(name => {
    const el = form.querySelector(`[name="${name}"]`);
    if (!el) return;
    el.addEventListener('change', () => debounceValidate(form, name, 0));
  });
}

// Attach to create form immediately
attachLiveValidation(document.getElementById('createCouponForm'));

// Attach to edit form each time the modal opens (data is freshly populated)
document.getElementById('editCouponModal').addEventListener('shown.bs.modal', () => {
  clearAllFieldErrors(document.getElementById('editCouponForm'));
  attachLiveValidation(document.getElementById('editCouponForm'));
});
</script>