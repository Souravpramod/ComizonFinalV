document.getElementById('editCouponForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  const errorBox  = document.getElementById('editCouponModalError');
  const submitBtn = document.getElementById('editCouponSubmitBtn');
  const btnText   = document.getElementById('editCouponBtnText');
  const btnSpin   = document.getElementById('editCouponBtnSpinner');
 
