<%- include('../../partials/admin-head') %>

<body class="bg-black text-light">
  <%- include('../../partials/admin-sidebar') %>

  <div class="main-content">
    <%- include('../../partials/admin-header') %>

    <div class="admin-content p-4">

      <% if (locals.error) { %>
        <div class="alert alert-danger alert-dismissible fade show rounded-0" role="alert">
          <%= error %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>
      <% if (locals.success) { %>
        <div class="alert alert-success alert-dismissible fade show rounded-0" role="alert">
          <%= success %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>

      <!-- Header -->
      <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/admin/orders" class="btn btn-outline-secondary btn-sm rounded-0">
          <i class="fas fa-arrow-left me-1"></i> Back
        </a>
        <div>
          <h4 class="mb-0" style="color:var(--admin-gold);">Manage Requests</h4>
          <p class="text-muted small mb-0">Review return requests — approve or reject each item</p>
        </div>
        <span class="ms-auto badge bg-warning text-dark fs-6 px-3 py-2">
          <%= requests.length %> pending
        </span>
      </div>

      <!-- Toast notification -->
      <div id="toastWrap" style="position:fixed;top:20px;right:20px;z-index:9999;min-width:280px;"></div>

      <% if (requests.length === 0) { %>
        <div class="text-center py-5 text-muted">
          <i class="fas fa-check-circle fa-3x mb-3" style="color:#28a745;"></i>
          <p class="fs-5">No pending requests. All caught up!</p>
        </div>

      <% } else { %>

        <%
          const returnReqs = requests.filter(r => r.itemStatus === 'return_requested');
        %>

        <!-- Return Requests -->
        <% if (returnReqs.length > 0) { %>
          <h5 class="mb-3" style="color:#fd9843;">
            <i class="fas fa-undo me-2"></i>Return Requests
            <span class="badge bg-warning text-dark ms-2"><%= returnReqs.length %></span>
          </h5>

          <div class="row g-3">
            <% returnReqs.forEach(r => { %>
              <div class="col-12" id="card-<%= r.itemId %>">
                <div class="card bg-dark border-warning" style="border-left:3px solid #fd9843 !important;">
                  <div class="card-body">
                    <div class="d-flex gap-3 align-items-start">

                      <!-- Product image -->
                      <% if (r.image) { %>
                        <img src="<%= r.image %>" alt="" style="width:56px;height:56px;object-fit:cover;border-radius:4px;flex-shrink:0;">
                      <% } else { %>
                        <div style="width:56px;height:56px;background:#2a2a2a;border-radius:4px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                          <i class="fas fa-book text-info"></i>
                        </div>
                      <% } %>

                      <!-- Details -->
                      <div class="flex-grow-1">
                        <div class="d-flex flex-wrap gap-2 align-items-center mb-1">
                          <span class="fw-semibold"><%= r.productName %></span>
                          <span class="badge bg-secondary" style="font-size:.7rem;">SKU: <%= r.sku || '—' %></span>
                          <span class="badge bg-warning text-dark">Return Requested</span>
                        </div>
                        <div class="small text-muted mb-1">
                          Order <span class="text-warning fw-bold">#<%= r.orderRef %></span>
                          &nbsp;·&nbsp; Customer: <span class="text-info"><%= r.userId?.firstName %> <%= r.userId?.lastName %></span>
                          &nbsp;·&nbsp; <%= r.quantity %> unit(s) &nbsp;·&nbsp; $<%= r.lineTotal.toFixed(2) %>
                        </div>
                        <% if (r.returnReason) { %>
                          <div class="small text-warning"><i class="fas fa-comment me-1"></i>Reason: "<%= r.returnReason %>"</div>
                        <% } %>
                        <div class="small mt-1">
                          Payment currently:
                          <span class="badge bg-<%= r.paymentStatus==='refunded'?'info':r.paymentStatus==='paid'?'success':'warning' %>">
                            <%= r.paymentStatus.charAt(0).toUpperCase()+r.paymentStatus.slice(1) %>
                          </span>
                        </div>
                      </div>

                      <!-- Action buttons -->
                      <div class="d-flex flex-column gap-2 align-items-center" style="flex-shrink:0;">
                        <button class="btn btn-success btn-sm rounded-circle resolve-btn"
                                style="width:42px;height:42px;font-size:1.1rem;"
                                title="Approve — mark returned + refund"
                                data-order-id="<%= r.orderId %>"
                                data-item-id="<%= r.itemId %>"
                                data-type="return"
                                data-action="approve">
                          <i class="fas fa-check"></i>
                        </button>
                        <button class="btn btn-danger btn-sm rounded-circle resolve-btn"
                                style="width:42px;height:42px;font-size:1.1rem;"
                                title="Reject — revert to delivered"
                                data-order-id="<%= r.orderId %>"
                                data-item-id="<%= r.itemId %>"
                                data-type="return"
                                data-action="reject">
                          <i class="fas fa-times"></i>
                        </button>
                      </div>

                    </div>

                    <!-- Result message area -->
                    <div class="result-msg mt-2" id="msg-<%= r.itemId %>"></div>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>

      <% } %>

    </div><!-- /admin-content -->
  </div><!-- /main-content -->
</body>

<script>
document.querySelectorAll('.resolve-btn').forEach(btn => {
  btn.addEventListener('click', async function () {
    const orderId = this.dataset.orderId;
    const itemId  = this.dataset.itemId;
    const type    = this.dataset.type;    // 'cancel' | 'return'
    const action  = this.dataset.action; // 'approve' | 'reject'

    const endpoint = type === 'cancel'
      ? `/admin/orders/${orderId}/items/${itemId}/resolve-cancel`
      : `/admin/orders/${orderId}/items/${itemId}/resolve-return`;

    // Disable both buttons on this card while waiting
    const card = document.getElementById(`card-${itemId}`);
    card.querySelectorAll('.resolve-btn').forEach(b => b.disabled = true);

    try {
      const res  = await fetch(endpoint, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ action }),
      });
      const data = await res.json();

      const msgEl = document.getElementById(`msg-${itemId}`);

      if (data.ok) {
        // Flash card green/red and fade it out
        const isApprove = action === 'approve';
        card.style.transition = 'opacity 0.6s ease';
        card.style.borderColor = isApprove ? '#28a745' : '#dc3545';
        msgEl.innerHTML = `<span class="badge bg-${isApprove ? 'success' : 'danger'} small">${data.message}</span>`;

        setTimeout(() => {
          card.style.opacity = '0';
          setTimeout(() => card.remove(), 650);
        }, 1400);

        showToast(data.message, isApprove ? 'success' : 'danger');

      } else {
        msgEl.innerHTML = `<span class="badge bg-danger small">${data.message || 'Error'}</span>`;
        card.querySelectorAll('.resolve-btn').forEach(b => b.disabled = false);
      }

    } catch (e) {
      document.getElementById(`msg-${itemId}`).innerHTML =
        '<span class="badge bg-danger small">Network error</span>';
      card.querySelectorAll('.resolve-btn').forEach(b => b.disabled = false);
    }
  });
});

function showToast(msg, type = 'success') {
  const wrap = document.getElementById('toastWrap');
  const id   = 'toast-' + Date.now();
  wrap.insertAdjacentHTML('beforeend', `
    <div id="${id}" class="alert alert-${type} alert-dismissible shadow mb-2 py-2 px-3" style="font-size:.9rem;">
      ${msg}
      <button type="button" class="btn-close btn-sm" onclick="document.getElementById('${id}').remove()"></button>
    </div>
  `);
  setTimeout(() => { const el = document.getElementById(id); if(el) el.remove(); }, 4000);
}
</script>
