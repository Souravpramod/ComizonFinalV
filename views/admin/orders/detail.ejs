<%- include('../../partials/admin-head') %>

<body class="bg-black text-light">
  <%- include('../../partials/admin-sidebar') %>

  <div class="main-content">
    <%- include('../../partials/admin-header') %>

    <div class="admin-content p-4">

      <% if (locals.error) { %>
        <div class="alert alert-danger alert-dismissible fade show rounded-0" role="alert">
          <%= error %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>
      <% if (locals.success) { %>
        <div class="alert alert-success alert-dismissible fade show rounded-0" role="alert">
          <%= success %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>

      <!-- Back + Header -->
      <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/admin/orders" class="btn btn-outline-secondary btn-sm">
          <i class="fas fa-arrow-left me-1"></i> Back
        </a>
        <div>
          <h4 class="mb-0" style="color:var(--admin-gold);">Order #<%= order.orderId %></h4>
          <p class="text-info small mb-0">
            Placed on <%= new Date(order.orderedAt).toLocaleString('en-US',{dateStyle:'medium',timeStyle:'short'}) %>
          </p>
        </div>
        <div class="ms-auto">
          <!-- Overall status badge -->
          <% const sc = {pending:'warning',processing:'info',shipped:'primary',out_for_delivery:'info',delivered:'success',cancelled:'danger'}; %>
          <span class="badge bg-<%= sc[order.status]||'secondary' %> fs-6 px-3 py-2" id="overallBadge">
            <%= order.status.replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase()) %>
          </span>
        </div>
      </div>

      <div class="row g-4">

        <!-- Left column: items -->
        <div class="col-lg-8">
          <div class="card bg-dark border-secondary">
            <div class="card-header border-secondary d-flex justify-content-between align-items-center">
              <span style="color:var(--admin-gold);font-weight:600;">Order Items</span>
              <!-- Quick overall status change -->
              <div class="d-flex align-items-center gap-2">
                <label class="text-info small mb-0">Overall:</label>
                <%
                  const isOrderLocked = ['cancelled','delivered','return_requested','returned'].includes(order.status);
                %>
                <% if (isOrderLocked) { %>
                  <%
                    const lockedColor = order.status === 'delivered'        ? 'success'
                                      : order.status === 'return_requested' ? 'warning'
                                      : order.status === 'returned'         ? 'info'
                                      :                                       'danger';
                  %>
                  <span class="badge bg-<%= lockedColor %> px-3 py-2">
                    <%= order.status.replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase()) %> — Locked
                  </span>
                <% } else { %>
                  <select class="form-select form-select-sm bg-dark text-light border-secondary" id="overallStatusSel" style="width:180px;">
                    <% ['pending','processing','shipped','out_for_delivery','delivered','cancelled','return_requested','returned'].forEach(s=>{ %>
                      <option value="<%= s %>" <%= order.status===s?'selected':'' %> style="background:#1a1a1a;">
                        <%= s.replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase()) %>
                      </option>
                    <% }) %>
                  </select>
                  <button class="btn btn-admin-primary btn-sm" id="applyOverallBtn">Apply</button>
                <% } %>
                
              </div>
            </div>
            <div class="card-body p-0">

              <% order.items.forEach(item => { %>
                <div class="border-bottom border-secondary p-3">
                  <!-- Product row -->
                  <div class="d-flex gap-3 align-items-start mb-3">
                    <% if (item.image) { %>
                      <img src="<%= item.image %>" alt="" style="width:60px;height:60px;object-fit:cover;border-radius:4px;">
                    <% } else { %>
                      <div style="width:60px;height:60px;background:#2a2a2a;border-radius:4px;display:flex;align-items:center;justify-content:center;">
                        <i class="fas fa-book text-info"></i>
                      </div>
                    <% } %>
                    <div class="flex-grow-1">
                      <div class="fw-semibold"><%= item.productName %></div>
                      <div class="text-info small">SKU: <%= item.sku || '—' %></div>
                      <div class="small mt-1">
                        $<%= item.price.toFixed(2) %> × <%= item.quantity %>
                        = <span class="text-warning fw-bold">$<%= item.lineTotal.toFixed(2) %></span>
                      </div>
                    </div>
                  </div>

                  <!-- Per-unit status table -->
                  <div class="table-responsive">
                    <table class="table table-sm table-dark mb-0" style="font-size:0.85rem;">
                      <thead>
                        <tr>
                          <th class="text-info fw-normal">Unit #</th>
                          <th class="text-info fw-normal">Status</th>
                          <th class="text-info fw-normal">Action</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% item.unitStatuses.forEach(u => { %>
                          <% const uc = {pending:'warning',processing:'info',shipped:'primary',out_for_delivery:'info',delivered:'success',cancelled:'danger'}; %>
                          <tr data-item-id="<%= item._id %>" data-unit="<%= u.unitIndex %>">
                            <td>Unit <%= u.unitIndex + 1 %></td>
                            <td>
                              <span class="badge bg-<%= uc[u.status]||'secondary' %> unit-status-badge">
                                <%= u.status.replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase()) %>
                              </span>
                            </td>
                            <td>
                              <% const unitLocked = ['cancelled','delivered','return_requested'].includes(order.status) || ['cancelled','return_requested','returned'].includes(item.itemStatus); %>
                              <% if (unitLocked) { %>
                                <span class="badge bg-<%= u.status==='cancelled'?'danger':u.status==='delivered'?'success':'warning' %> px-2 py-1">
                                  <%= u.status.replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase()) %>
                                  <i class="fas fa-lock ms-1" style="font-size:.6rem;opacity:.7;"></i>
                                </span>
                              <% } else { %>
                                <select class="form-select form-select-sm bg-dark text-light border-secondary unit-status-sel"
                                        style="width:150px;display:inline-block;"
                                        data-order-id="<%= order._id %>"
                                        data-item-id="<%= item._id %>"
                                        data-unit-index="<%= u.unitIndex %>">
                                  <% ['pending','processing','shipped','out_for_delivery','delivered','cancelled','return_requested','returned'].forEach(s=>{ %>
                                    <option value="<%= s %>" <%= u.status===s?'selected':'' %> style="background:#1a1a1a;">
                                      <%= s.replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase()) %>
                                    </option>
                                  <% }) %>
                                </select>
                                <button class="btn btn-sm btn-outline-warning ms-1 unit-save-btn"
                                        data-order-id="<%= order._id %>"
                                        data-item-id="<%= item._id %>"
                                        data-unit-index="<%= u.unitIndex %>">
                                  Save
                                </button>
                              <% } %>
                            </td>
                          </tr>
                        <% }) %>
                      </tbody>
                    </table>
                  </div>
                </div>
              <% }) %>

            </div><!-- /card-body -->
          </div>
        </div>

        <!-- Right column: summary -->
        <div class="col-lg-4">

          <!-- Customer -->
          <div class="card bg-dark border-secondary mb-3">
            <div class="card-header border-secondary" style="color:var(--admin-gold);font-weight:600;">
              Customer
            </div>
            <div class="card-body">
              <% if (order.userId) { %>
                <div class="fw-semibold"><%= order.userId.firstName %> <%= order.userId.lastName %></div>
                <div class="text-info small"><%= order.userId.email %></div>
                <% if (order.userId.phone) { %>
                  <div class="text-info small"><%= order.userId.phone %></div>
                <% } %>
              <% } else { %>
                <span class="text-info">Guest</span>
              <% } %>
            </div>
          </div>

          <!-- Shipping Address -->
          <div class="card bg-dark border-secondary mb-3">
            <div class="card-header border-secondary" style="color:var(--admin-gold);font-weight:600;">
              Shipping Address
            </div>
            <div class="card-body small text-info">
              <% const a = order.shippingAddress || {}; %>
              <%= a.addressLane1 || '—' %><br>
              <% if (a.addressLane2) { %><%= a.addressLane2 %><br><% } %>
              <%= a.city || '' %><% if (a.state) { %>, <%= a.state %><% } %><br>
              <%= a.pincode || '' %> <%= a.country || '' %>
            </div>
          </div>

          <!-- Order Summary -->
          <div class="card bg-dark border-secondary">
            <div class="card-header border-secondary" style="color:var(--admin-gold);font-weight:600;">
              Order Summary
            </div>
            <div class="card-body">
              <div class="d-flex justify-content-between mb-2">
                <span class="text-info">Subtotal</span>
                <span>$<%= order.subtotal.toFixed(2) %></span>
              </div>
              <div class="d-flex justify-content-between mb-2">
                <span class="text-info">Shipping</span>
                <span><%= order.shippingFee === 0 ? 'Free' : '$' + order.shippingFee.toFixed(2) %></span>
              </div>
              <hr class="border-secondary">
              <div class="d-flex justify-content-between fw-bold">
                <span>Total</span>
                <span class="text-warning">$<%= order.total.toFixed(2) %></span>
              </div>
              <div class="mt-3">
                <% const pc = {pending:'warning',paid:'success',refunded:'info'}; %>
                <span class="badge bg-<%= pc[order.paymentStatus]||'secondary' %>">
                  Payment: <%= order.paymentStatus.charAt(0).toUpperCase()+order.paymentStatus.slice(1) %>
                </span>
                <span class="badge bg-secondary ms-1"><%= order.paymentMethod.toUpperCase() %></span>
              </div>
            </div>
          </div>

        </div><!-- /col -->
      </div><!-- /row -->

    </div><!-- /admin-content -->
  </div><!-- /main-content -->
</body>

<script>
const ORDER_ID = '<%= order._id %>';

// ── Unit save button ──────────────────────────────────────────────────────────
document.querySelectorAll('.unit-save-btn').forEach(btn => {
  btn.addEventListener('click', async function () {
    const itemId    = this.dataset.itemId;
    const unitIndex = this.dataset.unitIndex;
    const row       = this.closest('tr');
    const sel       = row.querySelector('.unit-status-sel');
    const status    = sel.value;

    try {
      const res  = await fetch(`/admin/orders/${ORDER_ID}/items/${itemId}/units/${unitIndex}/status`, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ status }),
      });
      const data = await res.json();

      if (data.ok) {
        // Update badge
        const badge = row.querySelector('.unit-status-badge');
        const label = status.replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase());
        badge.textContent = label;
        badge.className = `badge unit-status-badge bg-${statusColor(status)}`;

        // Update overall badge
        const ob = document.getElementById('overallBadge');
        ob.textContent = data.orderStatus.replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase());
        ob.className = `badge fs-6 px-3 py-2 bg-${statusColor(data.orderStatus)}`;

        flashRow(row, 'rgba(255,193,7,0.1)');
      } else {
        alert('Error: ' + (data.message || 'Unknown'));
      }
    } catch (e) {
      alert('Network error');
    }
  });
});

// ── Overall status apply ──────────────────────────────────────────────────────
const applyBtn = document.getElementById('applyOverallBtn');
if (applyBtn) applyBtn.addEventListener('click', async function () {
  const status = document.getElementById('overallStatusSel').value;
  try {
    const res  = await fetch(`/admin/orders/${ORDER_ID}/status`, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ status }),
    });
    const data = await res.json();
    if (data.ok) {
      location.reload();
    } else {
      alert('Error: ' + (data.message || 'Unknown'));
    }
 } catch (e) {
    alert('Network error');
  }
});  // end if(applyBtn)

function statusColor(s) {
  const m = {pending:'warning',processing:'info',shipped:'primary',out_for_delivery:'info',delivered:'success',cancelled:'danger',return_requested:'warning',returned:'info'};
  return m[s] || 'secondary';
}

function flashRow(row, color) {
  row.style.transition = 'background .3s';
  row.style.background = color;
  setTimeout(() => { row.style.background = ''; }, 1200);
}
</script>
