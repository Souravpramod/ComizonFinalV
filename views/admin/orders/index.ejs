<%- include('../../partials/admin-head') %>

<body class="bg-black text-light">
  <%- include('../../partials/admin-sidebar') %>

  <div class="main-content">
    <%- include('../../partials/admin-header') %>

    <div class="admin-content p-4">

      <% if (locals.error) { %>
        <div class="alert alert-danger alert-dismissible fade show rounded-0" role="alert">
          <%= error %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>
      <% if (locals.success) { %>
        <div class="alert alert-success alert-dismissible fade show rounded-0" role="alert">
          <%= success %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>

      <!-- Page Header -->
      <div class="admin-header mb-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
          <div>
            <h4 class="mb-0" style="color: var(--admin-gold);">Order Management</h4>
            <p class="text-muted small mb-0">Track and manage customer orders</p>
          </div>
          <a href="/admin/orders/manage-requests" class="btn btn-warning btn-sm fw-bold rounded-0">
            <i class="fas fa-tasks me-1"></i> Manage Requests
          </a>
        </div>
      </div>

      <!-- Stats Cards -->
      <div class="row mb-4">
        <div class="col-lg-3 col-md-6 mb-3">
          <div class="admin-stat-card" style="border-left: 3px solid var(--admin-gold);">
            <div class="d-flex align-items-center gap-3">
              <div class="stat-icon" style="background: rgba(255,193,7,0.15); color: var(--admin-gold);">
                <i class="fas fa-shopping-cart"></i>
              </div>
              <div>
                <div class="stat-value text-warning"><%= stats.total || 0 %></div>
                <div class="stat-label text-muted small">Total Orders</div>
              </div>
            </div>
          </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
          <div class="admin-stat-card" style="border-left: 3px solid #28a745;">
            <div class="d-flex align-items-center gap-3">
              <div class="stat-icon" style="background: rgba(40,167,69,0.15); color: #28a745;">
                <i class="fas fa-check-circle"></i>
              </div>
              <div>
                <div class="stat-value" style="color:#28a745;"><%= stats.completed || 0 %></div>
                <div class="stat-label text-muted small">Delivered</div>
              </div>
            </div>
          </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
          <div class="admin-stat-card" style="border-left: 3px solid #17a2b8;">
            <div class="d-flex align-items-center gap-3">
              <div class="stat-icon" style="background: rgba(23,162,184,0.15); color: #17a2b8;">
                <i class="fas fa-clock"></i>
              </div>
              <div>
                <div class="stat-value" style="color:#17a2b8;"><%= stats.pending || 0 %></div>
                <div class="stat-label text-muted small">In Progress</div>
              </div>
            </div>
          </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
          <div class="admin-stat-card" style="border-left: 3px solid #dc3545;">
            <div class="d-flex align-items-center gap-3">
              <div class="stat-icon" style="background: rgba(220,53,69,0.15); color: #dc3545;">
                <i class="fas fa-times-circle"></i>
              </div>
              <div>
                <div class="stat-value text-danger"><%= stats.cancelled || 0 %></div>
                <div class="stat-label text-muted small">Cancelled</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Search / Filter Bar -->
      <form method="GET" action="/admin/orders" id="filterForm">
        <div class="row mb-4 align-items-end">
          <div class="col-lg-4 col-md-6 mb-2">
            <div class="input-group">
              <span class="input-group-text bg-dark border-secondary text-muted"><i class="fas fa-search"></i></span>
              <input type="text" class="form-control bg-dark text-light border-secondary"
                     name="search" placeholder="Search by Order ID or customer…"
                     value="<%= locals.search || '' %>">
            </div>
          </div>
          <div class="col-lg-2 col-md-4 mb-2">
            <select class="form-select bg-dark text-light border-secondary" name="status">
              <option value="">All Status</option>
              <% ['pending','processing','shipped','out_for_delivery','delivered','cancelled','return_requested','failed'].forEach(s => { %>
                <option value="<%= s %>" <%= (locals.status === s) ? 'selected' : '' %>>
                  <%= s.replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase()) %>
                </option>
              <% }) %>
            </select>
          </div>
          <div class="col-lg-2 col-md-4 mb-2">
            <select class="form-select bg-dark text-light border-secondary" name="sort">
              <option value="newest"     <%= (locals.sort==='newest')     ? 'selected':'' %>>Newest First</option>
              <option value="oldest"     <%= (locals.sort==='oldest')     ? 'selected':'' %>>Oldest First</option>
              <option value="total_desc" <%= (locals.sort==='total_desc') ? 'selected':'' %>>Total (High–Low)</option>
              <option value="total_asc"  <%= (locals.sort==='total_asc')  ? 'selected':'' %>>Total (Low–High)</option>
            </select>
          </div>
          <div class="col-lg-1 col-md-2 mb-2">
            <button type="submit" class="btn btn-admin-primary w-100">Go</button>
          </div>
          <div class="col-lg-1 col-md-2 mb-2">
            <a href="/admin/orders" class="btn btn-outline-secondary w-100" title="Clear filters">
              <i class="fas fa-times"></i>
            </a>
          </div>
        </div>
      </form>

      <!-- Orders Table -->
      <div class="admin-table">
        <table class="table table-dark table-hover mb-0">
          <thead>
            <tr>
              <th style="color:var(--admin-gold);">ORDER ID</th>
              <th style="color:var(--admin-gold);">DATE</th>
              <th style="color:var(--admin-gold);">CUSTOMER</th>
              <th style="color:var(--admin-gold);">ITEMS</th>
              <th style="color:var(--admin-gold);">TOTAL</th>
              <th style="color:var(--admin-gold);">STATUS</th>
              <th style="color:var(--admin-gold);">PAYMENT</th>
              <th style="color:var(--admin-gold);">ACTION</th>
            </tr>
          </thead>
          <tbody>
            <% if (!orders || orders.length === 0) { %>
              <tr>
                <td colspan="8" class="text-center text-muted py-4">No orders found</td>
              </tr>
            <% } else { %>
              <% orders.forEach(order => { %>
                <tr>
                  <td>
                    <span class="fw-bold text-warning">#<%= order.orderId %></span>
                  </td>
                  <td>
                    <div class="small"><%= new Date(order.orderedAt).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) %></div>
                    <div class="text-muted" style="font-size:0.75rem;"><%= new Date(order.orderedAt).toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'}) %></div>
                  </td>
                  <td>
                    <% if (order.userId) { %>
                      <div class="fw-semibold"><%= order.userId.firstName %> <%= order.userId.lastName %></div>
                      <div class="text-muted small"><%= order.userId.email %></div>
                    <% } else { %>
                      <span class="text-muted">—</span>
                    <% } %>
                  </td>
                  <td>
                    <span class="badge bg-secondary"><%= order.items.reduce((n,i)=>n+i.quantity,0) %> item(s)</span>
                  </td>
                  <td class="text-warning fw-bold">$<%= order.total.toFixed(2) %></td>
                  <td>
                    <% const LOCKED = ['cancelled','delivered','return_requested','returned','out_for_delivery','failed'];
                       const isLocked = LOCKED.includes(order.status);
                       const statusColors = {
                         pending:'warning', processing:'info', shipped:'primary',
                         out_for_delivery:'info', delivered:'success',
                         cancelled:'danger', return_requested:'warning',
                         returned:'secondary', failed:'danger'
                       }; %>
                    <% if (isLocked) { %>
                      <span class="badge bg-<%= statusColors[order.status]||'secondary' %> px-2 py-1" style="font-size:.75rem;">
                        <%= order.status.replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase()) %>
                        <i class="fas fa-lock ms-1" style="font-size:.6rem;opacity:.7;"></i>
                      </span>
                    <% } else { %>
                      <select class="form-select form-select-sm bg-dark text-light border-0 status-select"
                              style="min-width:150px;"
                              data-order-id="<%= order._id %>"
                              data-original="<%= order.status %>">
                        <% ['pending','processing','shipped','out_for_delivery','delivered','cancelled','return_requested','returned'].forEach(s => { %>
                          <option value="<%= s %>" <%= order.status === s ? 'selected':'' %>
                            style="background:#1a1a1a;">
                            <%= s.replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase()) %>
                          </option>
                        <% }) %>
                      </select>
                    <% } %>
                  </td>
                  <td>
                    <% const payColors = {pending:'warning', paid:'success', refunded:'info', failed:'danger'}; %>
                    <span class="badge bg-<%= payColors[order.paymentStatus] || 'secondary' %>">
                      <%= order.paymentStatus.charAt(0).toUpperCase() + order.paymentStatus.slice(1) %>
                    </span>
                  </td>
                  <td>
                    <a href="/admin/orders/<%= order._id %>" class="btn btn-sm" style="color:#17a2b8;" title="View Detail">
                      <i class="fas fa-eye"></i>
                    </a>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>
        <div class="d-flex justify-content-between align-items-center mt-4 flex-wrap gap-2">
          <span class="text-muted small">
            Showing <%= ((currentPage-1)*10)+1 %>–<%= Math.min(currentPage*10, totalOrders) %> of <%= totalOrders %> orders
          </span>
          <nav>
            <ul class="pagination pagination-sm mb-0">
              <li class="page-item <%= currentPage===1?'disabled':'' %>">
                <a class="page-link bg-dark text-light border-secondary"
                   href="?page=<%= currentPage-1 %>&search=<%= search %>&status=<%= status %>&sort=<%= sort %>">
                  &laquo;
                </a>
              </li>
              <% for(let p=1;p<=totalPages;p++){ %>
                <% if(p===1||p===totalPages||Math.abs(p-currentPage)<=1){ %>
                  <li class="page-item <%= p===currentPage?'active':'' %>">
                    <a class="page-link <%= p===currentPage?'bg-warning text-dark border-warning':'bg-dark text-light border-secondary' %>"
                       href="?page=<%= p %>&search=<%= search %>&status=<%= status %>&sort=<%= sort %>">
                      <%= p %>
                    </a>
                  </li>
                <% } else if(Math.abs(p-currentPage)===2){ %>
                  <li class="page-item disabled"><span class="page-link bg-dark text-muted border-secondary">…</span></li>
                <% } %>
              <% } %>
              <li class="page-item <%= currentPage===totalPages?'disabled':'' %>">
                <a class="page-link bg-dark text-light border-secondary"
                   href="?page=<%= currentPage+1 %>&search=<%= search %>&status=<%= status %>&sort=<%= sort %>">
                  &raquo;
                </a>
              </li>
            </ul>
          </nav>
        </div>
      <% } %>

    </div><!-- /admin-content -->
  </div><!-- /main-content -->
</body>

<script>

  function showToast(msg, type='danger') {
    const id = 'toast_' + Date.now();
    const bg = type === 'success' ? 'bg-success' : type === 'warning' ? 'bg-warning text-dark' : 'bg-danger';
    const el = document.createElement('div');
    el.id = id;
    el.className = `toast align-items-center text-white border-0 ${bg} position-fixed rounded-0`;
    el.style.cssText = 'top:80px;right:20px;z-index:9999;min-width:280px;';
    el.setAttribute('role','alert');
    el.innerHTML = `<div class="d-flex"><div class="toast-body fw-semibold">${msg}</div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div>`;
    document.body.appendChild(el);
    const t = new bootstrap.Toast(el, { delay: 4000 });
    t.show();
    el.addEventListener('hidden.bs.toast', () => el.remove());
}
// Inline status change via AJAX
document.querySelectorAll('.status-select').forEach(sel => {
  sel.addEventListener('change', async function () {
    const orderId = this.dataset.orderId;
    const status  = this.value;
    const orig    = this.dataset.original || status;

    try {
      const res  = await fetch(`/admin/orders/${orderId}/status`, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ status }),
      });
      const data = await res.json();

      if (!data.ok) {
        showToast('Failed to update status: ' + (data.message || 'Unknown error'));
        this.value = orig;
      } else {
        // Flash row green briefly
        const row = this.closest('tr');
        row.style.transition = 'background .3s';
        row.style.background = 'rgba(40,167,69,0.15)';
        setTimeout(() => { row.style.background = ''; }, 1200);
      }
    } catch (e) {
      showToast('Network error. Please try again.');
      this.value = orig;
    }
  });
});
</script>
