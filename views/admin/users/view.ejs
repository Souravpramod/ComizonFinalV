<%- include('../../partials/admin-head') %>

<body class="bg-black text-light">
  <%- include('../../partials/admin-sidebar') %>
  <div class="main-content">
    <%- include('../../partials/admin-header') %>
    <div class="admin-content p-4">

      <!-- Page Header -->
      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h4 class="fw-bold text-uppercase text-white mb-0">User Details</h4>
          <p class="text-info small mb-0">Read-only profile view</p>
        </div>
        <a href="/admin/users" class="btn btn-outline-light rounded-2">
          <i class="fas fa-arrow-left me-2"></i>Back to Users
        </a>
      </div>

      <div class="row g-4">

        <!-- LEFT: Avatar + identity card -->
        <div class="col-md-4">
          <div class="card bg-dark border-0 rounded-3 shadow-sm h-100"
            style="border-top: 3px solid #f39c12 !important;">
            <div class="card-body p-4 text-center">

              <%
                let avatarColor = 'bg-primary bg-opacity-25 text-primary';
                if (user.role === 'admin')   avatarColor = 'bg-danger bg-opacity-25 text-danger';
                else if (user.isPremium)     avatarColor = 'bg-warning bg-opacity-25 text-warning';
              %>
              <% if (user.profilePhoto) { %>
                <img src="<%= user.profilePhoto %>" alt="<%= user.firstName %>"
                  class="rounded-circle mx-auto mb-3 d-block object-fit-cover"
                  style="width:80px;height:80px;">
              <% } else { %>
                <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold mx-auto mb-3 <%= avatarColor %>"
                  style="width:80px;height:80px;font-size:2rem;">
                  <%= user.firstName ? user.firstName.charAt(0).toUpperCase() : '?' %>
                </div>
              <% } %>

              <h5 class="text-white fw-bold mb-0">
                <%= user.firstName %> <%= user.lastName %>
              </h5>
              <p class="text-info small mb-3">ID: USR-<%= user._id.toString().slice(-3).toUpperCase() %></p>

              <!-- Role badge -->
              <% if (user.role === 'admin') { %>
                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger rounded-1 px-3 py-2 fs-6">
                  <i class="fas fa-user-shield me-1"></i>Admin
                </span>
              <% } else if (user.isPremium) { %>
                <span class="badge bg-warning bg-opacity-10 text-warning border border-warning rounded-1 px-3 py-2 fs-6">
                  <i class="fas fa-crown me-1"></i>Premium User
                </span>
              <% } else { %>
                <span class="badge bg-info bg-opacity-10 text-info border border-info rounded-1 px-3 py-2 fs-6">
                  <i class="fas fa-user me-1"></i>User
                </span>
              <% } %>

              <!-- Active / Blocked status -->
              <div class="mt-3">
                <span class="badge rounded-1 px-3 py-2 fs-6
                  <%= user.isBlocked
                      ? 'bg-danger bg-opacity-10 border border-danger text-danger'
                      : 'bg-success bg-opacity-10 border border-success text-success' %>">
                  <i class="fas <%= user.isBlocked ? 'fa-ban' : 'fa-check-circle' %> me-1"></i>
                  <%= user.isBlocked ? 'Suspended' : 'Active' %>
                </span>
              </div>

            </div>
          </div>
        </div>

        <!-- RIGHT: Info fields -->
        <div class="col-md-8">
          <div class="card bg-dark border-0 rounded-3 shadow-sm"
            style="border-top: 3px solid #2ecc71 !important;">
            <div class="card-body p-4">

              <h6 class="text-warning text-uppercase small fw-bold mb-3">Account Information</h6>

              <div class="row g-3">

                <div class="col-md-6">
                  <p class="text-info small mb-1 text-uppercase fw-bold">First Name</p>
                  <p class="text-white mb-0"><%= user.firstName || '—' %></p>
                </div>

                <div class="col-md-6">
                  <p class="text-info small mb-1 text-uppercase fw-bold">Last Name</p>
                  <p class="text-white mb-0"><%= user.lastName || '—' %></p>
                </div>

                <div class="col-md-6">
                  <p class="text-info small mb-1 text-uppercase fw-bold">Username</p>
                  <p class="text-white mb-0"><%= user.username || '—' %></p>
                </div>

                <div class="col-md-6">
                  <p class="text-info small mb-1 text-uppercase fw-bold">Email</p>
                  <p class="text-white mb-0"><%= user.email %></p>
                </div>

                <div class="col-md-6">
                  <p class="text-info small mb-1 text-uppercase fw-bold">Gender</p>
                  <p class="text-white mb-0 text-capitalize"><%= user.gender || '—' %></p>
                </div>

                <div class="col-md-6">
                  <p class="text-info small mb-1 text-uppercase fw-bold">Role</p>
                  <p class="text-white mb-0 text-capitalize">
                    <% if (user.isPremium && user.role !== 'admin') { %>
                      Premium User
                    <% } else { %>
                      <%= user.role || 'user' %>
                    <% } %>
                  </p>
                </div>

                <div class="col-md-6">
                  <p class="text-info small mb-1 text-uppercase fw-bold">Account Status</p>
                  <p class="mb-0">
                    <span class="<%= user.isActive ? 'text-success' : 'text-danger' %> fw-bold">
                      <%= user.isActive ? 'Active' : 'Inactive' %>
                    </span>
                  </p>
                </div>

                <div class="col-md-6">
                  <p class="text-info small mb-1 text-uppercase fw-bold">Blocked</p>
                  <p class="mb-0">
                    <span class="<%= user.isBlocked ? 'text-danger' : 'text-success' %> fw-bold">
                      <%= user.isBlocked ? 'Yes — Suspended' : 'Not-Blocked' %>
                    </span>
                  </p>
                </div>

                <div class="col-md-6">
                  <p class="text-info small mb-1 text-uppercase fw-bold">Joined Date</p>
                  <p class="text-white mb-0">
                    <%= new Date(user.createdAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %>
                  </p>
                </div>

                <div class="col-md-6">
                  <p class="text-info small mb-1 text-uppercase fw-bold">Last Login</p>
                  <p class="text-white mb-0">
                    <% if (user.lastLogin) { %>
                      <%= new Date(user.lastLogin).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %>
                      &nbsp;<span class="text-info small">
                        <%= new Date(user.lastLogin).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %>
                      </span>
                    <% } else { %>
                      <span class="text-info">Never logged in</span>
                    <% } %>
                  </p>
                </div>

              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>