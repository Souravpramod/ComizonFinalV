<%- include('../../partials/admin-head') %>

  <body class="bg-black text-light">
    <%- include('../../partials/admin-sidebar') %>
      <div class="main-content">
        <%- include('../../partials/admin-header') %>
          <div class="admin-content p-4">

           
            <% if (locals.error) { %>
              <div class="alert alert-danger alert-dismissible fade show rounded-0" role="alert">
                <%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
              </div>
            <% } %>

                <!-- Header -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                  <div>
                    <h4 class="fw-bold text-uppercase text-white mb-0">User Management</h4>
                    <p class="text-muted small mb-0">Manage users and their roles</p>
                  </div>
                  <div class="d-flex gap-2">
                    <button class="btn btn-outline-light rounded-2"><i class="fas fa-download me-2"></i>Export
                      Users</button>
                    <button class="btn btn-warning text-dark fw-bold rounded-2 px-3" data-bs-toggle="modal"
                      data-bs-target="#addUserModal">
                      <i class="fas fa-user-plus me-2"></i>Add User
                    </button>
                  </div>
                </div>

                <!-- Summary Cards -->
                <div class="row g-4 mb-4">
                  <!-- Total Users -->
                  <div class="col-md-3">
                    <div class="card bg-dark border-0 rounded-3 shadow-sm h-100"
                      style="border-top: 3px solid #f39c12 !important;">
                      <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                          <div class="bg-primary bg-opacity-10 p-3 rounded-3 text-primary">
                            <i class="fas fa-users fs-4"></i>
                          </div>
                        </div>
                        <p class="text-muted text-uppercase small fw-bold mb-1">Total Users</p>
                        <h2 class="text-white mb-0 fw-bold">
                          <%= locals.allUsersCount || 0 %>
                        </h2>
                      </div>
                    </div>
                  </div>

                  <!-- Regular Users -->
                  <div class="col-md-3">
                    <div class="card bg-dark border-0 rounded-3 shadow-sm h-100"
                      style="border-top: 3px solid #2ecc71 !important;">
                      <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                          <div class="bg-success bg-opacity-10 p-3 rounded-3 text-success">
                            <i class="fas fa-user fs-4"></i>
                          </div>
                        </div>
                        <p class="text-muted text-uppercase small fw-bold mb-1">Regular Users</p>
                        <h2 class="text-white mb-0 fw-bold">
                          <%= locals.regularCount || 0 %>
                        </h2>
                      </div>
                    </div>
                  </div>

                  <!-- Premium Members -->
                  <div class="col-md-3">
                    <div class="card bg-dark border-0 rounded-3 shadow-sm h-100"
                      style="border-top: 3px solid #f1c40f !important;">
                      <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                          <div class="bg-warning bg-opacity-10 p-3 rounded-3 text-warning">
                            <i class="fas fa-crown fs-4"></i>
                          </div>
                        </div>
                        <p class="text-muted text-uppercase small fw-bold mb-1">Premium Members</p>
                        <h2 class="text-white mb-0 fw-bold">
                          <%= locals.premiumCount || 0 %>
                        </h2>
                      </div>
                    </div>
                  </div>

                  <!-- Administrators -->
                  <div class="col-md-3">
                    <div class="card bg-dark border-0 rounded-3 shadow-sm h-100"
                      style="border-top: 3px solid #e74c3c !important;">
                      <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                          <div class="bg-danger bg-opacity-10 p-3 rounded-3 text-danger">
                            <i class="fas fa-user-shield fs-4"></i>
                          </div>
                        </div>
                        <p class="text-muted text-uppercase small fw-bold mb-1">Administrators</p>
                        <h2 class="text-white mb-0 fw-bold">
                          <%= locals.adminCount || 0 %>
                        </h2>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Search & Filter -->
                <div class="d-flex flex-wrap gap-3 justify-content-between align-items-center mb-4">
                  <form action="/admin/users" method="GET" class="d-flex gap-3 flex-grow-1" id="searchForm">
                    <div class="input-group" style="max-width: 400px;">
                      <span class="input-group-text bg-dark border-secondary text-muted rounded-start-2"><i
                          class="fas fa-search"></i></span>
                      <input type="text" name="search" id="searchInput"
                        class="form-control bg-dark border-secondary text-white" placeholder="Search by name, email..."
                        value="<%= locals.search || '' %>">
                      <% if (locals.search) { %>
                        <a href="/admin/users" class="btn btn-outline-secondary" title="Clear search"><i
                            class="fas fa-times"></i></a>
                        <% } %>
                    </div>

                    <select name="role" class="form-select bg-dark border-secondary text-white w-auto"
                      onchange="this.form.submit()">
                      <option value="">All Roles</option>
                      <option value="user" <%=locals.role==='user' ?'selected':''%>>Regular</option>
                      <option value="premium" <%=locals.role==='premium' ?'selected':''%>>Premium</option>
                      <option value="admin" <%=locals.role==='admin' ?'selected':''%>>Admin</option>
                    </select>

                    <select name="status" class="form-select bg-dark border-secondary text-white w-auto"
                      onchange="this.form.submit()">
                      <option value="">All Status</option>
                      <option value="active" <%=locals.status==='active' ?'selected':''%>>Active</option>
                      <option value="blocked" <%=locals.status==='blocked' ?'selected':''%>>Suspended</option>
                    </select>

                    <select name="sort" class="form-select bg-dark border-secondary text-white w-auto"
                      onchange="this.form.submit()">
                      <option value="newest" <%=locals.sort==='newest' ?'selected':''%>>Sort by: Newest</option>
                      <option value="oldest" <%=locals.sort==='oldest' ?'selected':''%>>Sort by: Oldest</option>
                      <option value="az" <%=locals.sort==='az' ?'selected':''%>>Sort A–Z</option>
                    </select>

                    <button type="button" class="btn btn-outline-light rounded-2"><i class="fas fa-filter me-2"></i>More
                      Filters</button>
                  </form>
                </div>

                <!-- Users Table -->
                <div class="card rounded-3 border-0 overflow-hidden bg-white shadow-sm">
                  <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 bg-white">
                      <thead class="bg-white">
                        <tr class="text-uppercase text-warning small fw-bold" style="border-bottom: 2px solid #eee;">
                          <th class="py-3 px-4 border-0">User</th>
                          <th class="py-3 border-0">Email</th>
                          <th class="py-3 border-0">Role</th>
                          <th class="py-3 border-0 text-center">Premium</th>
                          <th class="py-3 border-0 text-center">Orders</th>
                          <th class="py-3 border-0">Total Spent</th>
                          <th class="py-3 border-0">Status</th>
                          <th class="py-3 border-0">Joined Date</th>
                          <th class="py-3 px-4 text-center border-0">Actions</th>
                        </tr>
                      </thead>
                      <tbody class="border-top-0">
                        <% if (locals.users && users.length> 0) { %>
                          <% users.forEach((user)=> { %>
                            <tr class="fw-medium text-dark" style="border-bottom: 1px solid #f1f1f1;">
                              <td class="px-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                  <% let avatarColor='bg-info bg-opacity-25 text-info' ; if (user.role==='admin' )
                                    avatarColor='bg-danger bg-opacity-25 text-danger' ; else if (user.isPremium)
                                    avatarColor='bg-warning bg-opacity-25 text-warning' ; else
                                    avatarColor='bg-primary bg-opacity-25 text-primary text-opacity-75' ; %>
                                    <div
                                      class="rounded-circle d-flex align-items-center justify-content-center fw-bold <%= avatarColor %>"
                                      style="width:40px;height:40px;font-size:1.1rem;min-width:40px; background-color: #f1f3f5;">
                                      <%= user.firstName.charAt(0).toUpperCase() %>
                                    </div>
                                    <div>
                                      <div class="text-dark fw-bold" style="font-size: 0.95rem;">
                                        <%= user.firstName %>
                                          <%= user.lastName %>
                                      </div>
                                      <div class="text-muted small">ID: USR-<%=
                                          user._id.toString().slice(-3).toUpperCase() %>
                                      </div>
                                    </div>
                                </div>
                              </td>
                              <td class="text-secondary" style="font-size: 0.9rem;">
                                <%= user.email %>
                              </td>
                              <td>
                                <% if (user.role==='admin' ) { %>
                                  <span
                                    class="badge bg-danger bg-opacity-10 text-danger border border-danger rounded-1 px-2 py-1"><i
                                      class="fas fa-user-shield me-1"></i>Admin</span>
                                  <% } else if (user.isPremium) { %>
                                    <span
                                      class="badge bg-warning bg-opacity-10 text-warning border border-warning rounded-1 px-2 py-1"><i
                                        class="fas fa-crown me-1"></i>Premium</span>
                                    <% } else { %>
                                      <span
                                        class="badge bg-info bg-opacity-10 text-info border border-info rounded-1 px-2 py-1"><i
                                          class="fas fa-user me-1"></i>User</span>
                                      <% } %>
                              </td>
                              <td class="text-secondary text-center fw-bold" style="font-size: 0.9rem;">
                                <%= user.isPremium ? 'Yes' : 'No' %>
                              </td>
                              <td class="text-secondary text-center" style="font-size: 0.9rem;">
                                <% if (user.role==='admin' ) { %>
                                  -
                                  <% } else { %>
                                    0
                                    <% } %>
                              </td>
                              <td class="text-warning fw-bold" style="font-size: 0.9rem;">
                                <% if (user.role==='admin' ) { %>
                                  <span class="text-secondary fw-normal">-</span>
                                  <% } else { %>
                                    ₹0.00
                                    <% } %>
                              </td>
                              <td>
                                <span
                                  class="badge rounded-1 px-2 py-1 <%= user.isBlocked ? 'bg-danger bg-opacity-10 border border-danger text-danger' : 'bg-success bg-opacity-10 border border-success text-success' %>">
                                  <%= user.isBlocked ? 'Suspended' : 'Active' %>
                                </span>
                              </td>
                              <td class="text-secondary" style="font-size: 0.9rem;">
                                <%= new Date(user.createdAt).toLocaleDateString('en-US', {month:'short', day:'numeric',
                                  year:'numeric'}) %>
                              </td>
                              <td class="px-4 text-center">
                                <div class="d-flex justify-content-center gap-2">
                                  <!-- View -->
                                  <a href="/admin/users/view/<%= user._id %>"
                                    class="btn btn-sm d-flex align-items-center justify-content-center rounded-circle"
                                    style="width: 32px; height: 32px; background-color: #e8f5e9; color: #2e7d32; text-decoration: none;"
                                    title="View User">
                                    <i class="fas fa-eye"></i>
                                  </a>

                                  <!-- Edit -->
                                  <button type="button"
                                    class="btn btn-sm d-flex align-items-center justify-content-center rounded-circle border-0"
                                    style="width: 32px; height: 32px; background-color: #e3f2fd; color: #1565c0;"
                                    title="Edit User"
                                    onclick="openEditModal('<%= user._id %>', '<%= user.firstName %>', '<%= user.lastName %>', '<%= user.email %>', '<%= user.role === `admin` ? `admin` : `user` %>', '<%= user.isPremium %>', '<%= user.isBlocked ? `blocked` : `active` %>')">
                                    <i class="fas fa-user-edit"></i>
                                  </button>

                                  <!-- Suspend/Activate -->
                                  <form action="/admin/users/toggle-block/<%= user._id %>" method="POST" class="m-0 p-0"
                                    onsubmit="return confirm('<%= user.isBlocked ? `Activate` : `Suspend` %> user <%= user.firstName %>?');">
                                    <% if (user.isBlocked) { %>
                                      <button type="submit"
                                        class="btn btn-sm d-flex align-items-center justify-content-center rounded-circle border-0"
                                        style="width: 32px; height: 32px; background-color: #e8f5e9; color: #4caf50;"
                                        title="Activate User">
                                        <i class="fas fa-check"></i>
                                      </button>
                                      <% } else { %>
                                        <button type="submit"
                                          class="btn btn-sm d-flex align-items-center justify-content-center rounded-circle border-0"
                                          style="width: 32px; height: 32px; background-color: #ffebee; color: #ef5350;"
                                          title="Suspend User">
                                          <i class="fas fa-ban"></i>
                                        </button>
                                        <% } %>
                                  </form>

                                  <!-- Delete -->
                                  <form action="/admin/users/delete/<%= user._id %>" method="POST" class="m-0 p-0"
                                    onsubmit="return confirm('Are you sure you want to completely delete user <%= user.firstName %>? This action cannot be undone.');">
                                    <button type="submit"
                                      class="btn btn-sm d-flex align-items-center justify-content-center rounded-circle border-0"
                                      style="width: 32px; height: 32px; background-color: #ffebee; color: #c62828;"
                                      title="Delete User">
                                      <i class="fas fa-trash"></i>
                                    </button>
                                  </form>
                                </div>
                              </td>
                            </tr>
                            <% }) %>
                              <% } else { %>
                                <tr>
                                  <td colspan="8" class="text-center py-5 text-muted bg-white">
                                    <i class="fas fa-users fs-1 mb-3 d-block opacity-25"></i>
                                    No users found matching your criteria.
                                    <% if (locals.search || locals.role || locals.status) { %>
                                      <br><a href="/admin/users"
                                        class="text-warning text-decoration-none mt-2 d-inline-block">Clear all
                                        filters</a>
                                      <% } %>
                                  </td>
                                </tr>
                                <% } %>
                      </tbody>
                    </table>
                  </div>

                  <!-- Pagination -->
                  <div class="p-3 border-top d-flex justify-content-between align-items-center flex-wrap gap-2 bg-dark">
                    <p class="text-muted mb-0 small">
                      Showing <%= locals.users ? users.length : 0 %> of <%= locals.totalUsers || 0 %> users
                    </p>
                    <% const tp=locals.totalPages || 1; const cp=locals.currentPage || 1; %>
                      <% if (tp> 1) { %>
                        <nav>
                          <ul class="pagination pagination-sm mb-0">
                            <li class="page-item <%= cp===1?'disabled':'' %>">
                              <a class="page-link bg-dark border-secondary text-white rounded-start"
                                href="/admin/users?page=<%= cp-1 %>&search=<%= locals.search||'' %>&role=<%= locals.role||'' %>&status=<%= locals.status||'' %>&sort=<%= locals.sort||'newest' %>">
                                <i class="fas fa-chevron-left"></i>
                              </a>
                            </li>
                            <% for(let i=1;i<=tp;i++){ %>
                              <li class="page-item <%= i===cp?'active':'' %>">
                                <a class="page-link <%= i===cp?'bg-warning border-warning text-dark fw-bold':'bg-dark border-secondary text-white' %>"
                                  href="/admin/users?page=<%= i %>&search=<%= locals.search||'' %>&role=<%= locals.role||'' %>&status=<%= locals.status||'' %>&sort=<%= locals.sort||'newest' %>">
                                  <%= i %>
                                </a>
                              </li>
                              <% } %>
                                <li class="page-item <%= cp===tp?'disabled':'' %>">
                                  <a class="page-link bg-dark border-secondary text-white rounded-end"
                                    href="/admin/users?page=<%= cp+1 %>&search=<%= locals.search||'' %>&role=<%= locals.role||'' %>&status=<%= locals.status||'' %>&sort=<%= locals.sort||'newest' %>">
                                    <i class="fas fa-chevron-right"></i>
                                  </a>
                                </li>
                          </ul>
                        </nav>
                        <% } %>
                  </div>
                </div>
          </div>
      </div>

      <!-- Add User Modal -->
      <!-- Add User Modal -->
      <% if (locals.openAddModal) { %>
      <script>
        document.addEventListener('DOMContentLoaded', function () {
          new bootstrap.Modal(document.getElementById('addUserModal')).show();
        });
      </script>
      <% } %>
      <div class="modal fade" id="addUserModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
          <div class="modal-content text-white"
            style="background-color: #1a1a1a; border: 2px solid #ffcc00; border-radius: 8px;">
            <div class="modal-header border-0 pb-0">
              <div>
                <h4 class="modal-title fw-bold text-warning"><i class="fas fa-user-plus me-2"></i>Add New User</h4>
                <p class="text-muted small mb-0 ms-4">Create your account to start your collection.</p>
              </div>
            </div>
            <form action="/admin/users" method="POST">
              <div class="modal-body px-4">

                <!-- PERSONAL INFORMATION -->
                <h6 class="text-warning small fw-bold mt-2 text-uppercase">Personal Information</h6>
                <div class="row g-3 mb-4">
                  <div class="col-md-4">
                    <label class="form-label small text-light">First Name</label>
                    <input type="text" name="firstName"
                      class="form-control bg-dark text-white border-0 shadow-none <%= (locals.addFieldErrors && locals.addFieldErrors.firstName) ? 'is-invalid' : '' %>"
                      value="<%= (locals.addFormData && locals.addFormData.firstName) ? locals.addFormData.firstName : '' %>">
                    <% if (locals.addFieldErrors && locals.addFieldErrors.firstName) { %>
                      <div class="invalid-feedback"><%= locals.addFieldErrors.firstName %></div>
                    <% } %>
                  </div>
                  <div class="col-md-4">
                    <label class="form-label small text-light">Last Name</label>
                    <input type="text" name="lastName"
                      class="form-control bg-dark text-white border-0 shadow-none <%= (locals.addFieldErrors && locals.addFieldErrors.lastName) ? 'is-invalid' : '' %>"
                      value="<%= (locals.addFormData && locals.addFormData.lastName) ? locals.addFormData.lastName : '' %>">
                    <% if (locals.addFieldErrors && locals.addFieldErrors.lastName) { %>
                      <div class="invalid-feedback"><%= locals.addFieldErrors.lastName %></div>
                    <% } %>
                  </div>
                  <div class="col-md-4">
                    <label class="form-label small text-light">Gender</label>
                    <select name="gender" class="form-select bg-dark text-white border-0 shadow-none">
                      <option value="">Select Gender</option>
                      <option value="male"   <%= (locals.addFormData && locals.addFormData.gender === 'male')   ? 'selected' : '' %>>Male</option>
                      <option value="female" <%= (locals.addFormData && locals.addFormData.gender === 'female') ? 'selected' : '' %>>Female</option>
                      <option value="other"  <%= (locals.addFormData && locals.addFormData.gender === 'other')  ? 'selected' : '' %>>Other</option>
                    </select>
                  </div>
                </div>

                <!-- ACCOUNT DETAILS -->
                <h6 class="text-warning small fw-bold text-uppercase">Account Details</h6>
                <div class="row g-3 mb-4">
                  <div class="col-md-6">
                    <label class="form-label small text-light">Username</label>
                    <input type="text" name="username" class="form-control bg-dark text-white border-0 shadow-none"
                      value="<%= (locals.addFormData && locals.addFormData.username) ? locals.addFormData.username : '' %>">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label small text-light">Email Address</label>
                    <input type="email" name="email"
                      class="form-control bg-dark text-white border-0 shadow-none <%= (locals.addFieldErrors && locals.addFieldErrors.email) ? 'is-invalid' : '' %>"
                      value="<%= (locals.addFormData && locals.addFormData.email) ? locals.addFormData.email : '' %>">
                    <% if (locals.addFieldErrors && locals.addFieldErrors.email) { %>
                      <div class="invalid-feedback"><%= locals.addFieldErrors.email %></div>
                    <% } %>
                  </div>
                  ...
                  <div class="col-md-4">
                    <label class="form-label small text-light">Password_hash</label>
                    <input type="password" name="password"
                      class="form-control bg-dark text-white border-0 shadow-none <%= (locals.addFieldErrors && locals.addFieldErrors.password) ? 'is-invalid' : '' %>"
                      minlength="6">
                    <% if (locals.addFieldErrors && locals.addFieldErrors.password) { %>
                      <div class="invalid-feedback"><%= locals.addFieldErrors.password %></div>
                    <% } %>
                  </div>
                  <div class="col-md-2">
                    <label class="form-label small text-light">Premium</label>
                    <select name="isPremium" class="form-select bg-dark text-white border-0 shadow-none">
                      <option value="false">NO</option>
                      <option value="true">YES</option>
                    </select>
                  </div>
                </div>

                <!-- ADDRESS -->
                <h6 class="text-warning small fw-bold text-uppercase">Address</h6>
                <div class="row g-3">
                  <div class="col-12">
                    <label class="form-label small text-light">Address Line 1</label>
                    <input type="text" name="addressLane1" class="form-control bg-dark text-white border-0 shadow-none"
                      placeholder="Street address, P.O. box">
                  </div>
                  <div class="col-12">
                    <label class="form-label small text-light">Address Line 2 (optional)</label>
                    <input type="text" name="addressLane2" class="form-control bg-dark text-white border-0 shadow-none"
                      placeholder="Apartment, suite, unit, etc.">
                  </div>
                  <div class="col-md-4">
                    <label class="form-label small text-light">City</label>
                    <input type="text" name="city" class="form-control bg-dark text-white border-0 shadow-none">
                  </div>
                  <div class="col-md-4">
                    <label class="form-label small text-light">State/Province</label>
                    <input type="text" name="state" class="form-control bg-dark text-white border-0 shadow-none">
                  </div>
                  <div class="col-md-4">
                    <label class="form-label small text-light">Country</label>
                    <input type="text" name="country" class="form-control bg-dark text-white border-0 shadow-none">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label small text-light">PinCode</label>
                    <input type="text" name="pincode" class="form-control bg-dark text-white border-0 shadow-none">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label small text-light">label</label>
                    <input type="text" name="label" class="form-control bg-dark text-white border-0 shadow-none">
                  </div>
                </div>

              </div>
              <div class="modal-footer border-0 d-flex gap-3 px-4 pb-4">
                <button type="submit" class="btn btn-warning fw-bold text-dark flex-grow-1 py-2"
                  style="max-width:250px;"><i class="fas fa-user-plus me-2"></i>Add User</button>
                <button type="button" class="btn text-white flex-grow-1 py-2"
                  style="background-color: #4a4a4a; max-width:250px;" data-bs-dismiss="modal">Cancel</button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <!-- Edit User Modal -->
      <div class="modal fade" id="editUserModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content bg-dark text-white border-warning" style="border-width: 2px;">
            <div class="modal-header border-secondary">
              <h5 class="modal-title fw-bold text-warning"><i class="fas fa-user-edit me-2"></i>Edit User</h5>
              <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                aria-label="Close"></button>
            </div>
            <form id="editUserForm" method="POST">
              <div class="modal-body">
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label small" style="color:#aaa">First Name</label>
                    <input type="text" name="firstName" id="editFirstName"
                      class="form-control bg-black border-secondary text-white shadow-none <%= (locals.editFieldErrors && locals.editFieldErrors.firstName) ? 'is-invalid' : '' %>">
                    <% if (locals.editFieldErrors && locals.editFieldErrors.firstName) { %>
                      <div class="invalid-feedback"><%= locals.editFieldErrors.firstName %></div>
                    <% } %>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label small" style="color:#aaa">Last Name</label>
                    <input type="text" name="lastName" id="editLastName"
                      class="form-control bg-black border-secondary text-white shadow-none <%= (locals.editFieldErrors && locals.editFieldErrors.lastName) ? 'is-invalid' : '' %>">
                    <% if (locals.editFieldErrors && locals.editFieldErrors.lastName) { %>
                      <div class="invalid-feedback"><%= locals.editFieldErrors.lastName %></div>
                    <% } %>
                  </div>
                  <div class="col-12">
                    <label class="form-label small" style="color:#aaa">Email Address</label>
                    <input type="email" name="email" id="editEmail"
                      class="form-control bg-black border-secondary text-white shadow-none <%= (locals.editFieldErrors && locals.editFieldErrors.email) ? 'is-invalid' : '' %>">
                    <% if (locals.editFieldErrors && locals.editFieldErrors.email) { %>
                      <div class="invalid-feedback"><%= locals.editFieldErrors.email %></div>
                    <% } %>
                  </div>
                  <div class="col-md-4">
                    <label class="form-label small" style="color:#aaa">Role</label>
                    <select name="role" id="editRole"
                      class="form-select bg-black border-secondary text-white shadow-none">
                      <option value="user">User</option>
                      <option value="admin">Admin</option>
                    </select>
                  </div>
                  <div class="col-md-4">
                    <label class="form-label small" style="color:#aaa">Premium</label>
                    <select name="isPremium" id="editPremium"
                      class="form-select bg-black border-secondary text-white shadow-none">
                      <option value="false">NO</option>
                      <option value="true">YES</option>
                    </select>
                  </div>
                  <div class="col-md-4">
                    <label class="form-label small" style="color:#aaa">Status</label>
                    <select name="status" id="editStatus"
                      class="form-select bg-black border-secondary text-white shadow-none">
                      <option value="active">Active</option>
                      <option value="blocked">Suspended</option>
                    </select>
                  </div>
                </div>
              </div>
              <div class="modal-footer border-secondary">
                <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-warning fw-bold text-dark">Save Changes</button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
      <% if (locals.openEditModal) { %>
      <script>
        document.addEventListener('DOMContentLoaded', function () {
          const f = document.getElementById('editUserForm');
          f.action = '/admin/users/update/<%= locals.editUserId %>';
          document.getElementById('editFirstName').value = '<%= locals.editFormData.firstName || "" %>';
          document.getElementById('editLastName').value  = '<%= locals.editFormData.lastName  || "" %>';
          document.getElementById('editEmail').value     = '<%= locals.editFormData.email     || "" %>';
          document.getElementById('editRole').value      = '<%= locals.editFormData.role      || "user" %>';
          document.getElementById('editPremium').value   = '<%= locals.editFormData.isPremium || "false" %>';
          document.getElementById('editStatus').value    = '<%= locals.editFormData.status    || "active" %>';
          new bootstrap.Modal(document.getElementById('editUserModal')).show();
        });
      </script>
      <% } %>
      <script>
        function openEditModal(id, firstName, lastName, email, role, isPremium, status) {
          document.getElementById('editUserForm').action = '/admin/users/update/' + id;
          document.getElementById('editFirstName').value = firstName;
          document.getElementById('editLastName').value  = lastName;
          document.getElementById('editEmail').value     = email;
          document.getElementById('editRole').value      = role;
          document.getElementById('editPremium').value   = isPremium;
          document.getElementById('editStatus').value    = status;
          const modal = new bootstrap.Modal(document.getElementById('editUserModal'));
          modal.show();
        }
      </script>
  </body>

  </html>