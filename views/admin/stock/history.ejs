<%- include('../../partials/admin-head') %>

<body class="bg-black text-light">
  <%- include('../../partials/admin-sidebar') %>

  <div class="main-content">
    <%- include('../../partials/admin-header') %>

    <div class="admin-content p-4">

      <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/admin/stock" class="btn btn-outline-secondary btn-sm">
          <i class="fas fa-arrow-left me-1"></i> Back to Stock
        </a>
        <div>
          <h4 class="mb-0" style="color:var(--admin-gold);">Stock History</h4>
          <p class="text-muted small mb-0"><%= product.productName %> &mdash; SKU: <%= product.sku || '—' %></p>
        </div>
      </div>

      <!-- Product summary card -->
      <div class="card bg-dark border-secondary mb-4">
        <div class="card-body d-flex align-items-center gap-3">
          <% if (product.images && product.images[0]) { %>
            <img src="<%= product.images[0] %>" alt="" style="width:70px;height:70px;object-fit:cover;border-radius:4px;">
          <% } %>
          <div class="flex-grow-1">
            <div class="fw-bold fs-5"><%= product.productName %></div>
            <div class="text-muted small">Category: <%= product.categoryId?.categoryName || '—' %></div>
            <div class="small mt-1">Price: <span class="text-warning">$<%= product.price.toFixed(2) %></span></div>
          </div>
          <div class="text-end">
            <div class="text-muted small">Current Stock</div>
            <%
              const sc = product.outOfstock ? '#dc3545' : product.stockQuantity <= 10 ? '#fd7e14' : '#28a745';
            %>
            <div class="fw-bold fs-3" style="color:<%= sc %>"><%= product.stockQuantity %></div>
            <div class="small" style="color:<%= sc %>">
              <%= product.outOfstock ? 'Out of Stock' : product.stockQuantity <= 10 ? 'Low Stock' : 'In Stock' %>
            </div>
          </div>
        </div>
      </div>

      <!-- Unit history table -->
      <div class="admin-table">
        <div class="p-3 border-bottom border-secondary" style="color:var(--admin-gold);font-weight:600;">
          Individual Unit History
          <span class="text-muted fw-normal small ms-2">(<%= unitRows.length %> units consumed)</span>
        </div>
        <table class="table table-dark table-hover mb-0">
          <thead>
            <tr>
              <th style="color:var(--admin-gold);">UNIT SLOT</th>
              <th style="color:var(--admin-gold);">ORDER ID</th>
              <th style="color:var(--admin-gold);">CUSTOMER</th>
              <th style="color:var(--admin-gold);">EMAIL</th>
              <th style="color:var(--admin-gold);">ORDER DATE</th>
              <th style="color:var(--admin-gold);">UNIT STATUS</th>
              <th style="color:var(--admin-gold);">VIEW ORDER</th>
            </tr>
          </thead>
          <tbody>
            <% if (!unitRows || unitRows.length === 0) { %>
              <tr><td colspan="7" class="text-center text-muted py-4">No orders for this product yet</td></tr>
            <% } else { %>
              <% unitRows.forEach(row => { %>
                <%
                  const sc = {pending:'warning',processing:'info',shipped:'primary',out_for_delivery:'info',delivered:'success',cancelled:'danger'};
                %>
                <tr>
                  <td><span class="badge bg-secondary">Unit #<%= row.unitIndex + 1 %></span></td>
                  <td class="text-warning fw-bold">#<%= row.orderId %></td>
                  <td><%= row.customer || '—' %></td>
                  <td class="text-muted small"><%= row.email || '—' %></td>
                  <td class="small"><%= new Date(row.date).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) %></td>
                  <td>
                    <span class="badge bg-<%= sc[row.status]||'secondary' %>">
                      <%= row.status.replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase()) %>
                    </span>
                  </td>
                  <td>
                    <a href="/admin/orders/<%= row.orderDbId %>" class="btn btn-sm" style="color:#17a2b8;">
                      <i class="fas fa-eye"></i>
                    </a>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>

    </div>
  </div>
</body>
