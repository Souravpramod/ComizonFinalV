<%- include('../../partials/admin-head') %>

<body class="bg-black text-light">
  <%- include('../../partials/admin-sidebar') %>

  <div class="main-content">
    <%- include('../../partials/admin-header') %>

    <div class="admin-content p-4">

      <% if (locals.error) { %>
        <div class="alert alert-danger alert-dismissible fade show rounded-0" role="alert">
          <%= error %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>
      <% if (locals.success) { %>
        <div class="alert alert-success alert-dismissible fade show rounded-0" role="alert">
          <%= success %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>

      <div class="admin-header">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
          <div>
            <h4 class="mb-0" style="color: var(--admin-gold);">Product Management</h4>
            <p class="text-muted small mb-0">Manage your comic books and collectibles</p>
          </div>
          <button class="btn btn-admin-primary" data-bs-toggle="offcanvas" data-bs-target="#addProductModal">
            <i class="fas fa-plus me-2"></i>Add New Product
          </button>
        </div>
      </div>

      <form method="GET" action="/admin/products">
        <div class="row mb-4">
          <div class="col-lg-4 col-md-6 mb-3">
            <div class="search-bar">
              <div class="input-group">
                <span class="input-group-text"><i class="fas fa-search"></i></span>
                <input type="text" class="form-control" name="search" placeholder="Search products..." value="<%= locals.search || '' %>">
              </div>
            </div>
          </div>
          <div class="col-lg-3 col-md-6 mb-3">
            <select class="form-select" name="category">
              <option value="">All Categories</option>
              <% if (locals.categories) { %>
                <% categories.forEach(cat => { %>
                  <option value="<%= cat._id %>" <%= (locals.category == cat._id) ? 'selected' : '' %>>
                    <%= cat.categoryName %>
                  </option>
                <% }) %>
              <% } %>
            </select>
          </div>
          <div class="col-lg-2 col-md-6 mb-3">
            <select class="form-select" name="status">
              <option value="">All Status</option>
              <option value="instock" <%= (locals.status === 'instock') ? 'selected' : '' %>>In Stock</option>
              <option value="lowstock" <%= (locals.status === 'lowstock') ? 'selected' : '' %>>Low Stock</option>
              <option value="outofstock" <%= (locals.status === 'outofstock') ? 'selected' : '' %>>Out of Stock</option>
            </select>
          </div>
          <div class="col-lg-2 col-md-6 mb-3">
            <select class="form-select" name="sort">
              <option value="newest" <%= (locals.sort === 'newest') ? 'selected' : '' %>>Newest</option>
              <option value="name_asc" <%= (locals.sort === 'name_asc') ? 'selected' : '' %>>Name (A-Z)</option>
              <option value="price_asc" <%= (locals.sort === 'price_asc') ? 'selected' : '' %>>Price (Low-High)</option>
              <option value="price_desc" <%= (locals.sort === 'price_desc') ? 'selected' : '' %>>Price (High-Low)</option>
            </select>
          </div>
          <div class="col-lg-1 col-md-6 mb-3">
            <button type="submit" class="btn btn-admin-primary w-100">Go</button>
          </div>
        </div>
      </form>

      <div class="admin-table">
        <div class="table-responsive">
          <table class="table align-middle">
            <thead>
              <tr>
                <th style="width: 80px;">Image</th>
                <th>Product Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Stock Qty</th>
                <th>Stock Status</th>
                <th>Type</th>
                <th>Listing Status</th>
                <th style="width: 150px;">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (locals.products && products.length > 0) { %>
                <% products.forEach(product => { %>
                  <tr class="<%= product.isActive === false ? 'opacity-50' : '' %>">
                    <td>
                      <img src="<%= (product.images && product.images.length > 0) ? product.images[0] : 'https://placehold.co/60x80?text=No+Img' %>"
                           alt="" style="width:60px;height:80px;object-fit:cover;border-radius:4px;">
                    </td>
                    <td>
                      <div class="fw-bold"><%= product.productName %></div>
                      <div class="text-muted small">SKU: <%= product.sku || product._id.toString().slice(-6).toUpperCase() %></div>
                    </td>
                    <td><%= product.categoryId ? product.categoryId.categoryName : 'N/A' %></td>
                    <td class="fw-bold" style="color:var(--admin-gold);">$<%= Number(product.price).toFixed(2) %></td>
                    
                    <td class="text-center"><%= product.stockQuantity %></td>

                    <td>
                      <% if (product.stockQuantity === 0) { %>
                        <span class="badge bg-danger">
                          <i class="fas fa-times-circle me-1"></i>Out of Stock
                        </span>
                      <% } else if (product.stockQuantity <= 10) { %>
                        <span class="badge bg-warning text-dark">
                          <i class="fas fa-exclamation-triangle me-1"></i>Low Stock
                        </span>
                      <% } else { %>
                        <span class="badge bg-info-subtle text-info border border-info">
                          <i class="fas fa-boxes me-1"></i>High Stock
                        </span>
                      <% } %>
                    </td>

                    <td>
                      <% if (product.isPremium) { %>
                        <span class="badge" style="background-color: var(--admin-gold); color: black;">
                          <i class="fas fa-crown me-1"></i>Premium
                        </span>
                      <% } else { %>
                        <span class="badge border border-secondary text-secondary">Regular</span>
                      <% } %>
                    </td>

                    <td>
                      <% if (product.isActive === false) { %>
                        <span class="badge bg-secondary">
                          <i class="fas fa-eye-slash me-1"></i>Blocked
                        </span>
                      <% } else { %>
                        <span class="badge bg-success">
                          <i class="fas fa-check me-1"></i>Active
                        </span>
                      <% } %>
                    </td>

                    <td>
                      <div class="action-btns">
                        <a href="/admin/products/edit/<%= product._id %>" class="action-btn edit" title="Edit">
                          <i class="fas fa-edit"></i>
                        </a>

                        <% if (product.isActive !== false) { %>
                          <div class="action-btn delete" 
                               data-bs-toggle="modal" data-bs-target="#statusModal"
                               data-product-id="<%= product._id %>"
                               data-product-name="<%= product.productName %>"
                               data-action="block"
                               title="Block Product">
                            <i class="fas fa-ban"></i>
                          </div>
                        <% } else { %>
                          <div class="action-btn edit" 
                               data-bs-toggle="modal" data-bs-target="#statusModal"
                               data-product-id="<%= product._id %>"
                               data-product-name="<%= product.productName %>"
                               data-action="unblock"
                               title="Unblock Product"
                               style="background-color: #28a745 !important;">
                            <i class="fas fa-undo"></i>
                          </div>
                        <% } %>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="9" class="text-center py-5">No products found.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
      <% if (totalPages > 1) { %>
<nav class="mt-4">
  <ul class="pagination justify-content-center">

    <!-- Previous -->
    <li class="page-item <%= currentPage == 1 ? 'disabled' : '' %>">
      <a class="page-link"
         href="/admin/products?page=<%= currentPage - 1 %>&search=<%= search %>&category=<%= category %>&status=<%= status %>&sort=<%= sort %>">
        Previous
      </a>
    </li>

    <!-- Page Numbers -->
    <% for (let i = 1; i <= totalPages; i++) { %>
      <li class="page-item <%= currentPage == i ? 'active' : '' %>">
        <a class="page-link"
           href="/admin/products?page=<%= i %>&search=<%= search %>&category=<%= category %>&status=<%= status %>&sort=<%= sort %>">
          <%= i %>
        </a>
      </li>
    <% } %>

    <!-- Next -->
    <li class="page-item <%= currentPage == totalPages ? 'disabled' : '' %>">
      <a class="page-link"
         href="/admin/products?page=<%= currentPage + 1 %>&search=<%= search %>&category=<%= category %>&status=<%= status %>&sort=<%= sort %>">
        Next
      </a>
    </li>

  </ul>
</nav>
<% } %>
    </div>
  </div>


  <!-- ── ADD PRODUCT OFFCANVAS (slides from right) ── -->
  <div class="offcanvas offcanvas-end bg-dark text-white" tabindex="-1" id="addProductModal" style="width:780px;max-width:98vw;">
    <div class="offcanvas-header border-bottom border-secondary">
      <h5 class="offcanvas-title">
        <i class="fas fa-plus me-2" style="color:var(--admin-gold);"></i>Add New Product
      </h5>
      <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
    </div>

    <form id="addProductForm" action="/admin/products/add" method="POST" enctype="multipart/form-data" style="display:flex;flex-direction:column;height:100%;min-height:0;">
      <div class="offcanvas-body overflow-auto" style="flex:1 1 0;min-height:0;">
        <div class="row g-3">

          <!-- ── LEFT: product fields ── -->
          <div class="col-md-7">
            <div class="mb-3">
              <label class="form-label">Product Name <span class="text-danger">*</span></label>
              <input type="text" class="form-control bg-dark text-white border-secondary" name="productName" id="add_productName">
              <div class="invalid-feedback" id="err_productName"></div>
            </div>
            <div class="mb-3">
              <label class="form-label">Category <span class="text-danger">*</span></label>
              <select class="form-select bg-dark text-white border-secondary" name="categoryId" id="add_categoryId">
                <option value="">Select Category</option>
                <% if (locals.categories) { %>
                  <% categories.forEach(cat => { %>
                    <option value="<%= cat._id %>"><%= cat.categoryName %></option>
                  <% }) %>
                <% } %>
              </select>
              <div class="invalid-feedback" id="err_categoryId"></div>
            </div>
            <div class="row g-2 mb-3">
              <div class="col-6">
                <label class="form-label">Author</label>
                <input type="text" class="form-control bg-dark text-white border-secondary" name="author">
              </div>
              <div class="col-6">
                <label class="form-label">Publisher</label>
                <input type="text" class="form-control bg-dark text-white border-secondary" name="publisher">
              </div>
            </div>
            <div class="row g-2 mb-3">
              <div class="col-6">
                <label class="form-label">Price ($) <span class="text-danger">*</span></label>
                <input type="number" class="form-control bg-dark text-white border-secondary" name="price" id="add_price" step="0.01">
                <div class="invalid-feedback" id="err_price"></div>
              </div>
              <div class="col-6">
                <label class="form-label">Type</label>
                <select class="form-select bg-dark text-white border-secondary" name="isPremium">
                  <option value="false">Regular</option>
                  <option value="true">Premium</option>
                </select>
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label">Description</label>
              <textarea class="form-control bg-dark text-white border-secondary" name="description" rows="5"></textarea>
            </div>
            <!-- Stock hidden — default 0, managed by Stock Manager -->
            <input type="hidden" name="stockQuantity" value="0">
          </div>

          <!-- ── RIGHT: image slots ── -->
          <div class="col-md-5">
            <label class="form-label">Product Images</label>
            <small class="text-muted d-block mb-3">Pick → crop → Save Image for each slot, then click Add Product.</small>

            <% for(let idx = 0; idx < 3; idx++){ %>
            <div class="mb-3 p-2 border border-secondary rounded-0" id="addImageSlot<%= idx %>">
              <div class="small text-muted mb-1 fw-semibold">Image <%= idx + 1 %></div>

              <!-- Preview -->
              <div id="addPreview<%= idx %>" class="mb-2">
                <div style="width:100%;height:140px;background:#1a1a1a;display:flex;align-items:center;justify-content:center;color:#555;font-size:12px;border:1px dashed #444;">
                  Empty
                </div>
              </div>

              <!-- File picker -->
              <input type="file"
                     id="addImage<%= idx %>"
                     class="form-control form-control-sm mb-2 bg-dark text-white border-secondary"
                     data-index="<%= idx %>"
                     accept=".jpg,.jpeg,.png,.heif,.heic,.avif">

              <!-- Status -->
              <div class="small mb-2" id="addSlotStatus<%= idx %>">
                <span class="text-muted">No image</span>
              </div>

              <button type="button"
                      class="btn btn-sm btn-warning rounded-0 w-100 add-save-image-btn"
                      data-index="<%= idx %>">
                <i class="fas fa-save me-1"></i>Save Image <%= idx + 1 %>
              </button>
            </div>
            <% } %>
          </div>

        </div>
      </div>

      <!-- Footer sticks to bottom -->
      <div class="p-3 border-top border-secondary d-flex justify-content-end gap-2">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="offcanvas">Cancel</button>
        <button type="submit" class="btn btn-admin-primary">
          <i class="fas fa-plus me-2"></i>Add Product
        </button>
      </div>
    </form>
  </div>

  <div class="modal fade" id="statusModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content bg-dark text-white border-secondary">
        <div class="modal-header border-secondary">
          <h5 class="modal-title" id="statusModalTitle">Confirm Action</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <p id="statusModalText"></p>
          <div class="alert alert-secondary py-2">
            <strong>Product:</strong> <span id="statusProductName"></span>
          </div>
        </div>
        <div class="modal-footer border-secondary">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <form id="statusForm" action="" method="POST" style="display:inline;">
            <button type="submit" id="statusConfirmBtn" class="btn">Confirm</button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css"/>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>
<script>

  function showToast(msg, type='danger') {
    const id = 'toast_' + Date.now();
    const bg = type === 'success' ? 'bg-success' : type === 'warning' ? 'bg-warning text-dark' : 'bg-danger';
    const el = document.createElement('div');
    el.id = id;
    el.className = `toast align-items-center text-white border-0 ${bg} position-fixed rounded-0`;
    el.style.cssText = 'top:80px;right:20px;z-index:9999;min-width:280px;';
    el.setAttribute('role','alert');
    el.innerHTML = `<div class="d-flex"><div class="toast-body fw-semibold">${msg}</div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div>`;
    document.body.appendChild(el);
    const t = new bootstrap.Toast(el, { delay: 4000 });
    t.show();
    el.addEventListener('hidden.bs.toast', () => el.remove());
}

    // ── ADD MODAL: image cropping + staged save ───────────────────────────────
  const addCroppers = {};
  const addStagedBlobs = {}; // stores cropped blobs after "Save Image" clicked

  const ALLOWED_TYPES = ['image/jpeg', 'image/png', 'image/heif', 'image/heic', 'image/avif'];
  const ALLOWED_EXTS  = /\.(jpe?g|png|heif|heic|avif)$/i;

  function isValidImageFile(file) {
    return ALLOWED_TYPES.includes(file.type) || ALLOWED_EXTS.test(file.name);
  }

  // File picker → init cropper
  for (let i = 0; i < 3; i++) {
    document.getElementById('addImage' + i).addEventListener('change', function (e) {
      const file = e.target.files[0];
      if (!file) return;

      if (!isValidImageFile(file)) {
        showToast('Invalid file type for Image ' + (i + 1) + '. Allowed: JPEG, JPG, PNG, HEIF, HEIC, AVIF', 'warning');
        this.value = '';
        return;
      }

      // Clear any previously staged blob for this slot
      delete addStagedBlobs[i];
      document.getElementById('addSlotStatus' + i).innerHTML = '<span class="text-info">Crop the image, then click Save Image.</span>';

      const reader = new FileReader();
      reader.onload = function (ev) {
        const preview = document.getElementById('addPreview' + i);
        preview.innerHTML = '<img id="addCropImg' + i + '" style="max-width:200px;">';
        const img = document.getElementById('addCropImg' + i);
        img.src = ev.target.result;
        if (addCroppers[i]) addCroppers[i].destroy();
        addCroppers[i] = new Cropper(img, { aspectRatio: 3 / 4, viewMode: 1 });
      };
      reader.readAsDataURL(file);
    });
  }

  // "Save Image" per slot — crops and stages the blob (does NOT submit form)
  document.querySelectorAll('.add-save-image-btn').forEach(function (btn) {
    btn.addEventListener('click', async function () {
      const i = parseInt(this.getAttribute('data-index'));
      const statusEl = document.getElementById('addSlotStatus' + i);

      if (!addCroppers[i]) {
        showToast('Pick a file for Image ' + (i + 1) + ' first.', 'warning');
        return;
      }

      btn.disabled = true;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';

      const canvas = addCroppers[i].getCroppedCanvas({ width: 600, height: 800 });
      const blob   = await new Promise(resolve => canvas.toBlob(resolve, 'image/jpeg', 0.9));

      addStagedBlobs[i] = blob;

      // Show a small cropped preview to confirm
      const url = URL.createObjectURL(blob);
      document.getElementById('addPreview' + i).innerHTML =
        '<img src="' + url + '" style="width:120px;height:160px;object-fit:cover;border-radius:4px;">';

      statusEl.innerHTML = '<span class="text-success"><i class="fas fa-check me-1"></i>Staged — will upload on Add Product.</span>';

      addCroppers[i].destroy();
      delete addCroppers[i];

      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-save me-1"></i>Save Image';
    });
  });

  // Main form submit — attaches staged blobs then POSTs
  // ── Live validation helpers (Add form) ───────────────────────────────────
  function validateAddField(field) {
    const input = document.getElementById('add_' + field);
    const errEl = document.getElementById('err_' + field);
    if (!input || !errEl) return true;

    let msg = '';
    const val = input.value.trim();

    if (field === 'productName') {
      if (!val) msg = 'Product name is required';
    } else if (field === 'categoryId') {
      if (!val) msg = 'Category must be selected';
    } else if (field === 'price') {
      if (!val || isNaN(val) || Number(val) <= 0) msg = 'Price must be a valid positive number';
    }

    if (msg) {
      input.classList.add('is-invalid');
      input.classList.remove('is-valid');
      errEl.textContent = msg;
      return false;
    } else {
      input.classList.remove('is-invalid');
      input.classList.add('is-valid');
      errEl.textContent = '';
      return true;
    }
  }

  // Attach live listeners — blur fires when leaving a field, input fires while typing
  ['productName', 'price'].forEach(field => {
    const input = document.getElementById('add_' + field);
    if (!input) return;
    input.addEventListener('input', () => validateAddField(field));
    input.addEventListener('blur',  () => validateAddField(field));
  });
  // Select uses change instead of input
  const addCatSelect = document.getElementById('add_categoryId');
  if (addCatSelect) addCatSelect.addEventListener('change', () => validateAddField('categoryId'));
  // ─────────────────────────────────────────────────────────────────────────

  document.getElementById('addProductForm').addEventListener('submit', async function (e) {
    e.preventDefault();

    // Run all validations on submit — stops if any fail
    const allValid = ['productName', 'categoryId', 'price'].every(field => validateAddField(field));
    if (!allValid) return;

    ['productName', 'categoryId', 'price'].forEach(field => {
      const input = document.getElementById('add_' + field);
      const errEl = document.getElementById('err_' + field);
      if (input) input.classList.remove('is-invalid');
      if (errEl) errEl.textContent = '';
    });

    const formData = new FormData();

    // Append staged cropped blobs
    for (let i = 0; i < 3; i++) {
      if (addStagedBlobs[i]) {
        formData.append('image_' + i, addStagedBlobs[i], 'image_' + i + '.jpg');
      }
    }

    // Append all other form fields (skipping file inputs)
    const raw = new FormData(this);
    for (const [key, val] of raw.entries()) {
      if (!key.startsWith('image_')) formData.append(key, val);
    }

    try {
      const res  = await fetch('/admin/products/add', { method: 'POST', body: formData });
      const data = await res.json();

      if (!data.ok && data.fieldErrors) {
        Object.entries(data.fieldErrors).forEach(([field, msg]) => {
          const input = document.getElementById('add_' + field);
          const errEl = document.getElementById('err_' + field);
          if (input) input.classList.add('is-invalid');
          if (errEl) errEl.textContent = msg;
        });
        return;
      }

      window.location.href = '/admin/products?success=Product+added+successfully';

    } catch (err) {
      console.error('Add product error:', err);
    }
  });

    document.getElementById('statusModal').addEventListener('show.bs.modal', function (e) {
        const btn = e.relatedTarget;
        const id = btn.getAttribute('data-product-id');
        const name = btn.getAttribute('data-product-name');
        const action = btn.getAttribute('data-action');

        const title = document.getElementById('statusModalTitle');
        const text = document.getElementById('statusModalText');
        const confirmBtn = document.getElementById('statusConfirmBtn');
        const form = document.getElementById('statusForm');

        document.getElementById('statusProductName').textContent = name;

        if (action === 'block') {
            title.innerHTML = '<i class="fas fa-ban me-2 text-danger"></i>Block Product';
            text.textContent = 'This will hide the product from the storefront. You can unblock it later.';
            confirmBtn.className = 'btn btn-danger';
            confirmBtn.textContent = 'Block Product';
            form.action = `/admin/products/delete/${id}?_method=PATCH`;
        } else {
            title.innerHTML = '<i class="fas fa-check-circle me-2 text-success"></i>Unblock Product';
            text.textContent = 'This will restore the product to the storefront for customers to buy.';
            confirmBtn.className = 'btn btn-success';
            confirmBtn.textContent = 'Unblock Product';
            form.action = `/admin/products/${id}/activate?_method=PATCH`;
        }
    });
</script>
  </body>
