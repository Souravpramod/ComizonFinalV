<%- include('../../partials/admin-head') %>

<body class="bg-black text-light">
  <%- include('../../partials/admin-sidebar') %>

  <div class="main-content">
    <%- include('../../partials/admin-header') %>

    <div class="admin-content p-4">

      <% if (locals.error) { %>
        <div class="alert alert-danger alert-dismissible fade show rounded-0" role="alert">
          <%= error %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>
      <% if (locals.success) { %>
        <div class="alert alert-success alert-dismissible fade show rounded-0" role="alert">
          <%= success %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>

      <div class="admin-header">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
          <div>
            <h4 class="mb-0" style="color: var(--admin-gold);">Product Management</h4>
            <p class="text-muted small mb-0">Manage your comic books and collectibles</p>
          </div>
          <button class="btn btn-admin-primary" data-bs-toggle="modal" data-bs-target="#addProductModal">
            <i class="fas fa-plus me-2"></i>Add New Product
          </button>
        </div>
      </div>

      <form method="GET" action="/admin/products">
        <div class="row mb-4">
          <div class="col-lg-4 col-md-6 mb-3">
            <div class="search-bar">
              <div class="input-group">
                <span class="input-group-text"><i class="fas fa-search"></i></span>
                <input type="text" class="form-control" name="search" placeholder="Search products..." value="<%= locals.search || '' %>">
              </div>
            </div>
          </div>
          <div class="col-lg-3 col-md-6 mb-3">
            <select class="form-select" name="category">
              <option value="">All Categories</option>
              <% if (locals.categories) { %>
                <% categories.forEach(cat => { %>
                  <option value="<%= cat._id %>" <%= (locals.category == cat._id) ? 'selected' : '' %>>
                    <%= cat.categoryName %>
                  </option>
                <% }) %>
              <% } %>
            </select>
          </div>
          <div class="col-lg-2 col-md-6 mb-3">
            <select class="form-select" name="status">
              <option value="">All Status</option>
              <option value="instock" <%= (locals.status === 'instock') ? 'selected' : '' %>>In Stock</option>
              <option value="lowstock" <%= (locals.status === 'lowstock') ? 'selected' : '' %>>Low Stock</option>
              <option value="outofstock" <%= (locals.status === 'outofstock') ? 'selected' : '' %>>Out of Stock</option>
            </select>
          </div>
          <div class="col-lg-2 col-md-6 mb-3">
            <select class="form-select" name="sort">
              <option value="newest" <%= (locals.sort === 'newest') ? 'selected' : '' %>>Newest</option>
              <option value="name_asc" <%= (locals.sort === 'name_asc') ? 'selected' : '' %>>Name (A-Z)</option>
              <option value="price_asc" <%= (locals.sort === 'price_asc') ? 'selected' : '' %>>Price (Low-High)</option>
              <option value="price_desc" <%= (locals.sort === 'price_desc') ? 'selected' : '' %>>Price (High-Low)</option>
            </select>
          </div>
          <div class="col-lg-1 col-md-6 mb-3">
            <button type="submit" class="btn btn-admin-primary w-100">Go</button>
          </div>
        </div>
      </form>

      <div class="admin-table">
        <div class="table-responsive">
          <table class="table align-middle">
            <thead>
              <tr>
                <th style="width: 80px;">Image</th>
                <th>Product Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Stock Qty</th>
                <th>Stock Status</th>
                <th>Type</th>
                <th>Listing Status</th>
                <th style="width: 150px;">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (locals.products && products.length > 0) { %>
                <% products.forEach(product => { %>
                  <tr class="<%= product.isActive === false ? 'opacity-50' : '' %>">
                    <td>
                      <img src="<%= (product.images && product.images.length > 0) ? product.images[0] : 'https://placehold.co/60x80?text=No+Img' %>"
                           alt="" style="width:60px;height:80px;object-fit:cover;border-radius:4px;">
                    </td>
                    <td>
                      <div class="fw-bold"><%= product.productName %></div>
                      <div class="text-muted small">SKU: <%= product.sku || product._id.toString().slice(-6).toUpperCase() %></div>
                    </td>
                    <td><%= product.categoryId ? product.categoryId.categoryName : 'N/A' %></td>
                    <td class="fw-bold" style="color:var(--admin-gold);">$<%= Number(product.price).toFixed(2) %></td>
                    
                    <td class="text-center"><%= product.stockQuantity %></td>

                    <td>
                      <% if (product.stockQuantity === 0) { %>
                        <span class="badge bg-danger">
                          <i class="fas fa-times-circle me-1"></i>Out of Stock
                        </span>
                      <% } else if (product.stockQuantity <= 10) { %>
                        <span class="badge bg-warning text-dark">
                          <i class="fas fa-exclamation-triangle me-1"></i>Low Stock
                        </span>
                      <% } else { %>
                        <span class="badge bg-info-subtle text-info border border-info">
                          <i class="fas fa-boxes me-1"></i>High Stock
                        </span>
                      <% } %>
                    </td>

                    <td>
                      <% if (product.isPremium) { %>
                        <span class="badge" style="background-color: var(--admin-gold); color: black;">
                          <i class="fas fa-crown me-1"></i>Premium
                        </span>
                      <% } else { %>
                        <span class="badge border border-secondary text-secondary">Regular</span>
                      <% } %>
                    </td>

                    <td>
                      <% if (product.isActive === false) { %>
                        <span class="badge bg-secondary">
                          <i class="fas fa-eye-slash me-1"></i>Blocked
                        </span>
                      <% } else { %>
                        <span class="badge bg-success">
                          <i class="fas fa-check me-1"></i>Active
                        </span>
                      <% } %>
                    </td>

                    <td>
                      <div class="action-btns">
                        <a href="/admin/products/edit/<%= product._id %>" class="action-btn edit" title="Edit">
                          <i class="fas fa-edit"></i>
                        </a>

                        <% if (product.isActive !== false) { %>
                          <div class="action-btn delete" 
                               data-bs-toggle="modal" data-bs-target="#statusModal"
                               data-product-id="<%= product._id %>"
                               data-product-name="<%= product.productName %>"
                               data-action="block"
                               title="Block Product">
                            <i class="fas fa-ban"></i>
                          </div>
                        <% } else { %>
                          <div class="action-btn edit" 
                               data-bs-toggle="modal" data-bs-target="#statusModal"
                               data-product-id="<%= product._id %>"
                               data-product-name="<%= product.productName %>"
                               data-action="unblock"
                               title="Unblock Product"
                               style="background-color: #28a745 !important;">
                            <i class="fas fa-undo"></i>
                          </div>
                        <% } %>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="9" class="text-center py-5">No products found.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
      <% if (totalPages > 1) { %>
<nav class="mt-4">
  <ul class="pagination justify-content-center">

    <!-- Previous -->
    <li class="page-item <%= currentPage == 1 ? 'disabled' : '' %>">
      <a class="page-link"
         href="/admin/products?page=<%= currentPage - 1 %>&search=<%= search %>&category=<%= category %>&status=<%= status %>&sort=<%= sort %>">
        Previous
      </a>
    </li>

    <!-- Page Numbers -->
    <% for (let i = 1; i <= totalPages; i++) { %>
      <li class="page-item <%= currentPage == i ? 'active' : '' %>">
        <a class="page-link"
           href="/admin/products?page=<%= i %>&search=<%= search %>&category=<%= category %>&status=<%= status %>&sort=<%= sort %>">
          <%= i %>
        </a>
      </li>
    <% } %>

    <!-- Next -->
    <li class="page-item <%= currentPage == totalPages ? 'disabled' : '' %>">
      <a class="page-link"
         href="/admin/products?page=<%= currentPage + 1 %>&search=<%= search %>&category=<%= category %>&status=<%= status %>&sort=<%= sort %>">
        Next
      </a>
    </li>

  </ul>
</nav>
<% } %>
    </div>
  </div>


  <div class="modal fade" id="addProductModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
      <div class="modal-content bg-dark text-white border-secondary">
        <div class="modal-header border-secondary">
          <h5 class="modal-title">
            <i class="fas fa-plus me-2" style="color: var(--admin-gold);"></i>Add New Product
          </h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <form id="addProductForm" action="/admin/products/add" method="POST" enctype="multipart/form-data">
          <div class="modal-body">
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">Product Name <span class="text-danger">*</span></label>
                <input type="text" class="form-control bg-dark text-white border-secondary" name="productName" id="add_productName">
                <div class="invalid-feedback" id="err_productName"></div>
              </div>
              <div class="col-md-6">
                <label class="form-label">Category <span class="text-danger">*</span></label>
                <select class="form-select bg-dark text-white border-secondary" name="categoryId" id="add_categoryId">
                  <option value="">Select Category</option>
                  <% if (locals.categories) { %>
                    <% categories.forEach(cat => { %>
                      <option value="<%= cat._id %>"><%= cat.categoryName %></option>
                    <% }) %>
                  <% } %>
                </select>
                <div class="invalid-feedback" id="err_categoryId"></div>
              </div>
              <div class="col-md-6">
                <label class="form-label">Author</label>
                <input type="text" class="form-control bg-dark text-white border-secondary" name="author">
              </div>
              <div class="col-md-6">
                <label class="form-label">Publisher</label>
                <input type="text" class="form-control bg-dark text-white border-secondary" name="publisher">
              </div>
              <div class="col-md-4">
                <label class="form-label">Price ($) <span class="text-danger">*</span></label>
                <input type="number" class="form-control bg-dark text-white border-secondary" name="price" id="add_price" step="0.01">
                <div class="invalid-feedback" id="err_price"></div>
              </div>
              <div class="col-md-4">
                <label class="form-label">Stock Quantity <span class="text-danger">*</span></label>
                <input type="number" class="form-control bg-dark text-white border-secondary" name="stockQuantity" id="add_stockQuantity">
                <div class="invalid-feedback" id="err_stockQuantity"></div>
              </div>
              <div class="col-md-4">
                <label class="form-label">Type</label>
                <select class="form-select bg-dark text-white border-secondary" name="isPremium">
                  <option value="false">Regular</option>
                  <option value="true">Premium</option>
                </select>
              </div>
              <div class="col-12">
                <label class="form-label">Description</label>
                <textarea class="form-control bg-dark text-white border-secondary" name="description" rows="3"></textarea>
              </div>
              <div class="col-12">
                <label class="form-label">Product Images</label>
                <div class="mb-3">
                  <input type="file" name="image_0" id="addImage0" class="form-control mb-1">
                  <div id="addPreview0"></div>
                </div>
                <div class="mb-3">
                  <input type="file" name="image_1" id="addImage1" class="form-control mb-1">
                  <div id="addPreview1"></div>
                </div>
                <div class="mb-3">
                  <input type="file" name="image_2" id="addImage2" class="form-control mb-1">
                  <div id="addPreview2"></div>
                </div>
              </div>
            </div>
          </div>
          <div class="modal-footer border-secondary">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-admin-primary">
              <i class="fas fa-plus me-2"></i>Add Product
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="modal fade" id="statusModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content bg-dark text-white border-secondary">
        <div class="modal-header border-secondary">
          <h5 class="modal-title" id="statusModalTitle">Confirm Action</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <p id="statusModalText"></p>
          <div class="alert alert-secondary py-2">
            <strong>Product:</strong> <span id="statusProductName"></span>
          </div>
        </div>
        <div class="modal-footer border-secondary">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <form id="statusForm" action="" method="POST" style="display:inline;">
            <button type="submit" id="statusConfirmBtn" class="btn">Confirm</button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    const addCroppers = {};

    const ALLOWED_TYPES = ['image/jpeg', 'image/png', 'image/heif', 'image/heic', 'image/avif'];
const ALLOWED_EXTS  = /\.(jpe?g|png|heif|heic|avif)$/i;

function isValidImageFile(file) {
    return ALLOWED_TYPES.includes(file.type) || ALLOWED_EXTS.test(file.name);
}

for (let i = 0; i < 3; i++) {
    document.getElementById('addImage' + i).addEventListener('change', function (e) {
        const file = e.target.files[0];
        if (!file) return;

        if (!isValidImageFile(file)) {
            alert('Invalid file type for Image ' + (i + 1) + '.\nAllowed formats: JPEG, JPG, PNG, HEIF, HEIC, AVIF');
            this.value = '';
            return;
        }

        const reader = new FileReader();
        reader.onload = function (ev) {
            const preview = document.getElementById('addPreview' + i);
            preview.innerHTML = '<img id="addCropImg' + i + '" style="max-width:100%;margin-top:6px;">';
            const img = document.getElementById('addCropImg' + i);
            img.src = ev.target.result;
            if (addCroppers[i]) addCroppers[i].destroy();
            addCroppers[i] = new Cropper(img, { aspectRatio: 3 / 4, viewMode: 1 });
        };
        reader.readAsDataURL(file);
    });
}

    document.getElementById('addProductForm').addEventListener('submit', async function (e) {
        e.preventDefault();

        ['productName', 'categoryId', 'price', 'stockQuantity'].forEach(field => {
            const input = document.getElementById('add_' + field);
            const errEl = document.getElementById('err_' + field);
            if (input) input.classList.remove('is-invalid');
            if (errEl) errEl.textContent = '';
        });

        const formData = new FormData();

        for (let i = 0; i < 3; i++) {
            const input = document.getElementById('addImage' + i);
            if (addCroppers[i] && input.files[0]) {
                const canvas = addCroppers[i].getCroppedCanvas({ width: 600, height: 800 });
                const blob = await new Promise(resolve => canvas.toBlob(resolve, 'image/jpeg', 0.9));
                formData.append('image_' + i, blob, 'image_' + i + '.jpg');
            } else if (input.files[0]) {
                formData.append('image_' + i, input.files[0]);
            }
        }

        const raw = new FormData(this);
        for (const [key, val] of raw.entries()) {
            if (!key.startsWith('image_')) formData.append(key, val);
        }

        try {
            const res  = await fetch('/admin/products/add', { method: 'POST', body: formData });
            const data = await res.json();

            if (!data.ok && data.fieldErrors) {
                Object.entries(data.fieldErrors).forEach(([field, msg]) => {
                    const input = document.getElementById('add_' + field);
                    const errEl = document.getElementById('err_' + field);
                    if (input) input.classList.add('is-invalid');
                    if (errEl) errEl.textContent = msg;
                });
                return;
            }

            window.location.href = '/admin/products?success=Product+added+successfully';

        } catch (err) {
            console.error('Add product error:', err);
        }
    });

    document.getElementById('statusModal').addEventListener('show.bs.modal', function (e) {
        const btn = e.relatedTarget;
        const id = btn.getAttribute('data-product-id');
        const name = btn.getAttribute('data-product-name');
        const action = btn.getAttribute('data-action');

        const title = document.getElementById('statusModalTitle');
        const text = document.getElementById('statusModalText');
        const confirmBtn = document.getElementById('statusConfirmBtn');
        const form = document.getElementById('statusForm');

        document.getElementById('statusProductName').textContent = name;

        if (action === 'block') {
            title.innerHTML = '<i class="fas fa-ban me-2 text-danger"></i>Block Product';
            text.textContent = 'This will hide the product from the storefront. You can unblock it later.';
            confirmBtn.className = 'btn btn-danger';
            confirmBtn.textContent = 'Block Product';
            form.action = `/admin/products/delete/${id}?_method=PATCH`;
        } else {
            title.innerHTML = '<i class="fas fa-check-circle me-2 text-success"></i>Unblock Product';
            text.textContent = 'This will restore the product to the storefront for customers to buy.';
            confirmBtn.className = 'btn btn-success';
            confirmBtn.textContent = 'Unblock Product';
            form.action = `/admin/products/${id}/activate?_method=PATCH`;
        }
    });
</script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css"/>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>
</body>
