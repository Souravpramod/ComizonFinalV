<%- include('../../partials/admin-head') %>

<body class="bg-black text-light">
  <%- include('../../partials/admin-sidebar') %>

  <div class="main-content">
    <%- include('../../partials/admin-header') %>

    <div class="admin-content p-4">

      <% if (locals.success) { %>
        <div class="alert alert-success alert-dismissible fade show rounded-0" role="alert">
          <%= success %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>

      <!-- Page Header -->
      <div class="admin-header mb-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
          <div>
            <h4 class="mb-0" style="color: var(--admin-gold);">Edit Category</h4>
            <p class="text-muted small mb-0">Update details for <strong><%= category.categoryName %></strong></p>
          </div>
          <a href="/admin/categories" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to Categories
          </a>
        </div>
      </div>

      <!-- Edit Form Card -->
      <div class="admin-table p-4" style="max-width: 680px;">
        <form action="/admin/categories/edit/<%= category._id %>" method="POST">

          <div class="mb-3">
            <label class="form-label">Category Name</label>
            <input type="text"
              class="form-control <%= locals.error ? 'is-invalid' : '' %>"
              name="categoryName"
              id="edit_categoryName"
              value="<%= category.categoryName %>">
            <div class="invalid-feedback" id="err_edit_categoryName">
              <%= locals.error ? error : '' %>
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea class="form-control" name="description" rows="2"><%= category.description || '' %></textarea>
          </div>

          

          <div class="mb-3">
            <label class="form-label">Icon</label>
            <select class="form-select" name="icon">
              <% const icons = [
                { value: 'fa-tags',    label: '🏷️ Default Tag' },
                { value: 'fa-mask',    label: '🎭 Mask' },
                { value: 'fa-bolt',    label: '⚡ Bolt' },
                { value: 'fa-book',    label: '📚 Book' },
                { value: 'fa-gamepad', label: '🎮 Gamepad' },
                { value: 'fa-crown',   label: '👑 Crown' },
                { value: 'fa-image',   label: '🖼️ Image' },
                { value: 'fa-star',    label: '⭐ Star' },
                { value: 'fa-fire',    label: '🔥 Fire' },
                { value: 'fa-dragon',  label: '🐉 Dragon' },
                { value: 'fa-globe',   label: '🌐 Globe' },
              ]; %>
              <% icons.forEach(ic => { %>
                <option value="<%= ic.value %>"
                  <%= (category.icon === ic.value) ? 'selected' : '' %>>
                  <%= ic.label %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label">Display Order</label>
              <input type="number" class="form-control" name="displayOrder"
                id="edit_displayOrder"
                value="<%= category.displayOrder || 1 %>" min="1">
              <div class="invalid-feedback" id="err_edit_displayOrder"></div>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">Status</label>
              <select class="form-select" name="status">
                <option value="Active"   <%= category.isActive  ? 'selected' : '' %>>Active</option>
                <option value="Inactive" <%= !category.isActive ? 'selected' : '' %>>Inactive</option>
              </select>
            </div>
          </div>

          <div class="form-check mb-4">
            <input class="form-check-input" type="checkbox" name="isPremium"
              id="editFeaturedCheck" value="true"
              <%= category.isPremium ? 'checked' : '' %>>
            <label class="form-check-label" for="editFeaturedCheck">
              Set as Premium / Featured Category
            </label>
          </div>

          <div class="d-flex gap-2">
            <a href="/admin/categories" class="btn btn-secondary">Cancel</a>
            <button type="submit" class="btn btn-admin-primary">
              <i class="fas fa-save me-2"></i>Save Changes
            </button>
          </div>

        </form>
      </div>

    </div><!-- /admin-content -->
  </div><!-- /main-content -->

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    // ── Live validation — Edit Category form ────────────────────────────────
    function validateEditCatField(id, errId, rules) {
      const input = document.getElementById(id);
      const errEl = document.getElementById(errId);
      if (!input || !errEl) return true;

      const val = input.value.trim();
      let msg = '';
      if (rules.required && !val)             msg = rules.required;
      else if (rules.min && val && (isNaN(val) || Number(val) < rules.min))
                                              msg = rules.minMsg;

      if (msg) {
        input.classList.add('is-invalid');
        input.classList.remove('is-valid');
        errEl.textContent = msg;
        return false;
      }
      input.classList.remove('is-invalid');
      input.classList.add('is-valid');
      errEl.textContent = '';
      return true;
    }

    const editCatName  = document.getElementById('edit_categoryName');
    const editCatOrder = document.getElementById('edit_displayOrder');

    if (editCatName) {
      editCatName.addEventListener('input', function () {
        validateEditCatField('edit_categoryName', 'err_edit_categoryName',
          { required: 'Category name is required' });
      });
      editCatName.addEventListener('blur', function () {
        validateEditCatField('edit_categoryName', 'err_edit_categoryName',
          { required: 'Category name is required' });
      });
    }

    if (editCatOrder) {
      editCatOrder.addEventListener('input', function () {
        validateEditCatField('edit_displayOrder', 'err_edit_displayOrder',
          { min: 1, minMsg: 'Display order must be at least 1' });
      });
      editCatOrder.addEventListener('blur', function () {
        validateEditCatField('edit_displayOrder', 'err_edit_displayOrder',
          { min: 1, minMsg: 'Display order must be at least 1' });
      });
    }

    // Block form submit if validation fails
    document.querySelector('form').addEventListener('submit', function (e) {
      const nameOk  = validateEditCatField('edit_categoryName', 'err_edit_categoryName',
                        { required: 'Category name is required' });
      const orderOk = validateEditCatField('edit_displayOrder', 'err_edit_displayOrder',
                        { min: 1, minMsg: 'Display order must be at least 1' });
      if (!nameOk || !orderOk) e.preventDefault();
    });
    // ────────────────────────────────────────────────────────────────────────
  </script>
</body>
</html>
