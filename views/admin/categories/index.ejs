<%- include('../../partials/admin-head') %>

<body class="bg-black text-light">
  <%- include('../../partials/admin-sidebar') %>

  <div class="main-content">
    <%- include('../../partials/admin-header') %>

    <div class="admin-content p-4">

      <% if (locals.error) { %>
        <div class="alert alert-danger alert-dismissible fade show rounded-0" role="alert">
          <%= error %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>
      <% if (locals.success) { %>
        <div class="alert alert-success alert-dismissible fade show rounded-0" role="alert">
          <%= success %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>

      <!-- Page Header -->
      <div class="admin-header">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
          <div>
            <h4 class="mb-0" style="color: var(--admin-gold);">Category Management</h4>
            <p class="text-muted small mb-0">Organize your product categories</p>
          </div>
          <button class="btn btn-admin-primary" data-bs-toggle="modal" data-bs-target="#addCategoryModal">
            <i class="fas fa-plus me-2"></i>Add New Category
          </button>
        </div>
      </div>

      <!-- Stats Row -->
      <div class="row g-4 mb-4">
        <div class="col-lg-3 col-md-6">
          <div class="stat-card">
            <div class="stat-icon red"><i class="fas fa-tags"></i></div>
            <h6 class="text-muted text-uppercase mb-2" style="font-size:0.85rem;">Total Categories</h6>
            <h2 class="mb-0" style="color:var(--primary-red);"><%= locals.totalCategories || 0 %></h2>
          </div>
        </div>
        <div class="col-lg-3 col-md-6">
          <div class="stat-card">
            <div class="stat-icon green"><i class="fas fa-check-circle"></i></div>
            <h6 class="text-muted text-uppercase mb-2" style="font-size:0.85rem;">Active Categories</h6>
            <h2 class="mb-0" style="color:#2ecc71;"><%= locals.activeCategories || 0 %></h2>
          </div>
        </div>
        <div class="col-lg-3 col-md-6">
          <div class="stat-card">
            <div class="stat-icon gold"><i class="fas fa-box"></i></div>
            <h6 class="text-muted text-uppercase mb-2" style="font-size:0.85rem;">Premium Categories</h6>
            <h2 class="mb-0" style="color:#3498db;">
          <%= locals.featuredCount || 0 %>
          </h2>
          </div>
        </div>
        <div class="col-lg-3 col-md-6">
          <div class="stat-card">
            <div class="stat-icon blue"><i class="fas fa-star"></i></div>
            <h6 class="text-muted text-uppercase mb-2" style="font-size:0.85rem;">
            Largest Category Share
            </h6>

            <h2 class="mb-0" style="color:#3498db;">
            <%= locals.largestCategory ? locals.largestCategory.name : 'None' %>
            </h2>

            
            <%= locals.largestCategory ? locals.largestCategory.percentage : 0 %>% of products
            
          </div>
        </div>
      </div>

      <!-- Filters -->
      <form method="GET" action="/admin/categories">
        <div class="row mb-4">
          <div class="col-lg-5 col-md-6 mb-3">
            <div class="search-bar">
              <div class="input-group">
                <span class="input-group-text"><i class="fas fa-search"></i></span>
                <input type="text" class="form-control" name="search"
                  placeholder="Search categories..." value="<%= locals.search || '' %>">
              </div>
            </div>
          </div>
          <div class="col-lg-3 col-md-6 mb-3">
            <select class="form-select" name="status">
              <option value="">All Status</option>
              <option value="active"   <%= (locals.status === 'active')   ? 'selected' : '' %>>Active</option>
              <option value="inactive" <%= (locals.status === 'inactive') ? 'selected' : '' %>>Inactive</option>
              <option value="featured" <%= (locals.status === 'featured') ? 'selected' : '' %>>Featured</option>
            </select>
          </div>
          <div class="col-lg-1 col-md-6 mb-3">
            <button type="submit" class="btn btn-admin-primary w-100">Go</button>
          </div>
        </div>
      </form>

      <!-- Categories Grid -->
      <div class="row g-4">
        <% if (locals.categories && categories.length > 0) { %>
          <% categories.forEach(category => { %>
            <div class="col-lg-6">
              <div class="stat-card" style="<%= !category.isActive ? 'opacity:0.6;' : '' %>">

                <!-- Card Top -->
                <div class="d-flex justify-content-between align-items-start mb-3">
                  <div class="d-flex align-items-center gap-3">
                    <div class="stat-icon <%= category.isPremium ? 'gold' : category.isActive ? 'red' : '' %>"
                      style="width:60px;height:60px;<%= !category.isActive ? 'background-color:rgba(149,165,166,0.1);color:#95a5a6;' : '' %>">
                      <i class="fas <%= category.icon || 'fa-tags' %>" style="font-size:1.5rem;"></i>
                    </div>
                    <div>
                      <h5 class="mb-1"><%= category.categoryName %></h5>
                      <p class="text-muted small mb-0"><%= category.description || 'No description' %></p>
                    </div>
                  </div>
                  <!-- Status Badge -->
                  <% if (category.isPremium) { %>
                    <span class="badge badge-gold">Featured</span>
                  <% } else if (category.isActive) { %>
                    <span class="badge badge-success">Active</span>
                  <% } else { %>
                    <span class="badge badge-secondary">Inactive</span>
                  <% } %>
                </div>

                <!-- Stats Row -->
                <div class="row g-3 mb-3">
                  <div class="col-4">
                    <div class="text-center">
                      <h4 class="mb-0" style="color:<%= category.isActive ? 'var(--admin-gold)' : '#95a5a6' %>;">
                        <%= category.productCount || 0 %>
                      </h4>
                      <p class="text-muted small mb-0">Products</p>
                    </div>
                  </div>
                  <div class="col-4">
                    <div class="text-center">
                      <h4 class="mb-0" style="color:<%= category.isActive ? '#3498db' : '#95a5a6' %>;">
                        $<%= category.totalMoney >= 1000 ? (category.totalMoney / 1000).toFixed(1) + 'K' : (category.totalMoney || 0).toFixed(1) %>
                      </h4>
                      <p class="text-muted small mb-0">Revenue</p>
                    </div>
                  </div>
                  <div class="col-4">
                    <div class="text-center">
                      <h4 class="mb-0" style="color:<%= category.isActive ? '#2ecc71' : '#95a5a6' %>;">
                        <%= category.totalPercentage || 0 %>%
                      </h4>
                      <p class="text-muted small mb-0">Share</p>
                    </div>
                  </div>
                </div>

                <!-- Action Buttons -->
                <% if (category.isActive) { %>
                  <div class="d-flex gap-2">
                    <a href="/admin/categories/edit/<%= category._id %>"
                      class="btn btn-sm btn-outline-light flex-fill">
                      <i class="fas fa-edit me-1"></i>Edit
                    </a>
                    <a href="/admin/products?category=<%= category._id %>"
                      class="btn btn-sm btn-outline-light">
                      <i class="fas fa-eye me-1"></i>View Products
                    </a>
                  </div>
                <% } else { %>
                  <div class="d-flex gap-2">
                    <form action="/admin/categories/toggle-status/<%= category._id %>" method="POST" class="flex-fill">
                      <button type="submit" class="btn btn-sm btn-admin-primary w-100">
                        <i class="fas fa-check me-1"></i>Activate
                      </button>
                    </form>
                    <form action="/admin/categories/delete/<%= category._id %>" method="POST"
                      onsubmit="return confirm('Delete \'<%= category.categoryName %>\'? This cannot be undone.')">
                      <button type="submit" class="btn btn-sm btn-danger">
                        <i class="fas fa-trash me-1"></i>Delete
                      </button>
                    </form>
                  </div>
                <% } %>

              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="col-12">
            <div class="stat-card text-center py-5">
              <i class="fas fa-tags fa-3x mb-3 d-block" style="color:#444;"></i>
              <% if (locals.search || locals.status) { %>
                <h5 class="text-muted mb-2">No categories found</h5>
                <p class="text-muted small mb-3">Try adjusting your search or filter.</p>
                <a href="/admin/categories" class="btn btn-admin-primary">
                  <i class="fas fa-times me-2"></i>Clear Filters
                </a>
              <% } else { %>
                <h5 class="text-muted mb-2">No categories yet</h5>
                <p class="text-muted small mb-3">Add your first category to get started.</p>
                <button class="btn btn-admin-primary" data-bs-toggle="modal" data-bs-target="#addCategoryModal">
                  <i class="fas fa-plus me-2"></i>Add Category
                </button>
              <% } %>
            </div>
          </div>
        <% } %>
      </div>

      <!-- Pagination -->
      <% if (locals.totalPages && totalPages > 1) { %>
        <div class="d-flex justify-content-center mt-4">
          <nav>
            <ul class="pagination mb-0">
              <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
                <a class="page-link" href="/admin/categories?page=<%= currentPage - 1 %>&search=<%= locals.search || '' %>&status=<%= locals.status || '' %>">
                  <i class="fas fa-chevron-left"></i>
                </a>
              </li>
              <% for (let i = 1; i <= totalPages; i++) { %>
                <% if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) { %>
                  <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                    <a class="page-link" href="/admin/categories?page=<%= i %>&search=<%= locals.search || '' %>&status=<%= locals.status || '' %>"><%= i %></a>
                  </li>
                <% } else if (i === 2 || i === totalPages - 1) { %>
                  <li class="page-item disabled"><a class="page-link" href="#">...</a></li>
                <% } %>
              <% } %>
              <li class="page-item <%= currentPage >= totalPages ? 'disabled' : '' %>">
                <a class="page-link" href="/admin/categories?page=<%= currentPage + 1 %>&search=<%= locals.search || '' %>&status=<%= locals.status || '' %>">
                  <i class="fas fa-chevron-right"></i>
                </a>
              </li>
            </ul>
          </nav>
        </div>
      <% } %>

    </div><!-- /admin-content -->
  </div><!-- /main-content -->

  <!-- ── Add Category Modal ─────────────────────────────────────────────────── -->
  <!-- ── Add Category Modal ─────────────────────────────────────────────────── -->
<% if (locals.openAddModal) { %>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    var modal = new bootstrap.Modal(document.getElementById('addCategoryModal'));
    modal.show();
  });
</script>
<% } %>

<div class="modal fade" id="addCategoryModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="fas fa-plus-circle me-2"></i>Add New Category</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <form action="/admin/categories/add" method="POST">

          <div class="mb-3">
            <label class="form-label">Category Name</label>
            <input type="text"
              class="form-control <%= (locals.addFieldErrors && locals.addFieldErrors.categoryName) ? 'is-invalid' : '' %>"
              name="categoryName"
              value="<%= (locals.addFormData && locals.addFormData.categoryName) ? locals.addFormData.categoryName : '' %>"
              placeholder="e.g., Marvel Comics">
            <% if (locals.addFieldErrors && locals.addFieldErrors.categoryName) { %>
              <div class="invalid-feedback"><%= locals.addFieldErrors.categoryName %></div>
            <% } %>
          </div>

          <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea class="form-control" name="description" rows="2"
              placeholder="Brief description of the category"><%= (locals.addFormData && locals.addFormData.description) ? locals.addFormData.description : '' %></textarea>
          </div>

          <div class="mb-3">
            <label class="form-label">Icon</label>
            <select class="form-select" name="icon">
              <% const iconOpts = [
                { value: 'fa-tags',    label: '🏷️ Default Tag' },
                { value: 'fa-mask',    label: '🎭 Mask' },
                { value: 'fa-bolt',    label: '⚡ Bolt' },
                { value: 'fa-book',    label: '📚 Book' },
                { value: 'fa-gamepad', label: '🎮 Gamepad' },
                { value: 'fa-crown',   label: '👑 Crown' },
                { value: 'fa-image',   label: '🖼️ Image' },
                { value: 'fa-star',    label: '⭐ Star' },
                { value: 'fa-fire',    label: '🔥 Fire' },
                { value: 'fa-dragon',  label: '🐉 Dragon' },
                { value: 'fa-globe',   label: '🌐 Globe' },
              ]; %>
              <% iconOpts.forEach(ic => { %>
                <option value="<%= ic.value %>"
                  <%= (locals.addFormData && locals.addFormData.icon === ic.value) ? 'selected' : (ic.value === 'fa-tags' && !locals.addFormData) ? 'selected' : '' %>>
                  <%= ic.label %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label">Display Order</label>
              <input type="number"
                class="form-control <%= (locals.addFieldErrors && locals.addFieldErrors.displayOrder) ? 'is-invalid' : '' %>"
                name="displayOrder"
                placeholder="1" min="1"
                value="<%= (locals.addFormData && locals.addFormData.displayOrder) ? locals.addFormData.displayOrder : 1 %>">
              <% if (locals.addFieldErrors && locals.addFieldErrors.displayOrder) { %>
                <div class="invalid-feedback"><%= locals.addFieldErrors.displayOrder %></div>
              <% } %>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">Status</label>
              <select class="form-select" name="status">
                <option value="Active"   <%= (!locals.addFormData || locals.addFormData.status === 'Active')   ? 'selected' : '' %>>Active</option>
                <option value="Inactive" <%= (locals.addFormData  && locals.addFormData.status === 'Inactive') ? 'selected' : '' %>>Inactive</option>
              </select>
            </div>
          </div>

          <div class="form-check mb-3">
            <input class="form-check-input" type="checkbox" name="isPremium"
              id="addFeaturedCheck" value="true"
              <%= (locals.addFormData && locals.addFormData.isPremium === 'true') ? 'checked' : '' %>>
            <label class="form-check-label" for="addFeaturedCheck">
              Set as Premium / Featured Category
            </label>
          </div>

          <div class="d-flex justify-content-end gap-2">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-admin-primary">
              <i class="fas fa-save me-2"></i>Add Category
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
