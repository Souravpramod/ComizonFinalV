<%- include('../../partials/admin-head') %>

<body class="bg-black text-light">
  <%- include('../../partials/admin-sidebar') %>

  <div class="main-content">
    <%- include('../../partials/admin-header') %>

    <div class="admin-content p-4">

      <% if (locals.error) { %>
        <div class="alert alert-danger alert-dismissible fade show rounded-0">
          <%= error %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>

      <% if (locals.success) { %>
        <div class="alert alert-success alert-dismissible fade show rounded-0">
          <%= success %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>

      <!-- Page Header -->
      <div class="admin-header mb-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
          <div>
            <h4 class="mb-0" style="color:var(--admin-gold);">Page Settings</h4>
            <p class="text-muted small mb-0">Choose which categories appear on each page</p>
          </div>
        </div>
      </div>

      <div class="row g-4">

        <% const pages = [
          { key:'home', label:'Home Page' },
          { key:'american', label:'American Comics' },
          { key:'manga', label:'Manga' },
          { key:'toys', label:'Toys' },
          { key:'premium', label:'Premium' }
        ]; %>

        <% pages.forEach(pg => { 
          const setting = (settings || []).find(s => s.page === pg.key) || { categories: [] };
        %>

        <div class="col-lg-6">

          <div class="stat-card">

            <!-- Card Header -->
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h5 class="mb-0"><%= pg.label %></h5>
              <span class="badge badge-gold text-uppercase"><%= pg.key %></span>
            </div>

            <form action="/admin/pgSettings" method="POST">

              <input type="hidden" name="page" value="<%= pg.key %>">

              <div class="row g-2 mb-3">

                <% if (locals.categories && categories.length > 0) { %>
                  <% categories.forEach(cat => { %>

                    <div class="col-md-6">

                      <label class="d-flex align-items-center gap-2 border border-secondary p-2">

                        <input 
                          type="checkbox"
                          name="categories"
                          value="<%= cat._id %>"
                          <%= setting.categories.some(c => c._id.toString() === cat._id.toString()) ? 'checked' : '' %>
                        >

                        <span><%= cat.categoryName %></span>

                      </label>

                    </div>

                  <% }) %>
                <% } else { %>

                  <div class="col-12 text-muted small">
                    No categories found.
                  </div>

                <% } %>

              </div>

              <button type="submit" class="btn btn-admin-primary btn-sm">
                <i class="fas fa-save me-1"></i>Save
              </button>

            </form>

          </div>

        </div>

        <% }) %>

      </div>

    </div>
  </div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>