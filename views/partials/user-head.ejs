<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title + ' | Comizon' : 'Comizon | Premium Comic Store' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <style>
        
        body {
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
        }

        .logo-text,
        .hero-title {
            font-family: 'Anton', sans-serif;
            letter-spacing: 1px;
        }

  
        :root {
            --primary-red: #E63946;
            --dark-bg: #121212;
            --card-bg: #1A1A1A;
            --border-color: #333;
        }

      
        ::selection {
            background: var(--primary-red);
            color: white;
        }

        .text-danger {
            color: var(--primary-red) !important;
        }

        .bg-danger {
            background-color: var(--primary-red) !important;
            border-color: var(--primary-red) !important;
        }

        .btn-danger {
            background-color: var(--primary-red);
            border-color: var(--primary-red);
            transition: all 0.3s ease;
        }

        .btn-danger:hover {
            background-color: #c92a36;
            border-color: #c92a36;
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(230, 57, 70, 0.4);
        }

        .border-danger {
            border-color: var(--primary-red) !important;
        }

    
        .navbar {
            background-color: rgba(18, 18, 18, 0.95) !important;
            backdrop-filter: blur(10px);
            transition: all 0.3s ease;
        }

        .navbar-brand {
            font-size: 1.8rem;
            font-weight: 400;
        }

        .nav-link {
            font-weight: 500;
            text-transform: uppercase;
            font-size: 0.9rem;
            letter-spacing: 0.5px;
            padding: 0.5rem 1rem !important;
            position: relative;
        }

        .nav-link::after {
            content: '';
            position: absolute;
            width: 0;
            height: 2px;
            bottom: 0;
            left: 50%;
            background-color: var(--primary-red);
            transition: all 0.3s ease;
            transform: translateX(-50%);
        }

        .nav-link:hover::after,
        .nav-link.active::after {
            width: 80%;
        }

        .nav-icon {
            color: white;
            font-size: 1.2rem;
            transition: color 0.3s ease;
        }

        .nav-icon:hover {
            color: var(--primary-red);
        }

        .search-bar-group {
            width: 250px;
        }

        .search-bar-group input:focus {
            box-shadow: none;
            border-color: var(--primary-red) !important;
        }

        /* Hero Section */
        .hero-section {
            height: 60vh;
            min-height: 500px;
            background-image: url('dc/hero_section.jpg');
            background-size: cover;
            background-position: center;
            position: relative;
            margin-top: 76px;
            
            border-bottom: 4px solid var(--primary-red);
        }

        .hero-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, #000000 0%, rgba(0, 0, 0, 0.7) 60%, rgba(0, 0, 0, 0.2) 100%);
            z-index: 1;
        }

        .hero-title {
            font-size: 4rem;
            line-height: 0.9;
            text-shadow: 2px 2px 0px #000;
            margin-bottom: 1.5rem;
        }

        @media (max-width: 768px) {
            .hero-title {
                font-size: 2.5rem;
            }

            .hero-section {
                height: 50vh;
            }
        }

        /* Search Section */
        .search-section {
            background-color: #1a1a1a;
            border-bottom: 1px solid #333;
        }

        /* Sidebar & Cards */
        .filter-card {
            position: sticky;
            top: 100px;
        }

        .category-list li {
            margin-bottom: 0.8rem;
        }

        .category-list a {
            color: #aaa;
            text-decoration: none;
            transition: all 0.2s;
            display: block;
            padding: 5px 10px;
            border-left: 2px solid transparent;
        }

        .category-list a:hover,
        .category-list a.active {
            color: white;
            background: rgba(255, 255, 255, 0.05);
            border-left: 2px solid var(--primary-red);
            padding-left: 15px;
        }

        /* Product Card */
        .product-card {
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .product-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            border-color: var(--primary-red) !important;
        }

        .card-img-wrapper img {
            height: 350px;
            object-fit: cover;
            width: 100%;
            transition: transform 0.5s ease;
        }

        .product-card:hover .card-img-wrapper img {
            transform: scale(1.05);
        }

        .card-title {
            color: white;
            transition: color 0.3s ease;
        }

        .product-card:hover .card-title {
            color: #FFD700;
        }

        .wishlist-btn {
            opacity: 0;
            transform: translateX(20px);
            transition: all 0.3s ease;
        }

        .product-card:hover .wishlist-btn {
            opacity: 1;
            transform: translateX(0);
        }

        .wishlist-btn:hover {
            background-color: var(--primary-red);
            color: white;
        }

        .wishlist-btn:hover i {
            color: white !important;
        }

        /* Footer */
        .footer-link {
            color: white;
            text-decoration: none;
            transition: color 0.3s ease;
        }

        .footer-link:hover {
            color: #FFD700 !important;
        }

        .pagination .page-link {
            border-radius: 0 !important;
            margin: 0 2px;
        }

        .hover-danger:hover {
            background-color: var(--primary-red) !important;
            border-color: var(--primary-red) !important;
        }

        /* Form Styles for Premium Feel */
        .form-range::-webkit-slider-thumb {
            background: var(--primary-red);
        }

        .form-control:focus,
        .form-select:focus {
            box-shadow: none;
            border-color: var(--primary-red);
        }
    </style>
</head>
