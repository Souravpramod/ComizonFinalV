<%- include('../partials/user-head', { title: 'Reset Password' }) %>
  <style>
    body {
      background: linear-gradient(135deg, #1a1a1a 0%, #000 100%);
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .reset-container {
      background: #121212;
      border: 1px solid #333;
      border-top: 4px solid var(--primary-red);
      width: 100%;
      max-width: 480px;
      padding: 3rem 2.5rem;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.7);
    }

    .form-control {
      background: #1E1E1E;
      border: 1px solid #444;
      color: white;
      padding: 0.9rem;
      border-radius: 0;
    }

    .form-control:focus {
      background: #1E1E1E;
      border-color: var(--primary-red);
      color: white;
      box-shadow: none;
    }

    .password-strength {
      height: 4px;
      border-radius: 2px;
      transition: all 0.3s;
    }
  </style>

  <body class="bg-black text-light">
    <div class="reset-container">
      <div class="text-center mb-4">
        <h2 class="logo-text mb-1">COMIZON<span class="text-danger">.</span></h2>
      </div>
      <div class="text-center mb-4"
        style="width:80px;height:80px;background:linear-gradient(135deg,var(--primary-red),#c92a36);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;font-size:2.5rem;color:white;">
        <i class="fas fa-key"></i>
      </div>
      <div class="text-center mb-4">
        <h4 class="fw-bold text-uppercase">Set New Password</h4>
        <p class="text-muted small">Your new password must be at least 8 characters.</p>
      </div>

      <% if (locals.error) { %>
        <div class="alert alert-danger rounded-0 small py-2 mb-3">
          <%= error %>
        </div>
        <% } %>

          <form action="/reset-password" method="POST">
            <input type="hidden" name="email" value="<%= locals.email || '' %>">
            <div class="mb-3">
              <label class="text-muted small fw-bold">NEW PASSWORD</label>
              <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-danger"><i class="fas fa-lock"></i></span>
                <input type="password" name="password" id="newPass" class="form-control password-field"
                  placeholder="New password" required minlength="8">
                <button class="btn btn-outline-secondary border-secondary toggle-password" type="button"><i
                    class="fas fa-eye"></i></button>
              </div>
              <div class="mt-2">
                <div class="password-strength bg-secondary" id="strengthBar"></div>
              </div>
            </div>
            <div class="mb-4">
              <label class="text-muted small fw-bold">CONFIRM PASSWORD</label>
              <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-danger"><i class="fas fa-lock"></i></span>
                <input type="password" name="confirmPassword" id="confPass" class="form-control password-field"
                  placeholder="Confirm password" required>
                <button class="btn btn-outline-secondary border-secondary toggle-password" type="button"><i
                    class="fas fa-eye"></i></button>
              </div>
              <div id="matchMsg" class="small mt-1"></div>
            </div>
            <button type="submit" class="btn btn-danger w-100 py-3 text-uppercase fw-bold rounded-0">
              <i class="fas fa-save me-2"></i>Reset Password
            </button>
          </form>

          <div class="text-center mt-4">
            <a href="/login" class="text-danger text-decoration-none fw-bold"><i class="fas fa-arrow-left me-1"></i>Back
              to Login</a>
          </div>
    </div>
    <script>
      document.querySelectorAll('.toggle-password').forEach(button => {
        button.addEventListener('click', function () {
          const input = this.previousElementSibling;
          const icon = this.querySelector('i');

          if (input.type === 'password') {
            input.type = 'text';
            icon.classList.remove('fa-eye');
            icon.classList.add('fa-eye-slash');
          } else {
            input.type = 'password';
            icon.classList.remove('fa-eye-slash');
            icon.classList.add('fa-eye');
          }
        });
      });

      document.getElementById('newPass').addEventListener('input', function () {
        const len = this.value.length;
        const bar = document.getElementById('strengthBar');
        if (len < 6) { bar.style.width = '33%'; bar.className = 'password-strength bg-danger'; }
        else if (len < 10) { bar.style.width = '66%'; bar.className = 'password-strength bg-warning'; }
        else { bar.style.width = '100%'; bar.className = 'password-strength bg-success'; }
      });
      document.getElementById('confPass').addEventListener('input', function () {
        const msg = document.getElementById('matchMsg');
        if (this.value === document.getElementById('newPass').value) {
          msg.innerHTML = '<span class="text-success"><i class="fas fa-check me-1"></i>Passwords match</span>';
        } else {
          msg.innerHTML = '<span class="text-danger"><i class="fas fa-times me-1"></i>Passwords do not match</span>';
        }
      });
    </script>
  </body>

  </html>