<% const products=Array.isArray(locals.products) ? locals.products : []; const totalProducts=typeof
  locals.totalProducts==='number' ? locals.totalProducts : products.length; const totalPages=typeof
  locals.totalPages==='number' ? locals.totalPages : 1; const currentPage=typeof locals.currentPage==='number' ?
  locals.currentPage : 1; const activeCategory=typeof locals.activeCategory==='string' ? locals.activeCategory : 'all' ;
  const sort=typeof locals.sort==='string' ? locals.sort : 'featured' ; const heroImage=typeof
  locals.heroImage==='string' ? locals.heroImage : '' ; const search=typeof locals.search==='string' ? locals.search : '' ;
  const dbCats=Array.isArray(locals.dbCategories) ? locals.dbCategories : [];
  const categories=[ { key:'all', label:'All' }, ...dbCats.map(c=>({ key: c._id.toString(), label: c.categoryName })) ]; %>

  <%- include('../partials/user-head', { title: 'Home' }) %>

    <body class="bg-black text-light">
      <%- include('../partials/header') %>

        <!-- HERO -->
        <header class="hero-section d-flex align-items-center"
          style="height:80vh; min-height:600px; background-image:url('<%= heroImage %>'); background-size:cover; background-position:center; margin-top:76px;">
          <div class="container position-relative z-2">
            <div class="row">
              <div class="col-lg-8">
                <h1 class="display-1 fw-bold text-uppercase hero-title">Unleash Your <span
                    class="text-danger">Hero</span></h1>
                <p class="lead mb-4 text-white-50">The ultimate destination for collectors. American Comics, Manga, and
                  Exclusive Premium Figures.</p>
                <div class="d-flex gap-3">
                  <a href="/american" class="btn btn-danger btn-lg px-4 rounded-0 fw-bold">SHOP NOW</a>
                  <a href="/premium" class="btn btn-outline-light btn-lg px-4 rounded-0 fw-bold">JOIN PREMIUM</a>
                </div>
              </div>
            </div>
          </div>
          <div class="hero-overlay"></div>
        </header>

        <!-- CATEGORY PILLS -->
        <section class="py-4 border-bottom border-secondary" style="background:#0d0d0d;">
          <div class="container">
            <div class="d-flex flex-wrap gap-2">
              <% categories.forEach(cat=> { %>
                <a href="/?category=<%= cat.key %>&page=1&sort=<%= sort %>&search=<%= encodeURIComponent(search) %>"
                  class="category-pill <%= activeCategory === cat.key ? 'active' : '' %>">
                  <%= cat.label %>
                </a>
                <% }) %>
            </div>
          </div>
        </section>

        <!-- PRODUCTS -->
        <section class="container py-5">
          <div class="row">
            <!-- Sidebar -->
            <aside class="col-lg-3 mb-4">
              <div class="filter-card bg-dark p-4 rounded-0 border border-secondary">
                <h4 class="text-uppercase fw-bold mb-4"><i class="fas fa-filter text-danger me-2"></i>Categories</h4>
                <ul class="list-unstyled category-list">
                  <% categories.forEach(cat=> { %>
                    <li><a href="/?category=<%= cat.key %>&page=1&sort=<%= sort %>&search=<%= encodeURIComponent(search) %>" class="<%= activeCategory===cat.key?'active':'' %>">
                        <%= cat.label %>
                      </a></li>
                    <% }) %>
                </ul>

                <hr class="border-secondary my-4">

                <h5 class="fw-bold mb-3">Search</h5>
                <form action="/" method="GET">
                  <input type="hidden" name="category" value="<%= activeCategory %>">
                  <input type="hidden" name="sort" value="<%= sort %>">
                  <input type="hidden" name="page" value="1">
                  <div class="input-group">
                    <input type="text" class="form-control bg-black text-light border-secondary rounded-0 shadow-none"
                      name="search" placeholder="Search products..." value="<%= search %>">
                    <button class="btn btn-danger rounded-0" type="submit"><i class="fas fa-search"></i></button>
                  </div>
                </form>

                <hr class="border-secondary my-4">

                <h5 class="fw-bold mb-3">Price Range</h5>

            <form action="/" method="GET">

            <input type="hidden" name="category" value="<%= activeCategory %>">
            <input type="hidden" name="sort" value="<%= sort %>">
            <input type="hidden" name="search" value="<%= search %>">
            <input type="hidden" name="page" value="1">

            <div class="mb-2">
            <input type="range"
            class="form-range"
            name="maxPrice"
            min="0"
            max="500"
            step="5"
            value="<%= typeof locals.maxPrice !== 'undefined' ? locals.maxPrice : 500 %>"
            oninput="document.getElementById('priceValue').innerText=this.value">
            </div>

            <div class="d-flex justify-content-between text-white small mb-3">
            <span>$0</span>
            <span>$<span id="priceValue"><%= typeof locals.maxPrice !== 'undefined' ? locals.maxPrice : 500 %></span></span>
            </div>

            <button class="btn btn-danger btn-sm w-100">Apply</button>

            </form>
            </aside>

            <!-- Product Grid -->
            <main class="col-lg-9">
              <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-secondary pb-3">
                <h2 class="text-white fw-bold text-uppercase border-start border-4 border-danger ps-3 mb-0">
                  Best Sellers
                  <% if (activeCategory !=='all' ) { %><span class="text-danger ms-2 fs-5">— <%= activeCategory %>
                    </span>
                    <% } %>
                  <% if (search) { %><span class="text-muted fs-6 ms-2 text-lowercase fw-normal">"<%= search %>"</span><% } %>
                </h2>
                <div class="d-flex align-items-center gap-3">
                  <span class="text-muted small">Showing <%= products.length %> of <%= totalProducts %></span>
                  <select class="form-select form-select-sm bg-black text-light border-secondary rounded-0 shadow-none"
                    onchange="location.href='/?sort='+this.value+'&category=<%= activeCategory %>&page=<%= currentPage %>&search=<%= encodeURIComponent(search) %>'">
                    <option value="featured" <%=sort==='featured' ?'selected':'' %>>Sort: Featured</option>
                    <option value="az" <%=sort==='az' ?'selected':'' %>>A–Z</option>
                    <option value="za" <%=sort==='za' ?'selected':'' %>>Z–A</option>
                    <option value="low" <%=sort==='low' ?'selected':'' %>>Price: Low–High</option>
                    <option value="high" <%=sort==='high' ?'selected':'' %>>Price: High–Low</option>
                  </select>
                </div>
              </div>

              <div class="row g-4">
                <% if (products.length> 0) { %>
                  <% products.forEach(p=> { %>
                    <div class="col-md-4">
                      <div class="card product-card h-100 bg-transparent border border-secondary rounded-0"
                           onclick="location.href='/product/<%= p._id %>'" style="cursor:pointer;">
                        <div class="card-img-wrapper position-relative overflow-hidden">
                          <img src="<%= p.image %>"
                               onerror="this.src='https://placehold.co/300x450/1a1a1a/E63946?text=No+Image'"
                               class="card-img-top" alt="<%= p.name %>">
                          <form action="/wishlist/add/<%= p._id %>" method="POST" onclick="event.stopPropagation()">
                            <button type="submit" class="btn btn-light btn-sm position-absolute top-0 end-0 m-2 rounded-circle wishlist-btn" title="Add to Wishlist">
                              <i class="far fa-heart text-danger"></i>
                            </button>
                          </form>
                          <% if (p.badge) { %>
                            <span class="badge <%= p.badge==='PREMIUM'?'bg-warning text-dark':'bg-danger' %> position-absolute top-0 start-0 m-2 rounded-0">
                              <%= p.badge %>
                            </span>
                          <% } %>
                        </div>
                        <div class="card-body">
                          <div class="text-muted small mb-1"><%= p.category %></div>
                          <h5 class="card-title fw-bold text-truncate text-white"><%= p.name %></h5>
                          <div class="d-flex align-items-center mb-2">
                            <% const full=Math.floor(p.rating||0); const half=(p.rating||0)%1>=0.25&&(p.rating||0)%1<0.75; %>
                            <div class="text-warning small me-2">
                              <% for(let i=0;i<full;i++){ %><i class="fas fa-star"></i><% } %>
                              <% if(half){ %><i class="fas fa-star-half-alt"></i><% } %>
                              <% for(let i=0;i<(5-full-(half?1:0));i++){ %><i class="far fa-star"></i><% } %>
                            </div>
                            <span class="text-muted small">(<%= p.reviews||0 %>)</span>
                          </div>
                          <div class="d-flex justify-content-between align-items-center mt-3">
                            <h4 class="text-white mb-0">$<%= Number(p.price).toFixed(2) %></h4>
                            <form action="/cart/add/<%= p._id %>" method="POST" onclick="event.stopPropagation()">
                              <button type="submit" class="btn btn-outline-danger btn-sm rounded-0">
                                <i class="fas fa-cart-plus"></i> Add
                              </button>
                            </form>
                          </div>
                        </div>
                      </div>
                    </div>
                  <% }) %>
                <% } else { %>
                  <div class="col-12 text-center py-5">
                    <p class="text-muted">No products found.</p>
                  </div>
                <% } %>
              </div>

              <% if (totalPages> 1) { %>
                <nav aria-label="Page navigation" class="mt-5 d-flex justify-content-center">
                  <ul class="pagination">
                    <li class="page-item <%= currentPage===1?'disabled':'' %>">
                      <a class="page-link <%= currentPage===1?'bg-dark text-white border-secondary':'bg-dark text-white border-secondary hover-danger' %>"
                        href="/?page=<%= currentPage-1 %>&category=<%= activeCategory %>&sort=<%= sort %>&search=<%= encodeURIComponent(search) %>"
                        <%=currentPage===1?'tabindex="-1" aria-disabled="true"':'' %>>Previous</a>
            </li>
            <% for (let i=1; i<=totalPages; i++) { %>
                <li class="page-item <%= i===currentPage?' active':'' %>">
                        <a class="page-link <%= i===currentPage?'bg-danger text-white border-danger':'bg-dark text-white border-secondary hover-danger' %>"
                          href="/?page=<%= i %>&category=<%= activeCategory %>&sort=<%= sort %>&search=<%= encodeURIComponent(search) %>">
                          <%= i %>
                        </a>
                    </li>
                    <% } %>
                      <li class="page-item <%= currentPage===totalPages?'disabled':'' %>">
                        <a class="page-link <%= currentPage===totalPages?'bg-dark text-white border-secondary':'bg-dark text-white border-secondary hover-danger' %>"
                          href="/?page=<%= currentPage+1 %>&category=<%= activeCategory %>&sort=<%= sort %>&search=<%= encodeURIComponent(search) %>"
                          <%=currentPage===totalPages?'tabindex="-1" aria-disabled="true"':'' %>>Next</a>
            </li>
          </ul>
        </nav>
      <% } %>
    </main>
  </div>
</section>

<%- include('../partials/footer') %>
    </body>

    </html>
