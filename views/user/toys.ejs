<% 
const products = Array.isArray(locals.products) ? locals.products : [];
const totalProducts = typeof locals.totalProducts === 'number' ? locals.totalProducts : 0;
const totalPages = typeof locals.totalPages === 'number' ? locals.totalPages : 1;
const currentPage = typeof locals.currentPage === 'number' ? locals.currentPage : 1;
const activeCategory = typeof locals.activeCategory === 'string' ? locals.activeCategory : 'all';
const sort = typeof locals.sort === 'string' ? locals.sort : 'featured';
const search = typeof locals.search === 'string' ? locals.search : '';

const CDN = 'https://res.cloudinary.com/deutxfkar/image/upload/v1771836691';
const title = 'Toys & Figures';

const dbCats = Array.isArray(locals.dbCategories) ? locals.dbCategories : [];

const categories = [
  { key:'all', label:'All Items' },
  ...dbCats.map(c => ({ key: c._id.toString(), label: c.categoryName }))
];

const displayProducts = products;
%>

<%- include('../partials/user-head', { title }) %>

<body class="bg-black text-light">

<%- include('../partials/header') %>

<!-- HERO -->
<header class="hero-section d-flex align-items-center"
style="height:60vh; min-height:500px; background-image:url('<%= heroImage || CDN + `/hero_imaget.jpg` %>'); background-size:cover; background-position:center; margin-top:76px;">

<div class="container position-relative z-2">
<div class="col-lg-7">

<h1 class="hero-title text-uppercase" style="font-size:4rem;">
Toys & <span class="text-danger">Figures</span>
</h1>

<p class="text-white-50 lead mb-4">
Find your favorite characters and bring them home.
</p>

<a href="#products" class="btn btn-danger btn-lg rounded-0 fw-bold px-4">
Browse All
</a>

</div>
</div>

<div class="hero-overlay"></div>

</header>





<section class="container py-5" id="products">

<div class="row">

<!-- Sidebar -->
<aside class="col-lg-3 mb-4">

<div class="filter-card bg-dark p-4 rounded-0 border border-secondary">

<h4 class="text-uppercase fw-bold mb-4">
<i class="fas fa-filter text-danger me-2"></i>Categories
</h4>

<ul class="list-unstyled category-list">

<% categories.forEach(cat => { %>

<li>
<a href="/toys?category=<%= cat.key %>&page=1&sort=<%= sort %>&search=<%= encodeURIComponent(search) %>"
class="<%= activeCategory === cat.key ? 'active' : '' %>">

<%= cat.label %>

</a>
</li>

<% }) %>

</ul>
<h5 class="fw-bold mb-3">Search</h5>

<form action="/toys" method="GET" id="search-form">
<input type="hidden" name="category" value="<%= activeCategory %>">
<input type="hidden" name="sort" value="<%= sort %>">
<input type="hidden" name="page" value="1">

<div class="input-group">
<input type="text"
class="form-control bg-black text-light border-secondary"
id="search-input"
name="search"
placeholder="Search toys..."
value="<%= search %>">

<button class="btn btn-danger">
<i class="fas fa-search"></i>
</button>
</div>
</form>

<hr class="border-secondary my-4">

<hr class="border-secondary my-4">


<hr class="border-secondary my-4">

<h5 class="fw-bold mb-3">Price Range</h5>

<form action="/toys" method="GET" id="price-form">
    <input type="hidden" name="category" value="<%= activeCategory %>">
    <input type="hidden" name="sort" value="<%= sort %>">
    <input type="hidden" name="search" value="<%= search %>">
    <input type="hidden" name="page" value="1">

    <div class="mb-2">
        <input type="range"
            class="form-range"
            id="price-range"
            name="maxPrice"
            min="0"
            max="1000"
            step="5"
            value="<%= typeof locals.maxPrice !== 'undefined' ? locals.maxPrice : 1000 %>"
            oninput="document.getElementById('priceValue').innerText=this.value">
    </div>

    <div class="d-flex justify-content-between text-white small mb-3">
        <span>$0</span>
        <span>$<span id="priceValue"><%= typeof locals.maxPrice !== 'undefined' ? locals.maxPrice : 1000 %></span></span>
    </div>

    <button class="btn btn-danger btn-sm w-100">Apply</button>
</form>
</div>

</aside>


<!-- Product Grid -->
<main class="col-lg-9">

<div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-secondary pb-3">

<h2 class="text-white fw-bold text-uppercase border-start border-4 border-danger ps-3 mb-0">

Toys & Figures

<% if (activeCategory !== 'all') { %>
<span class="text-danger ms-2 fs-5">— <%= activeCategory %></span>
<% } %>

<% if (search) { %>
<span class="text-muted fs-6 ms-2 text-lowercase fw-normal">"<%= search %>"</span>
<% } %>

</h2>


<div class="d-flex align-items-center gap-3">

<span class="text-muted small" id="showing-count">
Showing <%= displayProducts.length %> of <%= totalProducts || displayProducts.length %>
</span>

<select
class="form-select form-select-sm bg-black text-light border-secondary rounded-0 shadow-none"
id="sort-select">

<option value="featured" <%= sort === 'featured' ? 'selected' : '' %>>Sort: Featured</option>
<option value="az" <%= sort === 'az' ? 'selected' : '' %>>A–Z</option>
<option value="za" <%= sort === 'za' ? 'selected' : '' %>>Z–A</option>
<option value="low" <%= sort === 'low' ? 'selected' : '' %>>Price: Low–High</option>
<option value="high" <%= sort === 'high' ? 'selected' : '' %>>Price: High–Low</option>

</select>

</div>

</div>



<div class="row g-4" id="product-grid">

<% if (displayProducts.length > 0) { %>

<% displayProducts.forEach(p => { %>

<div class="col-md-4" data-product-id="<%= p._id %>">

<div class="card product-card h-100 bg-transparent border border-secondary rounded-0"
onclick="location.href='/product/<%= p._id %>'"
style="cursor:pointer;">

<div class="card-img-wrapper position-relative overflow-hidden">

<img src="<%= p.image %>"
onerror="this.src='https://placehold.co/300x450/1a1a1a/E63946?text=No+Image'"
class="card-img-top"
alt="<%= p.name %>">

<% const inWishlist = (locals.wishlistIds || []).includes(p._id.toString()); %>
                          <form action="/wishlist/add/<%= p._id %>" method="POST" onclick="event.stopPropagation()">
                            <button type="submit" class="btn btn-light btn-sm position-absolute top-0 end-0 m-2 rounded-circle wishlist-btn" title="<%= inWishlist ? 'In Wishlist' : 'Add to Wishlist' %>">
                              <i class="<%= inWishlist ? 'fas' : 'far' %> fa-heart text-danger"></i>
                            </button>
                          </form>

<% if (p.badge) { %>
<span class="badge <%= p.badge === 'PREMIUM' ? 'bg-warning text-dark' : 'bg-danger' %> position-absolute top-0 start-0 m-2 rounded-0">
<%= p.badge %>
</span>
<% } %>

</div>


<div class="card-body">

<div class="text-muted small mb-1"><%= p.category %></div>

<h5 class="card-title fw-bold text-truncate text-white">
<%= p.name %>
</h5>

<div class="d-flex align-items-center mb-2">

<% const full = Math.floor(p.rating || 0); const half = (p.rating || 0)%1 >= 0.25 && (p.rating || 0)%1 < 0.75; %>

<div class="text-warning small me-2">

<% for(let i=0;i<full;i++){ %><i class="fas fa-star"></i><% } %>
<% if(half){ %><i class="fas fa-star-half-alt"></i><% } %>
<% for(let i=0;i<(5-full-(half?1:0));i++){ %><i class="far fa-star"></i><% } %>

</div>

<span class="text-muted small">(<%= p.reviews || 0 %>)</span>

</div>


<div class="d-flex justify-content-between align-items-center mt-3">

<div>
  <% if (p.effectivePrice && p.effectivePrice < p.price) { %>
    <div class="text-white-50 text-decoration-line-through" data-original-price style="font-size:.8rem; line-height:1.2;">
      $<%= Number(p.price).toFixed(2) %>
    </div>
    <h4 class="mb-0 text-white" data-price data-effective-price="<%= p.effectivePrice %>">$<%= Number(p.effectivePrice).toFixed(2) %></h4>
    <div class="mt-1">
      <span class="fw-bold" data-offer-badge style="font-size:.72rem; color:<%= p.badgeColorListing || '#E63946' %>;">
        <i class="fas fa-tag me-1"></i><%= p.offerBadge %>
      </span>
    </div>
  <% } else { %>
    <div class="text-white-50 text-decoration-line-through" data-original-price style="font-size:.8rem; line-height:1.2; display:none;"></div>
    <h4 class="text-white mb-0" data-price data-effective-price="<%= p.price %>">$<%= Number(p.price).toFixed(2) %></h4>
    <div class="mt-1">
      <span class="fw-bold" data-offer-badge style="font-size:.72rem; color:#E63946; display:none;"></span>
    </div>
  <% } %>
</div>

<form action="/cart/add/<%= p._id %>" method="POST" onclick="event.stopPropagation()">
<button type="submit" class="btn btn-outline-danger btn-sm rounded-0" data-add-cart-btn>
<i class="fas fa-cart-plus"></i> Add
</button>
</form>

</div>

</div>

</div>

</div>

<% }) %>

<% } else { %>

<div class="col-12 text-center py-5">
<p class="text-muted">No products found.</p>
</div>

<% } %>

</div>



<% if (totalPages > 1) { %>

<nav class="mt-5 d-flex justify-content-center" id="pagination-wrap">

<ul class="pagination">

<li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">

<a class="page-link bg-dark text-white border-secondary"
href="/toys?page=<%= currentPage-1 %>&category=<%= activeCategory %>&sort=<%= sort %>&search=<%= encodeURIComponent(search) %>"
data-page="<%= currentPage-1 %>">

Previous

</a>

</li>


<% for(let i=1;i<=totalPages;i++){ %>

<li class="page-item <%= i===currentPage?'active':'' %>">

<a class="page-link <%= i===currentPage?'bg-danger text-white border-danger':'bg-dark text-white border-secondary' %>"
href="/toys?page=<%= i %>&category=<%= activeCategory %>&sort=<%= sort %>&search=<%= encodeURIComponent(search) %>"
data-page="<%= i %>">

<%= i %>

</a>

</li>

<% } %>


<li class="page-item <%= currentPage===totalPages?'disabled':'' %>">

<a class="page-link bg-dark text-white border-secondary"
href="/toys?page=<%= currentPage+1 %>&category=<%= activeCategory %>&sort=<%= sort %>&search=<%= encodeURIComponent(search) %>"
data-page="<%= currentPage+1 %>">

Next

</a>

</li>

</ul>

</nav>

<% } %>

</main>

</div>

</section>

<%- include('../partials/footer') %>

<script>
  window.LISTING_BASE  = '/toys';
  window.LISTING_STATE = {
    category : '<%= activeCategory %>',
    sort     : '<%= sort %>',
    search   : '<%= search %>',
    minPrice : <%= typeof locals.minPrice !== 'undefined' ? locals.minPrice : 0 %>,
    maxPrice : <%= typeof locals.maxPrice !== 'undefined' ? locals.maxPrice : 1000 %>,
    page     : <%= currentPage %>
  };
</script>
<script src="/js/user/listing-ajax.js"></script>
<%- include('../partials/offer-poller') %>

</body>
</html>