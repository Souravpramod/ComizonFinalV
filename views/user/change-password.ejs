<%- include('../partials/user-head', { title: 'Change Password' }) %>

<style>
  body {
    background: linear-gradient(135deg, #1a1a1a 0%, #000 100%);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .change-container {
    background: #121212;
    border: 1px solid #333;
    border-top: 4px solid var(--primary-red);
    width: 100%;
    max-width: 480px;
    padding: 3rem 2.5rem;
    box-shadow: 0 10px 40px rgba(0,0,0,0.7);
  }

  .form-control {
    background: #1E1E1E;
    border: 1px solid #444;
    color: white;
    padding: 0.9rem;
    border-radius: 0;
  }

  .form-control:focus {
    background: #1E1E1E;
    border-color: var(--primary-red);
    color: white;
    box-shadow: none;
  }

  .password-strength {
    height: 4px;
    border-radius: 2px;
    transition: all 0.3s;
  }
</style>

<body class="bg-black text-light">
  <div class="change-container">

    <div class="text-center mb-2">
      <h2 class="logo-text mb-1">COMIZON<span class="text-danger">.</span></h2>
    </div>

    <div class="text-center mb-4"
      style="width:80px;height:80px;background:linear-gradient(135deg,var(--primary-red),#c92a36);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;font-size:2.5rem;color:white;">
      <i class="fas fa-shield-alt"></i>
    </div>

    <div class="text-center mb-4">
      <h4 class="fw-bold text-uppercase">Change Password</h4>
      <p class="text-white small">Almost there! Set your new password below.</p>
    </div>

    <% if (locals.error) { %>
      <div class="alert alert-danger rounded-0 small py-2 mb-3">
        <%= error %>
      </div>
    <% } %>

    <form action="/change-password" method="POST">
      <input type="hidden" name="email" value="<%= locals.email || '' %>">

      <div class="mb-3">
        <label class="text-white small fw-bold">NEW PASSWORD</label>
        <div class="input-group">
          <span class="input-group-text bg-dark border-secondary text-danger">
            <i class="fas fa-lock"></i>
          </span>
          <input type="password" name="password" id="newPass"
            class="form-control" placeholder="New password" required minlength="8">
          <button class="btn btn-outline-secondary border-secondary toggle-password" type="button">
            <i class="fas fa-eye"></i>
          </button>
        </div>
        <div class="mt-2">
          <div class="password-strength bg-secondary" id="strengthBar" style="width:0%;"></div>
        </div>
        <ul class="list-unstyled mt-2 small" id="criteria-list">
          <% (locals.passwordCriteria || []).forEach(c => { %>
            <li class="<%= c.passed ? 'text-success' : 'text-danger' %>">
              <i class="fas <%= c.passed ? 'fa-check' : 'fa-times' %> me-1"></i><%= c.label %>
            </li>
          <% }) %>
        </ul>
      </div>

      <div class="mb-4">
        <label class="text-white small fw-bold">CONFIRM PASSWORD</label>
        <div class="input-group">
          <span class="input-group-text bg-dark border-secondary text-danger">
            <i class="fas fa-lock"></i>
          </span>
          <input type="password" name="confirmPassword" id="confPass"
            class="form-control" placeholder="Confirm password" required>
          <button class="btn btn-outline-secondary border-secondary toggle-password" type="button">
            <i class="fas fa-eye"></i>
          </button>
        </div>
        <div id="matchMsg" class="small mt-1"></div>
      </div>

      <button type="submit" class="btn btn-danger w-100 py-3 text-uppercase fw-bold rounded-0">
        <i class="fas fa-check me-2"></i>Confirm & Log In
      </button>
    </form>

  </div>

   <script>
    const criteria = [
      { label: 'At least 8 characters',        test: v => v.length >= 8 },
      { label: 'At least one letter',           test: v => /[a-zA-Z]/.test(v) },
      { label: 'At least one number',           test: v => /[0-9]/.test(v) },
      { label: 'At least one special character',test: v => /[^a-zA-Z0-9]/.test(v) },
    ];

    function updateCriteria(password) {
      const list = document.getElementById('criteria-list');
      if (!list) return;
      list.querySelectorAll('li').forEach((li, i) => {
        const passed = criteria[i].test(password);
        li.className = passed ? 'text-success' : 'text-danger';
        li.querySelector('i').className = passed ? 'fas fa-check me-1' : 'fas fa-times me-1';
      });
    }

    function updateStrengthBar(password) {
      const passed = criteria.filter(c => c.test(password)).length;
      const bar = document.getElementById('strengthBar');
      if (passed <= 1)      { bar.style.width = '25%';  bar.className = 'password-strength bg-danger'; }
      else if (passed === 2) { bar.style.width = '50%';  bar.className = 'password-strength bg-warning'; }
      else if (passed === 3) { bar.style.width = '75%';  bar.className = 'password-strength bg-warning'; }
      else                   { bar.style.width = '100%'; bar.className = 'password-strength bg-success'; }
    }

    document.querySelectorAll('.toggle-password').forEach(button => {
      button.addEventListener('click', function () {
        const input = this.previousElementSibling;
        const icon = this.querySelector('i');
        if (input.type === 'password') {
          input.type = 'text';
          icon.classList.replace('fa-eye', 'fa-eye-slash');
        } else {
          input.type = 'password';
          icon.classList.replace('fa-eye-slash', 'fa-eye');
        }
      });
    });

    document.getElementById('newPass').addEventListener('input', function () {
      updateCriteria(this.value);
      updateStrengthBar(this.value);
    });

    document.getElementById('confPass').addEventListener('input', function () {
      const msg = document.getElementById('matchMsg');
      if (this.value === document.getElementById('newPass').value) {
        msg.innerHTML = '<span class="text-success"><i class="fas fa-check me-1"></i>Passwords match</span>';
      } else {
        msg.innerHTML = '<span class="text-danger"><i class="fas fa-times me-1"></i>Passwords do not match</span>';
      }
    });
  </script>
</body>
</html>