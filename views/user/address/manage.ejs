<%- include('../../partials/user-head') %>

<body class="bg-black text-light">
<%- include('../../partials/header') %>

<style>
  .addr-card {
    background: #1a1a1a;
    border: 1px solid #333;
    border-radius: 4px;
    padding: 1.2rem 1.4rem;
    margin-bottom: 1rem;
    transition: border-color 0.2s, background 0.2s;
    cursor: pointer;
  }
  .addr-card.selected {
    border-color: #E63946;
    background: #1f1010;
  }
  .addr-card input[type="radio"] {
    accent-color: #E63946;
  }
  .badge-type {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 2px 10px;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .badge-home   { background: #1a3a5c; color: #5bc0f8; }
  .badge-work   { background: #3a2a00; color: #f0a500; }
  .badge-other  { background: #2a2a2a; color: #aaaaaa; }
  .badge-default { background: #1a4a1a; color: #4caf50; font-size: 0.7rem; padding: 2px 8px; border-radius: 3px; }

  .selected-panel {
    background: #1a1a1a;
    border: 1px solid #333;
    border-left: 4px solid #E63946;
    padding: 1.4rem;
    border-radius: 4px;
    position: sticky;
    top: 100px;
  }
  .guidelines-panel {
    background: #0d1a2a;
    border: 1px solid #1a3a5c;
    border-radius: 4px;
    padding: 1.2rem;
    margin-top: 1rem;
    font-size: 0.85rem;
    color: #aaaaaa;
  }
  .add-address-btn {
    display: block;
    width: 100%;
    background: transparent;
    border: 1px dashed #444;
    color: #aaaaaa;
    padding: 1rem;
    text-align: center;
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
    border-radius: 4px;
  }
  .add-address-btn:hover {
    border-color: #E63946;
    color: #E63946;
  }
  .inline-edit-form {
    display: none;
    background: #111;
    border-top: 1px solid #333;
    padding-top: 1rem;
    margin-top: 1rem;
  }
  .inline-edit-form.open { display: block; }

  .form-control, .form-select {
    background: #111 !important;
    border-color: #444 !important;
    color: #fff !important;
  }
  .form-control:focus, .form-select:focus {
    border-color: #E63946 !important;
    box-shadow: none !important;
  }
  .form-control.is-invalid, .form-select.is-invalid {
    border-color: #E63946 !important;
  }
  .field-error {
    color: #ff4d4d;
    font-size: 0.75rem;
    margin-top: 0.25rem;
    display: block;
  }
  .modal-content {
    background: #1a1a1a;
    border: 1px solid #444;
    border-top: 4px solid #E63946;
    border-radius: 0;
  }
  .modal-header { border-bottom: 1px solid #333; }
  .modal-footer { border-top: 1px solid #333; }
</style>

<div class="container" style="margin-top:100px; margin-bottom:4rem;">
  <div class="row g-4">

    <!-- Sidebar -->
    <div class="col-lg-3">
      <%- include('../../partials/profile-sidebar', { activePage: 'addresses' }) %>
    </div>

    <!-- Main Content -->
    <div class="col-lg-9">

      <!-- Header -->
      <div class="bg-dark border border-secondary p-4 mb-4 d-flex justify-content-between align-items-start"
           style="border-top: 4px solid #E63946 !important;">
        <div>
          <h5 class="fw-bold text-uppercase border-start border-4 border-danger ps-3 mb-1">Manage Address</h5>
          <p class="text-muted small mb-0 ps-3">Select your default shipping address</p>
        </div>
        <a href="/profile" class="btn btn-outline-secondary btn-sm rounded-0">
          <i class="fas fa-arrow-left me-1"></i> Back to Profile
        </a>
      </div>

      <% if (locals.success) { %>
        <div class="alert alert-success rounded-0 small"><%= success %></div>
      <% } %>
      <% if (locals.error) { %>
        <div class="alert alert-danger rounded-0 small"><%= error %></div>
      <% } %>

      <div class="row g-4">
        <!-- Address List -->
        <div class="col-lg-7">

          <% if (addresses && addresses.length > 0) { %>
            <% addresses.forEach((addr, i) => { %>
              <div class="addr-card <%= addr.isDefault ? 'selected' : '' %>" id="card-<%= addr._id %>">
                <div class="d-flex align-items-start gap-3">

                  <!-- Radio to set default -->
                  <form action="/profile/address/default/<%= addr._id %>" method="POST" class="mt-1">
                    <input type="radio" name="defaultAddr"
                           <%= addr.isDefault ? 'checked' : '' %>
                           onchange="this.form.submit()"
                           style="width:18px;height:18px;accent-color:#E63946;">
                  </form>

                  <div class="flex-grow-1">
                    <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                      <span class="fw-bold text-white">
                        <%= locals.user ? user.firstName + ' ' + user.lastName : '' %>
                      </span>
                      <span class="badge-type badge-<%= addr.type || 'other' %>">
                        <i class="fas <%= addr.type === 'home' ? 'fa-home' : addr.type === 'work' ? 'fa-briefcase' : 'fa-map-marker-alt' %> me-1"></i>
                        <%= addr.type || 'other' %>
                      </span>
                      <% if (addr.isDefault) { %>
                        <span class="badge-default"><i class="fas fa-check-circle me-1"></i>Default</span>
                      <% } %>
                    </div>

                    <p class="mb-1 text-white-50 small">
                      <%= addr.addressLane1 %><% if (addr.addressLane2) { %>, <%= addr.addressLane2 %><% } %>
                    </p>
                    <p class="mb-2 text-white-50 small">
                      <%= addr.city %><% if (addr.state) { %>, <%= addr.state %><% } %>
                      <% if (addr.pincode) { %> <%= addr.pincode %><% } %>
                    </p>

                    <!-- Action buttons -->
                    <div class="d-flex gap-2">
                      <button class="btn btn-outline-secondary btn-sm rounded-0"
                              onclick="toggleEdit('<%= addr._id %>')">
                        <i class="fas fa-edit me-1"></i>Edit
                      </button>
                      <button type="button" class="btn btn-outline-danger btn-sm rounded-0"
                        onclick="userConfirmDeleteAddress('<%= addr._id %>')">
                        <i class="fas fa-trash me-1"></i>Delete
                      </button>
                      <form id="del-addr-<%= addr._id %>" action="/profile/address/delete/<%= addr._id %>" method="POST" style="display:none;"></form>
                    </div>

                    <!-- Inline Edit Form -->
                    <%
                      const isEditOpen = locals.openEditId && locals.openEditId == addr._id.toString();
                      const editErrors = isEditOpen && locals.formErrors && locals.formErrors.edit ? locals.formErrors.edit : {};
                      const editData   = isEditOpen && locals.formData   && locals.formData.edit   ? locals.formData.edit   : {};
                      const ev = (field, fallback) => editData[field] !== undefined ? editData[field] : (fallback || '');
                    %>
                    <div class="inline-edit-form <%= isEditOpen ? 'open' : '' %>" id="edit-<%= addr._id %>">
                      <form action="/profile/address/edit/<%= addr._id %>" method="POST" novalidate>
                        <div class="row g-2">
                          <div class="col-md-6">
                            <label class="form-label text-danger small fw-bold">TYPE</label>
                            <select name="type" class="form-select form-select-sm rounded-0 <%= editErrors.type ? 'is-invalid' : '' %>">
                              <option value="home"  <%= ev('type', addr.type) === 'home'  ? 'selected' : '' %>>Home</option>
                              <option value="work"  <%= ev('type', addr.type) === 'work'  ? 'selected' : '' %>>Work</option>
                              <option value="other" <%= ev('type', addr.type) === 'other' ? 'selected' : '' %>>Other</option>
                            </select>
                            <% if (editErrors.type) { %><span class="field-error"><i class="fas fa-exclamation-circle me-1"></i><%= editErrors.type %></span><% } %>
                          </div>
                          <div class="col-md-6">
                            <label class="form-label text-danger small fw-bold">PINCODE</label>
                            <input type="text" name="pincode" value="<%= ev('pincode', addr.pincode) %>"
                                   class="form-control form-control-sm rounded-0 <%= editErrors.pincode ? 'is-invalid' : '' %>">
                            <% if (editErrors.pincode) { %><span class="field-error"><i class="fas fa-exclamation-circle me-1"></i><%= editErrors.pincode %></span><% } %>
                          </div>
                          <div class="col-12">
                            <label class="form-label text-danger small fw-bold">ADDRESS LINE 1</label>
                            <input type="text" name="addressLane1" value="<%= ev('addressLane1', addr.addressLane1) %>"
                                   class="form-control form-control-sm rounded-0 <%= editErrors.addressLane1 ? 'is-invalid' : '' %>">
                            <% if (editErrors.addressLane1) { %><span class="field-error"><i class="fas fa-exclamation-circle me-1"></i><%= editErrors.addressLane1 %></span><% } %>
                          </div>
                          <div class="col-12">
                            <label class="form-label text-danger small fw-bold">ADDRESS LINE 2</label>
                            <input type="text" name="addressLane2" value="<%= ev('addressLane2', addr.addressLane2) %>"
                                   class="form-control form-control-sm rounded-0">
                          </div>
                          <div class="col-md-4">
                            <label class="form-label text-danger small fw-bold">CITY</label>
                            <input type="text" name="city" value="<%= ev('city', addr.city) %>"
                                   class="form-control form-control-sm rounded-0 <%= editErrors.city ? 'is-invalid' : '' %>">
                            <% if (editErrors.city) { %><span class="field-error"><i class="fas fa-exclamation-circle me-1"></i><%= editErrors.city %></span><% } %>
                          </div>
                          <div class="col-md-4">
                            <label class="form-label text-danger small fw-bold">STATE</label>
                            <input type="text" name="state" value="<%= ev('state', addr.state) %>"
                                   class="form-control form-control-sm rounded-0 <%= editErrors.state ? 'is-invalid' : '' %>">
                            <% if (editErrors.state) { %><span class="field-error"><i class="fas fa-exclamation-circle me-1"></i><%= editErrors.state %></span><% } %>
                          </div>
                          <div class="col-md-4">
                            <label class="form-label text-danger small fw-bold">COUNTRY</label>
                            <input type="text" name="country" value="<%= ev('country', addr.country) %>"
                                   class="form-control form-control-sm rounded-0 <%= editErrors.country ? 'is-invalid' : '' %>">
                            <% if (editErrors.country) { %><span class="field-error"><i class="fas fa-exclamation-circle me-1"></i><%= editErrors.country %></span><% } %>
                          </div>
                          <div class="col-12 d-flex gap-2 mt-1">
                            <button type="submit" class="btn btn-danger btn-sm rounded-0 fw-bold px-3">Save</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm rounded-0"
                                    onclick="toggleEdit('<%= addr._id %>')">Cancel</button>
                          </div>
                        </div>
                      </form>
                    </div>

                  </div>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="text-center text-muted py-5">
              <i class="fas fa-map-marker-alt fa-3x mb-3 text-secondary"></i>
              <p>No addresses saved yet.</p>
            </div>
          <% } %>

          <!-- Add New Address Button -->
          <button class="add-address-btn mt-2" data-bs-toggle="modal" data-bs-target="#addAddressModal">
            <i class="fas fa-plus-circle me-2"></i>Add New Address
          </button>

        </div>

        <!-- Selected Address Panel -->
        <div class="col-lg-5">
          <% const defaultAddr = addresses.find(a => a.isDefault); %>
          <div class="selected-panel">
            <div class="fw-bold text-uppercase small text-danger mb-3 border-start border-3 border-danger ps-2">
              Selected Address
            </div>
            <% if (defaultAddr) { %>
              <p class="fw-bold text-white mb-1">
                <%= user.firstName %> <%= user.lastName %>
              </p>
              <p class="text-white-50 small mb-1"><%= defaultAddr.addressLane1 %></p>
              <% if (defaultAddr.addressLane2) { %>
                <p class="text-white-50 small mb-1"><%= defaultAddr.addressLane2 %></p>
              <% } %>
              <p class="text-white-50 small mb-1">
                <%= defaultAddr.city %><% if (defaultAddr.state) { %>, <%= defaultAddr.state %><% } %>
                <% if (defaultAddr.pincode) { %> <%= defaultAddr.pincode %><% } %>
              </p>
              <% if (user.phone) { %>
                <p class="text-white-50 small mb-3"><%= user.phone %></p>
              <% } %>
              
            <% } else { %>
              <p class="text-muted small">No default address selected.</p>
            <% } %>
          </div>

          <!-- Guidelines -->
          <div class="guidelines-panel">
            <div class="text-info small fw-bold mb-2">
              <i class="fas fa-info-circle me-1"></i> Address Guidelines
            </div>
            <ul class="mb-0 ps-3 small" style="line-height:2;">
              <li>Ensure your address is complete and accurate</li>
              <li>Include apartment/suite numbers if applicable</li>
              <li>Add a phone number for delivery updates</li>
              <li>You can have multiple addresses saved</li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<!-- Add Address Modal -->
<%
  const addErrors = locals.formErrors && locals.formErrors.add ? locals.formErrors.add : {};
  const addData   = locals.formData   && locals.formData.add   ? locals.formData.add   : {};
  const openModal = Object.keys(addErrors).length > 0;
%>
<div class="modal fade" id="addAddressModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h6 class="modal-title fw-bold text-uppercase text-white">
          <i class="fas fa-plus-circle me-2 text-danger"></i>Add New Address
        </h6>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form action="/profile/address/add" method="POST" novalidate>
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label text-danger small fw-bold">TYPE</label>
              <select name="type" class="form-select rounded-0 <%= addErrors.type ? 'is-invalid' : '' %>">
                <option value="home"  <%= addData.type === 'home'  ? 'selected' : '' %>>Home</option>
                <option value="work"  <%= addData.type === 'work'  ? 'selected' : '' %>>Work</option>
                <option value="other" <%= addData.type === 'other' ? 'selected' : '' %>>Other</option>
              </select>
              <% if (addErrors.type) { %><span class="field-error"><i class="fas fa-exclamation-circle me-1"></i><%= addErrors.type %></span><% } %>
            </div>
            <div class="col-md-6">
              <label class="form-label text-danger small fw-bold">PINCODE</label>
              <input type="text" name="pincode" value="<%= addData.pincode || '' %>"
                     class="form-control rounded-0 <%= addErrors.pincode ? 'is-invalid' : '' %>" placeholder="e.g. 560001">
              <% if (addErrors.pincode) { %><span class="field-error"><i class="fas fa-exclamation-circle me-1"></i><%= addErrors.pincode %></span><% } %>
            </div>
            <div class="col-12">
              <label class="form-label text-danger small fw-bold">ADDRESS LINE 1</label>
              <input type="text" name="addressLane1" value="<%= addData.addressLane1 || '' %>"
                     class="form-control rounded-0 <%= addErrors.addressLane1 ? 'is-invalid' : '' %>" placeholder="Street, building">
              <% if (addErrors.addressLane1) { %><span class="field-error"><i class="fas fa-exclamation-circle me-1"></i><%= addErrors.addressLane1 %></span><% } %>
            </div>
            <div class="col-12">
              <label class="form-label text-danger small fw-bold">ADDRESS LINE 2</label>
              <input type="text" name="addressLane2" value="<%= addData.addressLane2 || '' %>"
                     class="form-control rounded-0" placeholder="Apt, floor (optional)">
            </div>
            <div class="col-md-4">
              <label class="form-label text-danger small fw-bold">CITY</label>
              <input type="text" name="city" value="<%= addData.city || '' %>"
                     class="form-control rounded-0 <%= addErrors.city ? 'is-invalid' : '' %>">
              <% if (addErrors.city) { %><span class="field-error"><i class="fas fa-exclamation-circle me-1"></i><%= addErrors.city %></span><% } %>
            </div>
            <div class="col-md-4">
              <label class="form-label text-danger small fw-bold">STATE</label>
              <input type="text" name="state" value="<%= addData.state || '' %>"
                     class="form-control rounded-0 <%= addErrors.state ? 'is-invalid' : '' %>">
              <% if (addErrors.state) { %><span class="field-error"><i class="fas fa-exclamation-circle me-1"></i><%= addErrors.state %></span><% } %>
            </div>
            <div class="col-md-4">
              <label class="form-label text-danger small fw-bold">COUNTRY</label>
              <input type="text" name="country" value="<%= addData.country || '' %>"
                     class="form-control rounded-0 <%= addErrors.country ? 'is-invalid' : '' %>">
              <% if (addErrors.country) { %><span class="field-error"><i class="fas fa-exclamation-circle me-1"></i><%= addErrors.country %></span><% } %>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary rounded-0" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-danger rounded-0 fw-bold px-4">Add Address</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  function toggleEdit(id) {
    const form = document.getElementById('edit-' + id);
    form.classList.toggle('open');
  }

  // ── Field validation rules ────────────────────────────────────────────────
  function getFieldError(name, value) {
    const v = (value || '').trim();
    if (name === 'addressLane1') return v.length < 5 ? 'Address Line 1 must be at least 5 characters.' : '';
    if (name === 'city') {
      if (!v || v.length < 2) return 'City is required.';
      if (!/^[a-zA-Z\s\-'.]+$/.test(v)) return 'City must contain only letters.';
      return '';
    }
    if (name === 'state') {
      if (v && !/^[a-zA-Z\s\-'.]+$/.test(v)) return 'State must contain only letters.';
      return '';
    }
    if (name === 'country') {
      if (v && !/^[a-zA-Z\s\-'.]+$/.test(v)) return 'Country must contain only letters.';
      return '';
    }
    if (name === 'pincode') return !v ? 'Pincode is required.' : '';
    return '';
  }

  function setFieldState(input, msg) {
    let errEl = input.parentElement.querySelector('.live-field-err');
    if (!errEl) {
      errEl = document.createElement('span');
      errEl.className = 'field-error live-field-err';
      input.parentElement.appendChild(errEl);
    }
    if (msg) {
      errEl.innerHTML = `<i class="fas fa-exclamation-circle me-1"></i>${msg}`;
      input.classList.add('is-invalid');
    } else {
      errEl.innerHTML = '';
      input.classList.remove('is-invalid');
      input.classList.add('is-valid');
    }
  }

  // Attach live validation to all relevant inputs in a given container
  function wireFormValidation(container) {
    const fields = ['addressLane1', 'city', 'state', 'country', 'pincode'];
    fields.forEach(name => {
      const input = container.querySelector(`[name="${name}"]`);
      if (!input) return;
      ['blur', 'input'].forEach(evt => {
        input.addEventListener(evt, () => {
          // Skip pincode on input event — it uses async API check
          if (name === 'pincode' && evt === 'input') return;
          setFieldState(input, getFieldError(name, input.value));
        });
      });
    });
  }

  // ── Live pincode validation (async API) ───────────────────────────────────
  async function checkPincode(pincodeInput, countryInput, msgEl) {
    const pin  = pincodeInput.value.trim();
    const ctry = countryInput.value.trim();
    if (!pin) { setFieldState(pincodeInput, 'Pincode is required.'); return; }
    if (!ctry) { msgEl && (msgEl.innerHTML = ''); return; }

    msgEl.innerHTML = '<span style="color:#aaa;font-size:.75rem;"><i class="fas fa-spinner fa-spin me-1"></i>Validating…</span>';
    pincodeInput.classList.remove('is-invalid', 'is-valid');

    try {
      const res  = await fetch(`/profile/address/validate-pincode?pincode=${encodeURIComponent(pin)}&country=${encodeURIComponent(ctry)}`);
      const data = await res.json();
      if (data.valid) {
        msgEl.innerHTML = '<span style="color:#28a745;font-size:.75rem;"><i class="fas fa-check-circle me-1"></i>Valid postal code.</span>';
        pincodeInput.classList.remove('is-invalid');
        pincodeInput.classList.add('is-valid');
      } else {
        msgEl.innerHTML = `<span style="color:#ff4d4d;font-size:.75rem;"><i class="fas fa-exclamation-circle me-1"></i>${data.message}</span>`;
        pincodeInput.classList.add('is-invalid');
        pincodeInput.classList.remove('is-valid');
      }
    } catch (_) { msgEl.innerHTML = ''; }
  }

  function wirePincode(container) {
    const pinEl  = container.querySelector('input[name="pincode"]');
    const ctryEl = container.querySelector('input[name="country"]');
    if (!pinEl || !ctryEl) return;
    let msg = pinEl.parentElement.querySelector('.pincode-live-msg');
    if (!msg) {
      msg = document.createElement('div');
      msg.className = 'pincode-live-msg';
      pinEl.parentElement.appendChild(msg);
    }
    pinEl.addEventListener('blur',  () => checkPincode(pinEl, ctryEl, msg));
    ctryEl.addEventListener('blur', () => { if (pinEl.value.trim()) checkPincode(pinEl, ctryEl, msg); });
  }

  document.addEventListener('DOMContentLoaded', function () {
    // Add Address Modal
    const addModal = document.getElementById('addAddressModal');
    if (addModal) {
      wireFormValidation(addModal);
      wirePincode(addModal);
    }

    // All inline Edit forms
    document.querySelectorAll('.inline-edit-form').forEach(form => {
      wireFormValidation(form);
      wirePincode(form);
    });

    <% if (openModal) { %>
      new bootstrap.Modal(document.getElementById('addAddressModal')).show();
    <% } %>
  });
</script>
<script>
function userConfirmDeleteAddress(id) {
  const overlay = document.createElement('div');
  overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.8);z-index:10000;display:flex;align-items:center;justify-content:center;';
  overlay.innerHTML = `
    <div style="background:#1A1A1A;border:1px solid #333;padding:2rem;width:100%;max-width:400px;font-family:'Inter',sans-serif;">
      <p style="color:#fff;font-size:1rem;margin-bottom:1.5rem;">Delete this address?</p>
      <div style="display:flex;gap:10px;justify-content:flex-end;">
        <button id="cancelDelBtn" style="background:transparent;border:1px solid #555;color:#aaa;padding:8px 20px;cursor:pointer;">Cancel</button>
        <button id="confirmDelBtn" style="background:#E63946;border:none;color:#fff;padding:8px 20px;font-weight:600;cursor:pointer;">Delete</button>
      </div>
    </div>`;
  document.body.appendChild(overlay);
  overlay.querySelector('#cancelDelBtn').addEventListener('click', () => overlay.remove());
  overlay.querySelector('#confirmDelBtn').addEventListener('click', () => {
    const form = document.getElementById('del-addr-' + id);
    if (form) form.submit();
  });
}
</script>

<%- include('../../partials/footer') %>
</body>
</html>
