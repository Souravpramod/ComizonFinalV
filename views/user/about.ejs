<% if(locals.sessionUser && locals.sessionUser.isPremium){ %>

<h3 class="text-warning fw-bold">Hi Skeptic 👋</h3>

<% } else { %>

<a href="/premium" class="btn btn-outline-warning btn-lg fw-bold">
JOIN NOW
</a>

<% } %>

</div>

</div>
</div>
</div>

