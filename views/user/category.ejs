<%- include('../partials/user-head') %>

    <body class="bg-black text-light">

        <%- include('../partials/header') %>

            <!-- Hero Section -->
            <header class="hero-section d-flex align-items-center"
                style="background-image: url('<%= categoryHeroImage || 'dc/hero_section.jpg' %>');">
                <div class="container position-relative z-2">
                    <div class="row">
                        <div class="col-lg-8">
                            <h1 class="display-1 fw-bold text-uppercase hero-title">
                                <%= categoryTitle %><span class="text-danger">.</span>
                            </h1>
                            <p class="lead mb-4 text-white-50">
                                <%= categoryDescription %>
                            </p>
                        </div>
                    </div>
                </div>
                <div class="hero-overlay"></div>
            </header>

            <!-- Main Content -->
            <section class="container py-5">
                <div class="row">
                    <!-- Sidebar -->
                    <aside class="col-lg-3 mb-4">
                        <div class="filter-card bg-dark p-4 rounded-0 border border-secondary">
                            <h4 class="text-uppercase fw-bold mb-4"><i class="fas fa-filter text-danger me-2"></i>Filter
                            </h4>
                            <form action="/<%= categorySlug %>" method="GET">
                                <div class="mb-4">
                                    <h6 class="fw-bold mb-3">Sort By</h6>
                                    <select name="sort"
                                        class="form-select bg-black text-light border-secondary rounded-0 shadow-none"
                                        onchange="this.form.submit()">
                                        <option value="featured" <%=locals.sort==='featured' ? 'selected' : '' %>
                                            >Featured</option>
                                        <option value="price-low" <%=locals.sort==='price-low' ? 'selected' : '' %>
                                            >Price: Low to High</option>
                                        <option value="price-high" <%=locals.sort==='price-high' ? 'selected' : '' %>
                                            >Price: High to Low</option>
                                    </select>
                                </div>
                            </form>
                        </div>
                    </aside>

                    <!-- Product Grid -->
                    <main class="col-lg-9">
                        <div class="row g-4" id="product-grid">
                            <% if (locals.products && products.length> 0) { %>
                                <% products.forEach(product=> { %>
                                    <div class="col-md-6 col-lg-4">
                                        <div
                                            class="card product-card h-100 bg-transparent border border-secondary rounded-0">
                                            <div class="card-img-wrapper position-relative overflow-hidden">
                                                <a href="/product/<%= product._id %>">
                                                    <img src="<%= product.image %>" onerror="this.src='https://placehold.co/300x450/1a1a1a/E63946?text=Image+Not+Found'" class="card-img-top"
                                                        alt="<%= product.name %>">
                                                </a>
                                                <a href="/wishlist/add/<%= product._id %>"
                                                    class="btn btn-light btn-sm position-absolute top-0 end-0 m-2 rounded-circle wishlist-btn">
                                                    <i class="far fa-heart text-danger"></i>
                                                </a>
                                            </div>
                                            <div class="card-body">
                                                <h5 class="card-title fw-bold text-truncate">
                                                    <a href="/product/<%= product._id %>"
                                                        class="text-white text-decoration-none">
                                                        <%= product.name %>
                                                    </a>
                                                </h5>
                                                <div class="d-flex justify-content-between align-items-center mt-3">
                                                    <h4 class="text-white mb-0">$<%= product.price %>
                                                    </h4>
                                                    <a href="/cart/add/<%= product._id %>"
                                                        class="btn btn-outline-danger btn-sm rounded-0">Add</a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <% }) %>
                                        <% } else { %>
                                            <div class="col-12 text-center py-5">
                                                <p class="text-muted">No products found in this category.</p>
                                            </div>
                                            <% } %>
                        </div>
                    </main>
                </div>
            </section>

            <%- include('../partials/footer') %>
    </body>

    </html>

