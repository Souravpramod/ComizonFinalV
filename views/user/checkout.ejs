                <span>Shipping</span>
                <% if (shippingFee === 0) { %>
                  <span class="text-success">FREE</span>
                <% } else { %>
                  <span>$<%= shippingFee.toFixed(2) %></span>
                <% } %>
              </div>
              <% const totalOfferSaving = cartItems.reduce((sum, i) => i.hasOffer ? +(sum + (i.price - i.effectivePrice) * i.quantity).toFixed(2) : sum, 0); %>
<div class="d-flex justify-content-between small mb-2" id="offerSavingsRow" style="color:#28a745;<%= totalOfferSaving > 0 ? '' : 'display:none;' %>">
  <span><i class="fas fa-tag me-1"></i>Offer Savings</span>
  <span id="offerSavingsAmt">- $<%= totalOfferSaving.toFixed(2) %></span>
</div>
              <div class="d-flex justify-content-between text-white-50 small mb-2" id="discountRow" style="display:none!important;">
                <span>Discount (<span id="appliedCodeDisplay"></span>)</span>
                <span class="text-success">- $<span id="discountDisplay">0.00</span></span>
              </div>

              <hr class="border-secondary">

              <div class="d-flex justify-content-between align-items-center mb-4">
                <span class="fw-bold">Total</span>
                <span class="fw-bold text-danger fs-5" id="grandTotal">$<%= total.toFixed(2) %></span>
