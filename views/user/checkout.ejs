                <i class="fas fa-ban me-1"></i>Some items in your cart have issues — please go back to your cart to resolve them before placing the order.
              </div>

              <p class="text-white-50 text-center mt-3 mb-0" style="font-size:.75rem;">
                <i class="fas fa-shield-alt me-1 text-success"></i>
                Secure checkout. Cash on Delivery available.
              </p>
            </div>
          </div>
        </div>

      </div><!-- /row -->
    </form>
  </div>

  <%- include('../partials/footer') %>
  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

  <script>
    <% if (locals.qtyAdjusted && qtyAdjusted.length) { %>
      window.addEventListener('DOMContentLoaded', () => {
        <% qtyAdjusted.forEach(adj => { %>
          showToast(
            `<i class="fas fa-exclamation-triangle me-1"></i> <strong><%= adj.name %></strong>: quantity reduced from <%= adj.from %> to <%= adj.to %> due to stock availability.`,
            'warning'
          );
        <% }) %>
      });
    <% } %>

    <% if (locals.isRetry) { %>
      window.addEventListener('DOMContentLoaded', async () => {
        try {
          
          const rzpRes = await fetch('/checkout/place-order', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              paymentMethod: 'online',
              addressId: '<%= defaultAddress?._id?.toString() || "" %>',
              couponCode: '<%= locals.retryCouponCode || "" %>',
            }),
          });
          const rzpData = await rzpRes.json();
          if (!rzpData.pendingOrder) throw new Error(rzpData.message || 'Retry preparation failed');

          const options = {
            key:         rzpData.key,
            amount:      rzpData.amount,
            currency:    rzpData.currency,
            name:        'Comizon',
            description: 'Retry Payment',
            order_id:    rzpData.razorpayOrderId,
            handler: async function (response) {
              const verifyRes = await fetch('/checkout/razorpay/verify', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  razorpay_order_id:   response.razorpay_order_id,
                  razorpay_payment_id: response.razorpay_payment_id,
                  razorpay_signature:  response.razorpay_signature,
                  addressId: '<%= defaultAddress?._id?.toString() || "" %>',
                }),
              });
              const verifyJson = await verifyRes.json();
              if (verifyJson.success) {
                window.location.href = verifyJson.redirectUrl;
              } else {
                showToast('Payment verification failed. Please contact support.');
              }
            },
            prefill: {
              name:    "<%= user.firstName %>",
              email:   "<%= user.email %>",
              contact: "<%= user.phone %>",
            },
            theme: { color: '#E63946' },
            modal: {
              ondismiss: function () {
                window.location.href = '/orders';
              },
            },
          };

          const rzp = new Razorpay(options);
          rzp.on('payment.failed', function (response) {
            const reason = response.error.description || 'Payment failed';
            window.location.href = `/checkout/payment-failed?reason=${encodeURIComponent(reason)}`;
          });
          rzp.open();

        } catch (err) {
          console.error('Auto retry error:', err);
          showToast('Could not initiate payment. Please try again.');
        }
      });
    <% } %>

    function showToast(msg, type='danger') {
    const id = 'toast_' + Date.now();
    const bg = type === 'success' ? 'bg-success' : type === 'warning' ? 'bg-warning text-dark' : 'bg-danger';
    const el = document.createElement('div');
    el.id = id;
    el.className = `toast align-items-center text-white border-0 ${bg} position-fixed rounded-0`;
    el.style.cssText = 'top:80px;right:20px;z-index:9999;min-width:280px;';
    el.setAttribute('role','alert');
    el.innerHTML = `<div class="d-flex"><div class="toast-body fw-semibold">${msg}</div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div>`;
    document.body.appendChild(el);
    const t = new bootstrap.Toast(el, { delay: 4000 });
    t.show();
    el.addEventListener('hidden.bs.toast', () => el.remove());
}
  // ── Constants from server ──────────────────────────────────────────────────
  // ── Constants from server ──────────────────────────────────────────────────
let BASE_SUBTOTAL    = <%= subtotal %>;
let BASE_SHIPPING    = <%= shippingFee %>;
let BASE_TOTAL       = <%= total %>;
const WALLET_BALANCE = <%= (walletBalance !== undefined ? walletBalance : 0) %>;
const FREE_SHIPPING_THRESHOLD = 500;
const SHIPPING_FEE_AMOUNT     = 5;

  // Compute total offer discount = sum of (price - effectivePrice) * qty for items with offers
  window._offerDiscount = <%- JSON.stringify(
    cartItems.reduce((sum, i) => {
      if (i.hasOffer && i.effectivePrice !== undefined) {
        return +(sum + (i.price - i.effectivePrice) * i.quantity).toFixed(2);
      }
      return sum;
    }, 0)
  ) %>;

  // ── Coupon state ──────────────────────────────────────────────────────────
  let appliedDiscount = 0;
  let appliedCode     = '';

  function tapCoupon(code) {
    document.getElementById('couponInput').value = code;
    handleCouponApply();
  }

  async function handleCouponApply() {
    const input   = document.getElementById('couponInput');
    const msgEl   = document.getElementById('couponMsg');
    const code    = input.value.trim().toUpperCase();

    if (!code) { msgEl.innerHTML = ''; return; }

    if (code === appliedCode) {
      removeCoupon();
      return;
    }

    msgEl.innerHTML = '<span class="text-white-50"><i class="fas fa-spinner fa-spin me-1"></i>Validating…</span>';

    try {
      const cartItemsForCoupon = <%- JSON.stringify(cartItems.map(i => ({
        productId:  i._id,
        categoryId: i.categoryId || null,
        quantity:   i.quantity,
        lineTotal:  i.lineTotal,
      }))) %>;

      const res  = await fetch('/checkout/apply-coupon', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({
          code,
          subtotal:             BASE_SUBTOTAL,
          appliedOfferDiscount: window._offerDiscount || 0,
          cartItems:            cartItemsForCoupon,
        }),
      });
      const data = await res.json();

      if (data.success) {
        appliedDiscount = data.discount;
        appliedCode     = data.code;

        document.getElementById('appliedCouponCode').value  = data.code;
        document.getElementById('appliedDiscountAmt').value = data.discount;

        updateTotal();
        document.getElementById('discountRow').style.display     = 'flex';
        document.getElementById('appliedCodeDisplay').textContent = data.code;
        document.getElementById('discountDisplay').textContent    = data.discount.toFixed(2);

        document.querySelectorAll('.coupon-card').forEach(el => el.classList.remove('applied'));
        const card = document.getElementById('ccard-' + data.code);
        if (card) card.classList.add('applied');

        document.getElementById('couponApplyBtn').textContent = 'REMOVE';
        document.getElementById('couponApplyBtn').classList.replace('btn-outline-danger', 'btn-outline-success');

        msgEl.innerHTML = `<span class="text-success"><i class="fas fa-check-circle me-1"></i>${data.message}</span>`;
      } else {
        msgEl.innerHTML = `<span class="text-danger"><i class="fas fa-times-circle me-1"></i>${data.message}</span>`;
      }
    } catch (err) {
      msgEl.innerHTML = '<span class="text-danger">Something went wrong. Try again.</span>';
    }
  }

  function removeCoupon() {
    appliedDiscount = 0;
    appliedCode     = '';

    document.getElementById('appliedCouponCode').value  = '';
    document.getElementById('appliedDiscountAmt').value = '0';
    document.getElementById('discountRow').style.display = 'none';
    document.getElementById('couponInput').value = '';

    document.querySelectorAll('.coupon-card').forEach(el => el.classList.remove('applied'));

    const btn = document.getElementById('couponApplyBtn');
    btn.textContent = 'APPLY';
    btn.classList.replace('btn-outline-success', 'btn-outline-danger');

    document.getElementById('couponMsg').innerHTML = '';
    updateTotal();
  }

  function updateTotal() {
    const newTotal = Math.max(0, BASE_SUBTOTAL + BASE_SHIPPING - appliedDiscount);
    document.getElementById('grandTotal').textContent = '$' + newTotal.toFixed(2);
  }

  // ── Coupon status poller ───────────────────────────────────────────────────
  // Collects all coupon codes visible on the page (cards + any applied one),
  // polls every 8 seconds, and reacts if admin deactivates one mid-session.
  (function startCouponPoller() {
    // Build the initial set of codes from rendered cards
    const knownCodes = new Set(
      [...document.querySelectorAll('.coupon-card[id^="ccard-"]')]
        .map(el => el.id.replace('ccard-', ''))
    );

    async function pollStatuses() {
      // Always include the currently applied code even if it has no card
      if (appliedCode) knownCodes.add(appliedCode);
      if (!knownCodes.size) return;

      try {
        const res  = await fetch('/checkout/coupon-status?codes=' + [...knownCodes].join(','));
        const data = await res.json();
        const statuses = data.statuses || {};

        for (const [code, status] of Object.entries(statuses)) {
          const card = document.getElementById('ccard-' + code);

          if (status === 'inactive') {
            // ── Dim the card if it exists ──────────────────────────────────
            if (card) {
              card.classList.add('not-applicable');
              card.style.pointerEvents = 'none';
              card.style.opacity = '0.45';
              // Add an "Inactive" badge if not already there
              if (!card.querySelector('.inactive-badge')) {
                const badge = document.createElement('span');
                badge.className = 'inactive-badge text-danger fw-bold';
                badge.style.cssText = 'font-size:.65rem;display:block;margin-top:.3rem;';
                badge.innerHTML = '<i class="fas fa-ban me-1"></i>Unavailable';
                card.appendChild(badge);
              }
            }

            // ── If THIS was the applied coupon, auto-remove it ─────────────
            if (appliedCode === code) {
              removeCoupon();
              // Show a persistent warning message
              const msgEl = document.getElementById('couponMsg');
              msgEl.innerHTML = `<span class="text-danger fw-bold">
                <i class="fas fa-exclamation-triangle me-1"></i>
                Your coupon <strong>${code}</strong> was deactivated by the store and has been removed.
              </span>`;
            }

          } else if (status === 'active' && card) {
            // ── Restore card if it was previously marked inactive ──────────
            card.classList.remove('not-applicable');
            card.style.pointerEvents = '';
            card.style.opacity = '';
            const badge = card.querySelector('.inactive-badge');
            if (badge) badge.remove();
          }
        }
      } catch (_) {
        // Silent fail — poller is best-effort
      }
    }

    // Poll immediately on load, then every 8 seconds
    pollStatuses();
    setInterval(pollStatuses, 8000);
  })();

  // ── Stock + Block poller ──────────────────────────────────────────────────
  // Tracks productIds with blocking issues to gate the Place Order button
  const checkoutBlockingIds = new Set();

  function updatePlaceOrderBtn() {
    const btn     = document.getElementById('placeOrderBtn');
    const msg     = document.getElementById('cartIssueMsg');
    if (!btn) return;
    if (checkoutBlockingIds.size > 0) {
      btn.disabled     = true;
      btn.classList.replace('btn-danger', 'btn-secondary');
      if (msg) msg.style.display = '';
    } else {
      btn.disabled     = false;
      btn.classList.replace('btn-secondary', 'btn-danger');
      if (msg) msg.style.display = 'none';
    }
  }

  // Product map: id → row element in the order summary
  // Each order-item-row has a data-product-id we'll add below via EJS
  async function syncCheckoutStock() {
    try {
      const res  = await fetch('/cart/stock-sync');
      const data = await res.json();
      if (!data.ok || !data.items) return;

      const newlyBlocked  = [];
      const newlyPremium  = [];
      const newlyOOS      = [];
      const qtyReduced    = [];

      data.items.forEach(item => {
        const row = document.querySelector(`.order-item-row[data-product-id="${item.productId}"]`);
        if (!row) return;

        const nameEl = row.querySelector('.small.fw-semibold');
        const productName = nameEl?.textContent?.trim() || 'A product';

        // ── Blocked ───────────────────────────────────────────────────────
        // ── Blocked ───────────────────────────────────────────────────────
        if (item.blocked) {
          checkoutBlockingIds.add(item.productId);
          if (!row.querySelector('.co-blocked-badge')) {
            const badge = document.createElement('span');
            badge.className = 'co-blocked-badge badge bg-danger ms-1';
            badge.innerHTML = '<i class="fas fa-ban me-1"></i>Blocked';
            nameEl?.after(badge);
            row.style.opacity = '0.55';
            newlyBlocked.push(productName);
          }
        } else {
          const b = row.querySelector('.co-blocked-badge');
          if (b) { b.remove(); row.style.opacity = ''; }
          if (!item.outOfstock) checkoutBlockingIds.delete(item.productId);
        }

        // ── Premium locked (product became premium, user is not premium) ───
        if (item.isPremiumLocked) {
          checkoutBlockingIds.add(item.productId);
          if (!row.querySelector('.co-premium-badge')) {
            const badge = document.createElement('span');
            badge.className = 'co-premium-badge badge bg-warning text-dark ms-1';
            badge.innerHTML = '<i class="fas fa-crown me-1"></i>Premium Only';
            nameEl?.after(badge);
            row.style.opacity = '0.55';
            newlyPremium.push(productName);
          }
        } else {
          // Only clear premium badge and unblock if truly no longer premium-locked
          const b = row.querySelector('.co-premium-badge');
          if (b) {
            b.remove();
            // Only restore opacity if also not blocked/OOS
            if (!item.blocked && !item.outOfstock) row.style.opacity = '';
          }
          // Remove from blocking set ONLY if no other issues remain
          if (!item.blocked && !item.outOfstock) {
            checkoutBlockingIds.delete(item.productId);
          }
        }
        // ─────────────────────────────────────────────────────────────────────
        // ────────────────────────────────────────────────────────────────

        // ── Out of stock ──────────────────────────────────────────────────
        if (item.outOfstock) {
          checkoutBlockingIds.add(item.productId);
          if (!row.querySelector('.co-oos-badge')) {
            const badge = document.createElement('span');
            badge.className = 'co-oos-badge badge bg-secondary ms-1';
            badge.textContent = 'Out of Stock';
            nameEl?.after(badge);
            newlyOOS.push(productName);
          }
        } else {
          const b = row.querySelector('.co-oos-badge');
          if (b) b.remove();
          if (!item.blocked) checkoutBlockingIds.delete(item.productId);
        }

        // ── Qty reduced ───────────────────────────────────────────────────
        // ── Qty reduced ───────────────────────────────────────────────────────────
if (item.reduced) {
  qtyReduced.push(productName);
  row.dataset.currentQty = item.quantity;

  // Update qty display — works for both offer and non-offer rows
  const qtyEl = row.querySelector('[data-qty-display]');
  if (qtyEl) {
    const priceArea = row.querySelector('[data-price-area]');
    const isOffer   = priceArea && !priceArea.classList.contains('text-white-50');
    qtyEl.textContent = isOffer ? ` × ${item.quantity}` : item.quantity;
  }

  // Update line total display for this row
  const effectivePrice = parseFloat(row.dataset.effectivePrice) || item.price || 0;
  const newLineTotal   = +(effectivePrice * item.quantity).toFixed(2);
  const lineTotalEl    = row.querySelector('.text-danger.fw-bold.small');
  if (lineTotalEl) lineTotalEl.textContent = `$${newLineTotal.toFixed(2)}`;

  // Recalculate subtotal from all current row line totals
  let newSubtotal = 0;
  document.querySelectorAll('.order-item-row').forEach(r => {
    const ltEl = r.querySelector('.text-danger.fw-bold.small');
    if (ltEl) newSubtotal += parseFloat(ltEl.textContent.replace('$', '')) || 0;
  });
  newSubtotal = +newSubtotal.toFixed(2);

  // Recalculate shipping based on new subtotal
  const newShipping = newSubtotal >= FREE_SHIPPING_THRESHOLD ? 0 : SHIPPING_FEE_AMOUNT;

  // Update the mutable base variables so coupon/wallet logic stays correct
  BASE_SUBTOTAL = newSubtotal;
  BASE_SHIPPING = newShipping;
  BASE_TOTAL    = +(newSubtotal + newShipping).toFixed(2);

  // Update subtotal display in the summary
  const subtotalEl = document.querySelector('.d-flex.justify-content-between.text-white-50.small span:last-child');
  // More reliable: query by sibling text content
  document.querySelectorAll('.d-flex.justify-content-between.text-white-50.small').forEach(row => {
    const label = row.querySelector('span:first-child');
    const val   = row.querySelector('span:last-child');
    if (!label || !val) return;
    if (label.textContent.trim() === 'Subtotal') {
      val.textContent = `$${newSubtotal.toFixed(2)}`;
    }
    if (label.textContent.trim() === 'Shipping') {
      val.textContent = newShipping === 0 ? 'FREE' : `$${newShipping.toFixed(2)}`;
    }
  });

  // Re-render grand total (respects any active coupon discount)
  updateTotal();
}
      });

      updatePlaceOrderBtn();

      // Toasts
      if (newlyBlocked.length) {
        showToast(`<i class="fas fa-ban me-1"></i> <strong>${newlyBlocked.join(', ')}</strong> has been blocked by the store. Go back to cart to remove it.`, 'danger');
      }
      if (newlyPremium.length) {
        showToast(`<i class="fas fa-crown me-1"></i> <strong>${newlyPremium.join(', ')}</strong> became a Premium product. Go back to cart to remove it, or upgrade your membership.`, 'warning');
      }
      if (newlyOOS.length) {
        showToast(`<i class="fas fa-box-open me-1"></i> <strong>${newlyOOS.join(', ')}</strong> just went out of stock. Go back to cart to remove it.`, 'danger');
      }
      if (qtyReduced.length) {
        showToast(`<i class="fas fa-exclamation-triangle me-1"></i> Quantity for <strong>${qtyReduced.join(', ')}</strong> was reduced to match available stock.`, 'warning');
      }

    } catch (_) { /* silent fail */ }
  }

  // ── Offer poller ──────────────────────────────────────────────────────────
  async function syncCheckoutOffers() {
    try {
      const res  = await fetch('/cart/offer-prices');
      const data = await res.json();
      if (!data.ok || !data.items?.length) return;

      const addedOffers   = [];
      const removedOffers = [];
      const changedOffers = [];

      data.items.forEach(item => {
        const row = document.querySelector(`.order-item-row[data-product-id="${item.productId}"]`);
        if (!row) return;

        const nameEl      = row.querySelector('.small.fw-semibold');
        const productName = nameEl?.textContent?.trim() || 'A product';
        const lineTotalEl = row.querySelector('.text-danger.fw-bold.small');
        const priceArea   = row.querySelector('div[style*="font-size:.75rem"]');

        // Detect offer state — check if offer badge exists
        const hadOffer    = !!row.querySelector('.badge[style*="background"]');
        const nowHasOffer = item.hasOffer;

        if (!hadOffer && nowHasOffer)      addedOffers.push(productName);
        else if (hadOffer && !nowHasOffer) removedOffers.push(productName);
        else if (hadOffer && Math.abs(item.effectivePrice - (parseFloat(row.dataset.effectivePrice) || item.effectivePrice)) > 0.001) {
          changedOffers.push(productName);
        }

        // Update stored effective price
        row.dataset.effectivePrice = item.effectivePrice;

        // Update line total
        if (lineTotalEl) {
          lineTotalEl.textContent = `$${item.lineTotal.toFixed(2)}`;
        }

        // Update price area display — preserve stock-corrected qty if available
        const displayQty = row.dataset.currentQty ?? item.quantity;
        if (priceArea && nowHasOffer) {
          priceArea.innerHTML = `
            <span class="text-white-50 text-decoration-line-through me-1">$${Number(item.originalPrice).toFixed(2)}</span>
            <span class="text-success fw-bold">$${item.effectivePrice.toFixed(2)}</span>
            <span class="text-white-50" data-qty-display> × ${displayQty}</span>`;
        } else if (priceArea && !nowHasOffer) {
          priceArea.innerHTML = `<span class="text-white-50">Qty: <span data-qty-display>${displayQty}</span> × $${Number(item.originalPrice).toFixed(2)}</span>`;
        }
      });

      // ── Recalculate and push all summary totals ──────────────────────────
      // Only run if any offer actually changed — avoids unnecessary DOM churn
      if (addedOffers.length || removedOffers.length || changedOffers.length) {

        // 1. Sum line totals from the live DOM (already updated above per-row)
        let newSubtotal = 0;
        let newOfferSavings = 0;
        document.querySelectorAll('.order-item-row').forEach(r => {
          const ltEl = r.querySelector('.text-danger.fw-bold.small');
          if (ltEl) newSubtotal += parseFloat(ltEl.textContent.replace('$', '')) || 0;

          // Offer savings = original price × qty  minus  effective price × qty
          const origPriceEl = r.querySelector('.text-white-50.text-decoration-line-through');
          const effPriceEl  = r.querySelector('.text-success.fw-bold');
          const qtyEl       = r.querySelector('[data-qty-display]');
          if (origPriceEl && effPriceEl && qtyEl) {
            const orig = parseFloat(origPriceEl.textContent.replace('$', '')) || 0;
            const eff  = parseFloat(effPriceEl.textContent.replace('$', ''))  || 0;
            const qty  = parseInt(qtyEl.textContent.replace('×', '').trim())  || 0;
            newOfferSavings += (orig - eff) * qty;
          }
        });
        newSubtotal     = +newSubtotal.toFixed(2);
        newOfferSavings = +newOfferSavings.toFixed(2);

        // 2. Recalculate shipping
        const newShipping = newSubtotal >= FREE_SHIPPING_THRESHOLD ? 0 : SHIPPING_FEE_AMOUNT;

        // 3. Update the mutable base vars so updateTotal() + wallet check stay correct
        BASE_SUBTOTAL = newSubtotal;
        BASE_SHIPPING = newShipping;
        BASE_TOTAL    = +(newSubtotal + newShipping).toFixed(2);

        // 4. Update Subtotal and Shipping spans
        document.querySelectorAll('.d-flex.justify-content-between.text-white-50.small').forEach(rowEl => {
          const label = rowEl.querySelector('span:first-child');
          const val   = rowEl.querySelector('span:last-child');
          if (!label || !val) return;
          if (label.textContent.trim() === 'Subtotal') val.textContent = `$${newSubtotal.toFixed(2)}`;
          if (label.textContent.trim() === 'Shipping')  val.textContent = newShipping === 0 ? 'FREE' : `$${newShipping.toFixed(2)}`;
        });

        // 5. Update Offer Savings row (show/hide + amount)
        const savingsRow = document.getElementById('offerSavingsRow');
        const savingsAmt = document.getElementById('offerSavingsAmt');
        if (savingsRow && savingsAmt) {
          if (newOfferSavings > 0) {
            savingsAmt.textContent = `- $${newOfferSavings.toFixed(2)}`;
            savingsRow.style.display = '';
          } else {
            savingsRow.style.display = 'none';
          }
        }

        // 6. Re-render grand total (honours any active coupon discount)
        updateTotal();
      }

      if (addedOffers.length)   showToast(`<i class="fas fa-tag me-1"></i> New offer on <strong>${addedOffers.join(', ')}</strong> — total updated!`, 'success');
      if (removedOffers.length) showToast(`<i class="fas fa-exclamation-triangle me-1"></i> Offer on <strong>${removedOffers.join(', ')}</strong> has ended — total updated.`, 'warning');
      if (changedOffers.length) showToast(`<i class="fas fa-info-circle me-1"></i> Offer price changed for <strong>${changedOffers.join(', ')}</strong> — total updated.`, 'warning');

    } catch (_) { /* silent fail */ }
  }

  // Run both immediately and on interval
  syncCheckoutStock();
  syncCheckoutOffers();
  const stockPollInterval = setInterval(syncCheckoutStock, 8000);
  const offerPollInterval = setInterval(syncCheckoutOffers, 30000);

  // Pause when tab hidden
  document.addEventListener('visibilitychange', () => {
    if (!document.hidden) {
      syncCheckoutStock();
      syncCheckoutOffers();
    }
  });

  // ── Payment method toggle ─────────────────────────────────────────────────
  function selectMethod(method) {
    document.getElementById('payMethodInput').value = method;
    document.querySelectorAll('.payment-opt').forEach(el => el.classList.remove('selected'));
    const map = { online: 'opt-online', wallet: 'opt-wallet', cod: 'opt-cod' };
    document.getElementById(map[method]).classList.add('selected');
  }

  // ── Form submit ───────────────────────────────────────────────────────────
  document.getElementById('checkoutForm').addEventListener('submit', async (e) => {
    e.preventDefault();

    const btn       = document.getElementById('placeOrderBtn');
    const txtSpan   = document.getElementById('btnText');
    const spinSpan  = document.getElementById('btnSpinner');
    const payMethod = document.getElementById('payMethodInput').value;
    const addressId = document.querySelector('input[name="addressId"]:checked')?.value;

    // ── Address validation → inline error ────────────────────────────────────
    if (!addressId) {
      showCheckoutError('Please select a shipping address before placing your order.');
      return;
    }

    // ── Wallet balance check → inline error ──────────────────────────────────
    if (payMethod === 'wallet') {
      const currentTotal = Math.max(0, BASE_SUBTOTAL + BASE_SHIPPING - appliedDiscount);
      if (WALLET_BALANCE < currentTotal) {
        showCheckoutError(
          `Insufficient Comizon Pay balance. ` +
          `Your balance: $${WALLET_BALANCE.toFixed(2)} — ` +
          `Order total: $${currentTotal.toFixed(2)}. ` +
          `Please top up your wallet first.`
        );
        return;
      }
    }

    btn.disabled = true;
    txtSpan.classList.add('d-none');
    spinSpan.classList.remove('d-none');

    const payload = {
      addressId,
      paymentMethod: payMethod,
      couponCode:    appliedCode,
    };

    try {
      // ── COD ──────────────────────────────────────────────────────────────
      if (payMethod === 'cod') {
        const res    = await fetch('/checkout/place-order', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify(payload),
        });
        const result = await res.json();
        if (result.success) {
          window.location.href = result.redirectUrl;
        } else {
          throw new Error(result.message || 'Failed to place COD order');
        }
        return;
      }

      // ── WALLET ───────────────────────────────────────────────────────────
      if (payMethod === 'wallet') {
        const res    = await fetch('/checkout/place-order', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify(payload),
        });
        const result = await res.json();
        if (result.success) {
          window.location.href = result.redirectUrl;
        } else {
          throw new Error(result.message || 'Wallet payment failed');
        }
        return;
      }

      // ── ONLINE (Razorpay) ─────────────────────────────────────────────
      const rzpRes = await fetch('/checkout/place-order', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(payload),   // payload already contains couponCode
      });

      if (!rzpRes.ok) throw new Error('Order preparation failed');
      const rzpData = await rzpRes.json();
      if (!rzpData.pendingOrder) throw new Error(rzpData.message || 'Order preparation failed');

      const options = {
        key:         rzpData.key,
        amount:      rzpData.amount,          // ← this is now the discounted amount in paise
        currency:    rzpData.currency,
        name:        'Comizon',
        description: appliedCode ? `Order (Coupon: ${appliedCode})` : 'Online Payment',
        order_id:    rzpData.razorpayOrderId,
        handler: async function (response) {
          const verifyRes = await fetch('/checkout/razorpay/verify', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({
              razorpay_order_id:   response.razorpay_order_id,
              razorpay_payment_id: response.razorpay_payment_id,
              razorpay_signature:  response.razorpay_signature,
              addressId,
            }),
          });
          const verifyJson = await verifyRes.json();
          if (verifyJson.success) {
            window.location.href = verifyJson.redirectUrl;
          } else {
            showToast('Payment verification failed. Please contact support.');
          }
        },
        prefill: {
          name:    "<%= user.firstName %>",
          email:   "<%= user.email %>",
          contact: "<%= user.phone %>",
        },
        theme: { color: '#E63946' },
        modal: {
          ondismiss: function () {
            btn.disabled = false;
            txtSpan.classList.remove('d-none');
            spinSpan.classList.add('d-none');
          },
        },
      };

      const rzp = new Razorpay(options);
      rzp.on('payment.failed', function (response) {
    
          const reason = response.error.description || "Payment failed";
          window.location.href = `/checkout/payment-failed?reason=${encodeURIComponent(reason)}`;
      });
      rzp.open();

    } catch (err) {
      console.error(err);
      showCheckoutError(err.message || 'Something went wrong. Please try again.');
      btn.disabled = false;
      txtSpan.classList.remove('d-none');
      spinSpan.classList.add('d-none');
    }
  });

  // ── Inline error helper ────────────────────────────────────────────────────
  function showCheckoutError(msg) {
    let el = document.getElementById('checkoutInlineError');
    if (!el) {
      el = document.createElement('div');
      el.id = 'checkoutInlineError';
      el.className = 'alert alert-danger rounded-0 border-0 border-start border-4 border-danger mb-3';
      // Insert before the Place Order button
      const btn = document.getElementById('placeOrderBtn');
      btn.parentNode.insertBefore(el, btn);
    }
    el.innerHTML = `<i class="fas fa-exclamation-circle me-2"></i>${msg}`;
    el.scrollIntoView({ behavior: 'smooth', block: 'center' });
    // Auto-hide after 6 seconds
    clearTimeout(el._hideTimer);
    el._hideTimer = setTimeout(() => el.remove(), 6000);
  }
  </script>
</body>
</html>
