                    <div class="flex-grow-1">
                      <div class="small fw-semibold"><%= item.name %></div>
                     <% if (item.hasOffer) { %>
                        <div style="font-size:.75rem;" data-price-area>
                          <span class="text-white-50 text-decoration-line-through me-1">$<%= item.price.toFixed(2) %></span>
                          <span class="text-success fw-bold">$<%= item.effectivePrice.toFixed(2) %></span>
                          <span class="text-white-50" data-qty-display> × <%= item.quantity %></span>
                        </div>
                        <% if (item.offerBadge) { %><span class="badge rounded-0 text-white" style="font-size:.6rem;background:<%= item.badgeColor || '#E63946' %>;"><%= item.offerBadge %></span><% } %>
                      <% } else { %>
                        <div class="text-white-50" style="font-size:.75rem;" data-price-area>Qty: <span data-qty-display><%= item.quantity %></span> × $<%= item.price.toFixed(2) %></div>
