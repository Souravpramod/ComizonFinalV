<%- include('../partials/user-head', { title: 'Checkout' }) %>

<body class="bg-black text-light">
  <%- include('../partials/header') %>

  <style>
    .checkout-wrap { margin-top: 90px; padding: 2rem 0 4rem; }
    .section-box { background:#1A1A1A; border:1px solid #333; padding:1.5rem; margin-bottom:1.5rem; }
    .section-title { font-size:.75rem; text-transform:uppercase; letter-spacing:1.5px; color:#E63946; font-weight:700; margin-bottom:1.2rem; border-left:3px solid #E63946; padding-left:.6rem; }
    .address-card { border:2px solid #333; background:#111; padding:1rem; border-radius:0; cursor:pointer; transition:border-color .2s; }
    .address-card.selected, .address-card:hover { border-color:#E63946; }
    .address-card input[type=radio] { accent-color:#E63946; }
    .addr-badge { font-size:.65rem; background:#E63946; color:#fff; padding:2px 6px; text-transform:uppercase; font-weight:700; }
    .summary-sticky { position:sticky; top:100px; }
    .coupon-card { border:1px dashed #444; background:#111; padding:.9rem 1rem; cursor:pointer; transition:border-color .2s; }
    .coupon-card:hover { border-color:#E63946; }
    .coupon-card.not-applicable { opacity:.5; cursor:default; }
    .coupon-card.applied { border-color:#28a745; border-style:solid; }
    .coupon-badge { font-size:.7rem; background:#222; border:1px solid #555; color:#FFD700; padding:3px 8px; font-family:monospace; font-weight:700; letter-spacing:1px; }
    .order-item-row { border-bottom:1px solid #2a2a2a; padding:.6rem 0; }
    .order-item-row:last-child { border-bottom:none; }
    .payment-opt { border:2px solid #333; background:#111; padding:.9rem 1.2rem; cursor:pointer; transition:border-color .2s; }
    .payment-opt.selected, .payment-opt:hover { border-color:#E63946; }
    .payment-opt input[type=radio] { accent-color:#E63946; }
    #place-order-loading { display:none; position:fixed; inset:0; background:rgba(0,0,0,.75); z-index:9999; align-items:center; justify-content:center; flex-direction:column; gap:1rem; }
    #place-order-loading.show { display:flex; }
    .pay-tab { background:#111; border:2px solid #333; color:#fff; padding:.4rem 1rem; font-size:.8rem; font-weight:600; transition:all .2s; cursor:pointer; }
    .pay-tab.active { border-color:#E63946; color:#E63946; }
    .pay-tab:hover { border-color:#E63946; }
    .eligibility-badge { font-size:.6rem; padding:2px 5px; border-radius:2px; font-weight:700; text-transform:uppercase; }

    /* ── Wallet option specific ── */
    .wallet-balance-chip {
      font-size:.72rem; background:rgba(40,167,69,.12);
      border:1px solid rgba(40,167,69,.3); color:#28a745;
      padding:2px 8px; font-weight:700;
    }
    .wallet-insufficient {
      font-size:.72rem; background:rgba(230,57,70,.1);
      border:1px solid rgba(230,57,70,.3); color:#E63946;
      padding:2px 8px; font-weight:700;
    }
  </style>

  <div id="place-order-loading">
    <div class="spinner-border text-danger" style="width:3rem;height:3rem;"></div>
    <p class="text-white fw-bold">Placing your order…</p>
  </div>

  <div class="container checkout-wrap">

    <% if (locals.error) { %>
      <div class="alert alert-danger alert-dismissible rounded-0 fade show border-0 border-start border-4 border-danger mb-4">
        <i class="fas fa-exclamation-circle me-2"></i><%= error %>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <div class="d-flex align-items-center gap-3 mb-4">
      <a href="/cart" class="text-white-50 text-decoration-none small">
        <i class="fas fa-arrow-left me-1"></i>Back to Cart
      </a>
      <h2 class="mb-0 fw-bold text-uppercase border-start border-3 border-danger ps-3">Checkout</h2>
    </div>

    <form action="/checkout/place-order" method="POST" id="checkoutForm">
      <!-- hidden fields populated by JS when coupon is applied -->
      <input type="hidden" name="couponCode"  id="appliedCouponCode"  value="">
      <input type="hidden" name="discountAmt" id="appliedDiscountAmt" value="0">

      <div class="row g-4">

        <!-- LEFT COLUMN -->
        <div class="col-lg-7">

          <!-- ① DELIVERY ADDRESS -->
          <div class="section-box">
            <div class="section-title"><i class="fas fa-map-marker-alt me-2"></i>Delivery Address</div>

            <% if (!addresses || addresses.length === 0) { %>
              <p class="text-white-50 small mb-3">No saved addresses. Add one below.</p>
            <% } %>

            <div class="row g-2 mb-3">
              <% (addresses || []).forEach((addr, idx) => { %>
                <div class="col-md-6">
                  <label class="address-card d-block w-100 <%= (defaultAddress && defaultAddress._id && addr._id && defaultAddress._id.toString() === addr._id.toString()) ? 'selected' : '' %>">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                      <div class="d-flex align-items-center gap-2">
                        <input type="radio" name="addressId" value="<%= addr._id %>"
                          <%= (defaultAddress && defaultAddress._id && addr._id && defaultAddress._id.toString() === addr._id.toString()) ? 'checked' : '' %>
                          onchange="document.querySelectorAll('.address-card').forEach(c=>c.classList.remove('selected'));this.closest('.address-card').classList.add('selected')">
                        <span class="addr-badge"><%= addr.type || 'home' %></span>
                      </div>
                      <% if (addr.isDefault) { %>
                        <span class="text-warning small"><i class="fas fa-star me-1"></i>Default</span>
                      <% } %>
                    </div>
                    <p class="mb-0 small fw-semibold"><%= addr.addressLane1 %></p>
                    <% if (addr.addressLane2) { %><p class="mb-0 small text-white-50"><%= addr.addressLane2 %></p><% } %>
                    <p class="mb-0 small text-white-50"><%= addr.city %><% if (addr.state) { %>, <%= addr.state %><% } %></p>
                    <p class="mb-0 small text-white-50"><%= addr.pincode %> <%= addr.country %></p>
                  </label>
                </div>
              <% }) %>
            </div>

            <button type="button" class="btn btn-outline-secondary btn-sm rounded-0"
                    data-bs-toggle="modal" data-bs-target="#checkoutAddAddrModal">
              <i class="fas fa-plus me-1"></i>Add New Address
            </button>
          </div><!-- close section-box -->

          <!-- ── Inline Add Address Modal ─────────────────────────────────── -->
          <div class="modal fade" id="checkoutAddAddrModal" tabindex="-1">
            <div class="modal-dialog modal-lg">
              <div class="modal-content bg-dark text-light border-secondary rounded-0">
                <div class="modal-header border-secondary">
                  <h5 class="modal-title fw-bold text-danger"><i class="fas fa-map-marker-alt me-2"></i>Add New Address</h5>
                  <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                  <div id="addrModalErr" class="alert alert-danger rounded-0 d-none small"></div>
                  <div id="addrModalOk"  class="alert alert-success rounded-0 d-none small"></div>
                  <div class="row g-3">
                    <div class="col-md-6">
                      <label class="form-label small text-white-50">Type</label>
                      <select id="ca_type" class="form-select bg-black border-secondary text-white rounded-0">
                        <option value="home">Home</option>
                        <option value="work">Work</option>
                        <option value="other">Other</option>
                      </select>
                    </div>
                    <div class="col-md-6">
                      <label class="form-label small text-white-50">Address Line 1 *</label>
                      <input type="text" id="ca_lane1" class="form-control bg-black border-secondary text-white rounded-0">
                    </div>
                    <div class="col-md-6">
                      <label class="form-label small text-white-50">Address Line 2</label>
                      <input type="text" id="ca_lane2" class="form-control bg-black border-secondary text-white rounded-0">
                    </div>
                    <div class="col-md-6">
                      <label class="form-label small text-white-50">City *</label>
                      <input type="text" id="ca_city" class="form-control bg-black border-secondary text-white rounded-0">
                    </div>
                    <div class="col-md-4">
                      <label class="form-label small text-white-50">State</label>
                      <input type="text" id="ca_state" class="form-control bg-black border-secondary text-white rounded-0">
                    </div>
                    <div class="col-md-4">
                      <label class="form-label small text-white-50">Pincode *</label>
                      <input type="text" id="ca_pincode" class="form-control bg-black border-secondary text-white rounded-0">
                    </div>
                    <div class="col-md-4">
                      <label class="form-label small text-white-50">Country *</label>
                      <input type="text" id="ca_country" class="form-control bg-black border-secondary text-white rounded-0">
                    </div>
                  </div>
                </div>
                <div class="modal-footer border-secondary">
                  <button type="button" class="btn btn-outline-secondary rounded-0" data-bs-dismiss="modal">Cancel</button>
                  <button type="button" class="btn btn-danger rounded-0 fw-bold" id="saveAddrInlineBtn">
                    <i class="fas fa-save me-2"></i>Save &amp; Select
                  </button>
                </div>
              </div>
            </div>
          </div>
          <script>
          // ── Live field validation for checkout address modal ──────────────
          function caFieldError(id, value) {
            const v = (value || '').trim();
            if (id === 'ca_lane1') return v.length < 5 ? 'At least 5 characters required.' : '';
            if (id === 'ca_city')  {
              if (!v) return 'City is required.';
              if (!/^[a-zA-Z\s\-'.]+$/.test(v)) return 'Letters only.';
              return '';
            }
            if (id === 'ca_state')   return (v && !/^[a-zA-Z\s\-'.]+$/.test(v)) ? 'Letters only.' : '';
            if (id === 'ca_country') return !v ? 'Country is required.' : (!/^[a-zA-Z\s\-'.]+$/.test(v) ? 'Letters only.' : '');
            if (id === 'ca_pincode') return !v ? 'Pincode is required.' : '';
            return '';
          }

          function caSetState(id, msg) {
            const input = document.getElementById(id);
            if (!input) return;
            let errEl = input.parentElement.querySelector('.ca-live-err');
            if (!errEl) {
              errEl = document.createElement('div');
              errEl.className = 'ca-live-err text-danger small mt-1';
              input.parentElement.appendChild(errEl);
            }
            if (msg) {
              errEl.innerHTML = `<i class="fas fa-exclamation-circle me-1"></i>${msg}`;
              input.classList.add('border-danger');
            } else {
              errEl.innerHTML = '';
              input.classList.remove('border-danger');
              input.classList.add('border-success');
            }
          }

          // Wire live blur/input validation on modal fields
          ['ca_lane1','ca_city','ca_state','ca_country'].forEach(id => {
            const el = document.getElementById(id);
            if (!el) return;
            ['blur','input'].forEach(evt => {
              el.addEventListener(evt, () => caSetState(id, caFieldError(id, el.value)));
            });
          });

          // Async pincode check
          let _caPinTimer;
          const caPinEl  = document.getElementById('ca_pincode');
          const caCtryEl = document.getElementById('ca_country');
          let caPinValid = null;

          async function caPincodeCheck() {
            const pin  = caPinEl.value.trim();
            const ctry = caCtryEl.value.trim();
            if (!pin)  { caSetState('ca_pincode', 'Pincode is required.'); caPinValid = false; return; }
            if (!ctry) { caSetState('ca_pincode', ''); caPinValid = null; return; }
            let errEl = caPinEl.parentElement.querySelector('.ca-live-err');
            if (!errEl) { errEl = document.createElement('div'); errEl.className='ca-live-err text-danger small mt-1'; caPinEl.parentElement.appendChild(errEl); }
            errEl.innerHTML = '<span style="color:#aaa;font-size:.75rem;"><i class="fas fa-spinner fa-spin me-1"></i>Validating…</span>';
            caPinEl.classList.remove('border-danger','border-success');
            try {
              const res  = await fetch(`/profile/address/validate-pincode?pincode=${encodeURIComponent(pin)}&country=${encodeURIComponent(ctry)}`);
              const data = await res.json();
              caPinValid = data.valid;
              if (data.valid) {
                errEl.innerHTML = '<span style="color:#28a745;font-size:.75rem;"><i class="fas fa-check-circle me-1"></i>Valid postal code.</span>';
                caPinEl.classList.add('border-success');
              } else {
                errEl.innerHTML = `<span style="color:#ff4d4d;font-size:.75rem;"><i class="fas fa-exclamation-circle me-1"></i>${data.message}</span>`;
                caPinEl.classList.add('border-danger');
              }
            } catch (_) { caPinValid = null; errEl.innerHTML = ''; }
          }

          if (caPinEl) {
            caPinEl.addEventListener('blur', caPincodeCheck);
            caCtryEl?.addEventListener('blur', () => { if (caPinEl.value.trim()) caPincodeCheck(); });
          }

          document.getElementById('saveAddrInlineBtn').addEventListener('click', async function() {
            const err = document.getElementById('addrModalErr');
            const ok  = document.getElementById('addrModalOk');
            err.classList.add('d-none'); ok.classList.add('d-none');

            // Run all field validations first
            const fields = ['ca_lane1','ca_city','ca_state','ca_country','ca_pincode'];
            let hasError = false;
            fields.forEach(id => {
              const msg = caFieldError(id, document.getElementById(id)?.value || '');
              if (msg) { caSetState(id, msg); hasError = true; }
            });
            if (hasError) return;

            const lane1 = document.getElementById('ca_lane1').value.trim();
            const city  = document.getElementById('ca_city').value.trim();
            const pin   = document.getElementById('ca_pincode').value.trim();
            const ctry  = document.getElementById('ca_country').value.trim();
            this.disabled = true; this.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Validating…';
            // Live pincode check before saving
            try {
              const vRes  = await fetch(`/profile/address/validate-pincode?pincode=${encodeURIComponent(pin)}&country=${encodeURIComponent(ctry)}`);
              const vData = await vRes.json();
              if (!vData.valid) {
                err.textContent = vData.message;
                err.classList.remove('d-none');
                this.disabled = false;
                this.innerHTML = '<i class="fas fa-save me-2"></i>Save &amp; Select';
                return;
              }
            } catch (_) { /* fail open — continue saving */ }
            this.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Saving…';
            try {
              const res  = await fetch('/profile/address/add-ajax', { method: 'POST', headers: {'Content-Type':'application/json'},
                body: JSON.stringify({ type: document.getElementById('ca_type').value.trim() || 'home', addressLane1: lane1,
                  addressLane2: document.getElementById('ca_lane2').value.trim(), city, state: document.getElementById('ca_state').value.trim(), pincode: pin, country: ctry }) });
              const data = await res.json();
              if (!data.ok) throw new Error(data.message);
              const a = data.address;
              document.querySelectorAll('.address-card').forEach(c => c.classList.remove('selected'));
              document.querySelectorAll('input[name="addressId"]').forEach(r => r.checked = false);
              const grid = document.querySelector('.row.g-2.mb-3');
              const col  = document.createElement('div'); col.className = 'col-md-6';
              col.innerHTML = `<label class="address-card d-block w-100 selected">
                <div class="d-flex align-items-center gap-2 mb-2">
                  <input type="radio" name="addressId" value="${a._id}" checked
                    onchange="document.querySelectorAll('.address-card').forEach(c=>c.classList.remove('selected'));this.closest('.address-card').classList.add('selected')">
                  <span class="addr-badge">${a.type||'home'}</span>
                </div>
                <p class="mb-0 small fw-semibold">${a.addressLane1}</p>
                ${a.addressLane2?`<p class="mb-0 small text-white-50">${a.addressLane2}</p>`:''}
                <p class="mb-0 small text-white-50">${a.city}${a.state?', '+a.state:''}</p>
                <p class="mb-0 small text-white-50">${a.pincode} ${a.country}</p></label>`;
              grid.appendChild(col);
              ok.textContent = 'Address saved and selected!'; ok.classList.remove('d-none');
              setTimeout(() => bootstrap.Modal.getInstance(document.getElementById('checkoutAddAddrModal'))?.hide(), 1000);
            } catch(e) { err.textContent = e.message; err.classList.remove('d-none'); }
            finally { this.disabled=false; this.innerHTML='<i class="fas fa-save me-2"></i>Save &amp; Select'; }
          });
          </script>

          <!-- ② COUPONS -->
          <div class="section-box">
            <div class="section-title"><i class="fas fa-tag me-2"></i>Coupons &amp; Offers</div>

            <!-- Manual entry -->
            <div class="input-group mb-2">
              <input type="text" id="couponInput"
                     class="form-control bg-black border-secondary text-white rounded-0"
                     placeholder="Enter coupon code"
                     style="text-transform:uppercase;">
              <button type="button" class="btn btn-outline-danger rounded-0 px-4 fw-bold"
                      id="couponApplyBtn" onclick="handleCouponApply()">APPLY</button>
            </div>
            <div id="couponMsg" class="small mb-3"></div>

            <!-- Available coupons -->
            <% if (availableCoupons && availableCoupons.length > 0) { %>
              <div class="d-flex justify-content-between align-items-center mb-2">
                <p class="text-white-50 small mb-0">Available for you:</p>
                <span class="text-white-50 small" id="couponPageInfo"></span>
              </div>
              <div class="row g-2" id="couponGrid"></div>
              <!-- Pagination controls -->
              <div class="d-flex justify-content-center align-items-center gap-2 mt-3" id="couponPagination"></div>
            <% } else { %>
              <p class="text-white-50 small">No coupons available right now.</p>
            <% } %>

            <script>
            (function() {
              const COUPONS_PER_PAGE = 4;
              const coupons = <%- JSON.stringify(availableCoupons) %>;
              const subtotal = <%= subtotal %>;
              let currentPage = 1;
              const totalPages = Math.ceil(coupons.length / COUPONS_PER_PAGE);

              function renderCoupons(page) {
                currentPage = page;
                const grid = document.getElementById('couponGrid');
                const info = document.getElementById('couponPageInfo');
                const start = (page - 1) * COUPONS_PER_PAGE;
                const slice = coupons.slice(start, start + COUPONS_PER_PAGE);

                grid.innerHTML = slice.map(c => {
                  const discountLabel = c.discountLabel || '';
                  const description   = c.description  || '';
                  const eligBadge = !c.applicable
                    ? `<span class="text-warning" style="font-size:.65rem;"><i class="fas fa-info-circle me-1"></i>Add $${(c.minOrderAmount - subtotal).toFixed(2)} more</span>`
                    : c.eligibility === 'new_user'
                      ? `<span class="eligibility-badge bg-info text-dark">New User</span>`
                      : c.eligibility === 'loyal'
                        ? `<span class="eligibility-badge bg-warning text-dark">Loyal Customer</span>`
                        : c.eligibility === 'bank'
                          ? `<span class="eligibility-badge bg-primary text-white">Bank Offer</span>`
                          : '';
                  const savingLine = c.applicable && c.saving > 0
                    ? `<p class="mb-0 text-success mt-1" style="font-size:.7rem;"><i class="fas fa-check-circle me-1"></i>You save $${c.saving.toFixed(2)}</p>`
                    : '';
                  return `
                    <div class="col-md-6">
                      <div class="coupon-card ${c.applicable ? '' : 'not-applicable'}"
                           id="ccard-${c.code}"
                           ${c.applicable ? `onclick="tapCoupon('${c.code}')"` : ''}>
                        <div class="d-flex justify-content-between align-items-start mb-1">
                          <span class="coupon-badge">${c.code}</span>
                          <span class="text-danger fw-bold small">${discountLabel}</span>
                        </div>
                        <p class="mb-1 text-white-50" style="font-size:.72rem;">${description}</p>
                        <div class="d-flex justify-content-between align-items-center">
                          <span class="text-white-50" style="font-size:.7rem;">Min. $${c.minOrderAmount}</span>
                          ${eligBadge}
                        </div>
                        ${savingLine}
                      </div>
                    </div>`;
                }).join('');

                // Page info
                const from = start + 1;
                const to   = Math.min(start + COUPONS_PER_PAGE, coupons.length);
                info.textContent = `${from}–${to} of ${coupons.length}`;

                renderPagination();
              }

              function renderPagination() {
                const nav = document.getElementById('couponPagination');
                if (totalPages <= 1) { nav.innerHTML = ''; return; }

                let html = `
                  <button class="btn btn-sm btn-outline-secondary rounded-0 px-2 py-1"
                          onclick="couponGoTo(${currentPage - 1})"
                          ${currentPage === 1 ? 'disabled' : ''}>
                    <i class="fas fa-chevron-left" style="font-size:.7rem;"></i>
                  </button>`;

                for (let i = 1; i <= totalPages; i++) {
                  html += `
                    <button class="btn btn-sm rounded-0 px-2 py-1 ${i === currentPage ? 'btn-danger' : 'btn-outline-secondary'}"
                            onclick="couponGoTo(${i})" style="font-size:.75rem; min-width:28px;">
                      ${i}
                    </button>`;
                }

                html += `
                  <button class="btn btn-sm btn-outline-secondary rounded-0 px-2 py-1"
                          onclick="couponGoTo(${currentPage + 1})"
                          ${currentPage === totalPages ? 'disabled' : ''}>
                    <i class="fas fa-chevron-right" style="font-size:.7rem;"></i>
                  </button>`;

                nav.innerHTML = html;
              }

              // Global so onclick attrs can reach it
              window.couponGoTo = function(page) {
                if (page < 1 || page > totalPages) return;
                renderCoupons(page);
              };

              // Re-highlight applied coupon card after page render
              const _origTapCoupon = window.tapCoupon;
              window.tapCoupon = function(code) {
                _origTapCoupon(code);
              };

              renderCoupons(1);
            })();
            </script>
          </div>

          <!-- ③ PAYMENT METHOD -->
          <div class="section-box">
            <div class="section-title"><i class="fas fa-credit-card me-2"></i>Payment Method</div>

            <div class="d-flex flex-column gap-2 mb-3">
              <input type="hidden" name="paymentMethod" value="online" id="payMethodInput">

              <!-- Online (Razorpay) -->
              <label class="payment-opt d-block selected" id="opt-online" onclick="selectMethod('online')">
                <div class="d-flex justify-content-between align-items-center">
                  <div>
                    <i class="fas fa-credit-card me-2 text-danger"></i>
                    <span class="fw-bold">Online Payment</span>
                    <div class="text-white-50" style="font-size:.72rem;">Card, UPI, Netbanking</div>
                  </div>
                  <i class="fas fa-chevron-right text-white-50"></i>
                </div>
              </label>

              <!-- Comizon Pay (Wallet) -->
              <label class="payment-opt d-block" id="opt-wallet" onclick="selectMethod('wallet')">
                <div class="d-flex justify-content-between align-items-center">
                  <div class="flex-grow-1">
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                      <i class="fas fa-wallet me-1 text-danger"></i>
                      <span class="fw-bold">Comizon Pay</span>
                      <!-- Balance chip — green if sufficient, red if not -->
                      <span id="walletChip"
                            class="<%= (walletBalance !== undefined && walletBalance >= total) ? 'wallet-balance-chip' : 'wallet-insufficient' %>">
                        $<%= (walletBalance !== undefined ? walletBalance : 0).toFixed(2) %> available
                      </span>
                    </div>
                    <div class="text-white-50 mt-1" style="font-size:.72rem;">
                      Instant deduction from your wallet. No OTP needed.
                    </div>
                    <!-- Insufficient funds warning -->
                    <% if (walletBalance !== undefined && walletBalance < total) { %>
                      <div class="mt-1" style="font-size:.7rem; color:#E63946;">
                        <i class="fas fa-exclamation-triangle me-1"></i>
                        Need $<%= (total - walletBalance).toFixed(2) %> more.
                        <a href="/wallet" class="text-danger fw-bold text-decoration-underline">Add money →</a>
                      </div>
                    <% } %>
                  </div>
                  <i class="fas fa-chevron-right text-white-50 ms-2"></i>
                </div>
              </label>

              <!-- COD -->
              <label class="payment-opt d-block" id="opt-cod" onclick="selectMethod('cod')">
                <div class="d-flex justify-content-between align-items-center">
                  <div>
                    <i class="fas fa-truck me-2 text-danger"></i>
                    <span class="fw-bold">Cash on Delivery</span>
                    <div class="text-white-50" style="font-size:.72rem;">Pay when your order arrives</div>
                  </div>
                  <i class="fas fa-chevron-right text-white-50"></i>
                </div>
              </label>
            </div>

            <p class="text-white-50 mt-2 mb-0" style="font-size:.72rem;">
              <i class="fas fa-lock me-1 text-success"></i>Secured by Razorpay
            </p>
          </div>

        </div><!-- /col-lg-7 -->

        <!-- RIGHT COLUMN — order summary -->
        <div class="col-lg-5">
          <div class="summary-sticky">
            <div class="section-box">
              <div class="section-title"><i class="fas fa-shopping-bag me-2"></i>Order Summary</div>

              <div class="mb-3">
                <% cartItems.forEach(item => { %>
                  <div class="order-item-row d-flex align-items-center gap-3" data-product-id="<%= item._id %>">
                    <% if (item.image) { %>
                      <img src="<%= item.image %>" alt="" style="width:50px;height:70px;object-fit:cover;flex-shrink:0;">
                    <% } else { %>
                      <div style="width:50px;height:70px;background:#2a2a2a;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <i class="fas fa-book text-white-50"></i>
                      </div>
