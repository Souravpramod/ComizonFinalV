<%- include('../partials/user-head', { title: 'Your Cart' }) %>

<body class="bg-black text-light">

    <%- include('../partials/header') %>

    <style>
        .cart-item {
            background-color: #1A1A1A;
            border: 1px solid #333;
            transition: border-color 0.2s;
        }
        .cart-item:hover {
            border-color: #555;
        }
        .cart-img {
            width: 100px;
            height: 150px;
            object-fit: cover;
            flex-shrink: 0;
        }
        .cart-img-placeholder {
            width: 100px;
            height: 150px;
            background-color: #2a2a2a;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        .quantity-input {
            width: 65px;
            background-color: #000;
            border: 1px solid #444;
            color: white;
            text-align: center;
        }
        .quantity-input:focus {
            background-color: #000;
            color: white;
            border-color: var(--primary-red);
            box-shadow: none;
        }
        .summary-card {
            background-color: #1A1A1A;
            border: 1px solid #333;
            position: sticky;
            top: 100px;
        }
        .page-header {
            margin-top: 90px;
            padding-top: 2rem;
            padding-bottom: 1.5rem;
        }
        .empty-state {
            min-height: 50vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }
        .empty-icon {
            font-size: 5rem;
            color: #333;
        }
        .btn-remove {
            background: transparent;
            border: 1px solid #555;
            color: #aaa;
            transition: all 0.2s;
        }
        .btn-remove:hover {
            background-color: var(--primary-red);
            border-color: var(--primary-red);
            color: white;
        }

        /* Hide native number arrows */
            .quantity-input::-webkit-outer-spin-button,
            .quantity-input::-webkit-inner-spin-button {
                -webkit-appearance: none;
                margin: 0;
            }
            .quantity-input[type=number] {
                -moz-appearance: textfield;
            }

            .qty-btn:hover {
                color: #FFFFFF !important;
                background-color: #cc0000 !important;
            }
    </style>

    <!-- Page Header -->
    <header class="container page-header mb-4">
        <h1 class="display-4 text-uppercase border-start border-4 border-danger ps-3">
            Your <span class="text-danger">Cart</span>
        </h1>
        <%
            const cartItems = Array.isArray(locals.cartItems) ? locals.cartItems : [];
            const subtotal  = typeof locals.subtotal === 'number'  ? locals.subtotal  : 0;
            const shipping  = typeof locals.shipping === 'number'  ? locals.shipping  : 0;
            const total     = typeof locals.total    === 'number'  ? locals.total     : 0;
            const itemCount = typeof locals.itemCount === 'number' ? locals.itemCount : 0;
        %>
        <p class="text-white-50 mt-2 ps-3"><%= itemCount %> item<%= itemCount !== 1 ? 's' : '' %> in your cart</p>
    </header>

   
    <!-- Blocked Products Warning Banner -->
    <% const blockedItems = cartItems.filter(i => !i.isActive); %>
    <% if (blockedItems.length > 0) { %>
        <div class="container mb-3">
            <div class="alert alert-danger rounded-0 border-0 border-start border-4 border-danger" role="alert">
                <i class="fas fa-ban me-2"></i>
                <strong>Action Required:</strong>
                The following item<%= blockedItems.length > 1 ? 's have' : ' has' %> been <strong>blocked by the admin</strong> and cannot be purchased:
                <ul class="mb-0 mt-1">
                    <% blockedItems.forEach(b => { %>
                        <li><strong><%= b.name %></strong> — please remove it to proceed to checkout.</li>
                    <% }) %>
                </ul>
            </div>
        </div>
    <% } %>

    <!-- Flash Messages -->
    <% if (locals.success) { %>
        <div class="container mb-3">
            <div class="alert alert-success alert-dismissible rounded-0 fade show border-0 border-start border-4 border-success" role="alert">
                <i class="fas fa-check-circle me-2"></i><%= locals.success %>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
            </div>
        </div>
    <% } %>
    <% if (locals.error) { %>
        <div class="container mb-3">
            <div class="alert alert-danger alert-dismissible rounded-0 fade show border-0 border-start border-4 border-danger" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i><%= locals.error %>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
            </div>
        </div>
    <% } %>

    <!-- Cart Content -->
    <section class="container pb-5">

        <% if (cartItems.length === 0) { %>

            <!-- Empty State -->
            <div class="empty-state text-center py-5">
                <div class="empty-icon"><i class="fas fa-shopping-cart"></i></div>
                <h3 class="text-white-50 mt-3">Your cart is empty</h3>
                <p class="text-white-50">Looks like you haven't added anything yet.</p>
                <a href="/" class="btn btn-danger px-4 py-2 rounded-0 fw-bold mt-2">
                    <i class="fas fa-book-open me-2"></i>Browse Comics
                </a>
            </div>

        <% } else { %>

            <div class="row g-4">

                <!-- ── Cart Items ─────────────────────────────── -->
                <div class="col-lg-8">

                    <% cartItems.forEach(item => { %>
                        <div class="d-flex align-items-start p-3 mb-3 cart-item rounded-0">

                            <!-- Product Image -->
                            <a href="/product/<%= item._id %>" class="me-3 flex-shrink-0">
                                <% if (item.image) { %>
                                    <img src="<%= item.image %>" alt="<%= item.name %>" class="cart-img">
                                <% } else { %>
                                    <div class="cart-img-placeholder">
                                        <i class="fas fa-book fa-2x text-white-50"></i>
                                    </div>
                                <% } %>
                            </a>

                            <!-- Product Info -->
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h5 class="fw-bold mb-1">
                                            <a href="/product/<%= item._id %>" class="text-decoration-none text-white"><%= item.name %></a>
                                        </h5>
                                        <p class="text-white-50 small mb-0">Category: <%= item.category %></p>
                                        <% if (item.hasOffer) { %>
                                            <div class="mt-1 d-flex align-items-center gap-2 flex-wrap offer-sync-badge">
                                                <span class="text-white-50 text-decoration-line-through small">$<%= Number(item.price).toFixed(2) %> each</span>
                                                <span class="small fw-bold" style="color:<%= item.badgeColor %>; font-size:.72rem;">
                                                    <i class="fas fa-tag me-1"></i><%= item.offerBadge %>
                                                </span>
                                            </div>
                                        <% } else { %>
                                            <p class="text-white-50 small mb-0 offer-sync-badge" data-nooffer="1">$<%= Number(item.price).toFixed(2) %> each</p>
                                        <% } %>
                                        <% if (!item.isActive) { %>
                                            <span class="badge bg-danger mt-1"><i class="fas fa-ban me-1"></i>Blocked by Admin</span>
                                        <% } else if (item.outOfstock) { %>
                                            <span class="badge bg-secondary mt-1 stock-badge">Out of Stock</span>
                                        <% } else if (item.stock <= 5) { %>
                                            <span class="badge bg-warning text-dark mt-1 stock-badge">Only <%= item.stock %> left</span>
                                        <% } %>
                                    </div>
                                    <h4 class="text-danger fw-bold ms-3 flex-shrink-0">
                                        $<%= item.lineTotal.toFixed(2) %>
                                    </h4>
                                </div>

                                <!-- Qty + Remove -->
                                <div class="d-flex justify-content-between align-items-center mt-3">

                                    
                                    <!-- Quantity Form -->
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="text-white-50 small">Qty:</span>
                                        <div class="qty-wrapper d-flex align-items-center rounded-0" style="border:1px solid #444; background:#000;">
                                            <button
                                                type="button"
                                                class="qty-btn"
                                                style="background:transparent; border:none; color:#FFFFFF; font-size:1.1rem; font-weight:700; width:30px; height:32px; cursor:pointer; line-height:1; display:flex; align-items:center; justify-content:center;"
                                                onclick="stepQty(this, -1)"
                                            >&#8722;</button>

                                            <input
                                                type="number"
                                                name="quantity"
                                                class="form-control form-control-sm quantity-input rounded-0"
                                                value="<%= item.quantity %>"
                                                min="1"
                                                max="<%= Math.min(item.stock, 6) %>"
                                                data-product-id="<%= item._id %>"
                                                data-original="<%= item.quantity %>"
                                                data-price="<%= item.effectivePrice %>"
                                                onchange="updateQty(this)"
                                                style="width:40px; background:#000; border:none; border-left:1px solid #444; border-right:1px solid #444; color:#FFFFFF; text-align:center; -moz-appearance:textfield;"
                                            >

                                            <button
                                                type="button"
                                                class="qty-btn"
                                                style="background:transparent; border:none; color:#FFFFFF; font-size:1.1rem; font-weight:700; width:30px; height:32px; cursor:pointer; line-height:1; display:flex; align-items:center; justify-content:center;"
                                                onclick="stepQty(this, +1)"
                                            >&#43;</button>
                                        </div>
                                        <span class="qty-spinner spinner-border spinner-border-sm text-danger d-none" data-spinner="<%= item._id %>"></span>
                                    </div>

                                    <!-- Remove Form -->
                                    <form action="/cart/remove/<%= item._id %>" method="POST" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-remove rounded-0 px-3">
                                            <i class="fas fa-trash-alt me-1"></i>Remove
                                        </button>
                                    </form>

                                </div>
                            </div>

                        </div>
                    <% }) %>

                    <!-- Continue Shopping -->
                    <div class="mt-3">
                        <a href="/" class="text-decoration-none text-white-50">
                            <i class="fas fa-arrow-left me-2"></i>Continue Shopping
                        </a>
                    </div>

                </div>

                <!-- ── Order Summary ───────────────────────────── -->
                <div class="col-lg-4">
                    <div class="summary-card p-4 rounded-0">
                        <h4 class="text-uppercase fw-bold mb-4 border-bottom border-secondary pb-3">
                            Order Summary
                        </h4>

                        <div class="d-flex justify-content-between mb-2 text-white-50">
                            <span>Subtotal (<span id="summary-itemcount"><%= itemCount %></span> item<%= itemCount !== 1 ? 's' : '' %>)</span>
                            <span id="summary-subtotal">$<%= subtotal.toFixed(2) %></span>
                        </div>

                        <div class="d-flex justify-content-between mb-3 text-white-50">
                            <span>Shipping</span>
                            <span id="summary-shipping" class="<%= shipping === 0 ? 'text-success' : '' %>">
                                <%= shipping === 0 ? 'FREE' : `$${shipping.toFixed(2)}` %>
                            </span>
                        </div>

                        <% if (shipping > 0) { %>
                            <p class="text-white-50 small mb-3">
                                <i class="fas fa-info-circle me-1"></i>
                                Add $<%= (500 - subtotal).toFixed(2) %> more for free shipping
                            </p>
                        <% } %>

                        
                        

                        <hr class="border-secondary">

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h4 class="fw-bold mb-0">Total</h4>
                            <h4 class="text-danger fw-bold mb-0" id="summary-total">$<%= total.toFixed(2) %></h4>
                        </div>

                        <% const hasBlocked = cartItems.some(i => !i.isActive); %>
                        <% const hasPremiumLocked = cartItems.some(i => i.isPremiumLocked); %>
                        <% if (hasBlocked || hasPremiumLocked) { %>
                          <button class="btn btn-secondary w-100 py-3 fw-bold rounded-0 mb-3 text-uppercase" disabled
                                  id="cartCheckoutBtn"
                                  title="Remove restricted items before proceeding">
                            <i class="fas fa-ban me-2"></i>Checkout Unavailable
                          </button>
                          <p class="text-danger small text-center mb-0" id="cartCheckoutMsg">
                            <i class="fas fa-exclamation-circle me-1"></i>
                            Remove blocked or premium item(s) above to proceed.
                          </p>
                        <% } else { %>
                          <a href="/checkout" class="btn btn-danger w-100 py-3 fw-bold rounded-0 mb-3 text-uppercase"
                             id="cartCheckoutBtn">
                            <i class="fas fa-lock me-2"></i>Proceed to Checkout
                          </a>
                          <p class="text-danger small text-center mb-0 d-none" id="cartCheckoutMsg">
                            <i class="fas fa-exclamation-circle me-1"></i>
                            Remove premium item(s) to proceed.
                          </p>
                        <% } %>

                        <div class="text-center my-2">
                            <span class="text-muted small">or</span>
                        </div>

                        <a href="/orders" class="btn btn-outline-light w-100 py-2 rounded-0 text-uppercase fw-bold">
                            <i class="fas fa-history me-2"></i>View Order History
                        </a>
                    </div>
                </div>

            </div>
        <% } %>

    </section>

    <%- include('../partials/footer') %>
<script>
function updateQty(input) {
    const productId = input.dataset.productId;
    const qty       = parseInt(input.value, 10);
    const spinner   = document.querySelector(`[data-spinner="${productId}"]`);

    if (isNaN(qty) || qty < 1) {
        input.value = input.dataset.original;
        return;
    }

    input.disabled = true;
    if (spinner) spinner.classList.remove('d-none');

    fetch(`/cart/update/${productId}`, {
        method:  'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body:    `quantity=${qty}`,
    })
    .then(r => r.json())
    .then(data => {
        if (!data.ok) {
            if (data.blocked) {
                showCartAlert('danger',
                    `<i class="fas fa-ban me-2"></i><strong>Product Blocked:</strong> "${input.closest('.cart-item')?.querySelector('h5 a')?.textContent?.trim() || 'This item'}" has been blocked by the admin and cannot be purchased. Please remove it from your cart.`
                );
                input.value = input.dataset.original;
            } else {
                showCartAlert('warning', `<i class="fas fa-exclamation-triangle me-2"></i>${data.message}`);
                input.value = input.dataset.original;
            }
        } else {
            input.dataset.original = data.updatedItem.quantity;
            input.value            = data.updatedItem.quantity;

            // update line total for this row
            const row = input.closest('.d-flex.align-items-start');
            if (row) {
                const lineEl = row.querySelector('h4.text-danger');
                if (lineEl) lineEl.textContent = `$${data.updatedItem.lineTotal.toFixed(2)}`;
            }

            // update summary panel
            const setEl = (sel, val) => { const el = document.querySelector(sel); if (el) el.textContent = val; };
            setEl('#summary-subtotal', `$${data.subtotal.toFixed(2)}`);
            setEl('#summary-shipping', data.shipping === 0 ? 'FREE' : `$${data.shipping.toFixed(2)}`);
            setEl('#summary-total',    `$${data.total.toFixed(2)}`);
            setEl('#summary-itemcount', data.itemCount);

            // header item count
            const countBadge = document.querySelector('.cart-count-badge');
            if (countBadge) {
                countBadge.textContent = data.itemCount;
                if (data.itemCount > 0) {
                    countBadge.classList.remove('d-none');
                } else {
                    countBadge.classList.add('d-none');
                }
            }
        }
    })
    .catch(() => {
        showCartAlert('danger', '<i class="fas fa-exclamation-circle me-2"></i>Network error. Please try again.');
        input.value = input.dataset.original;
    })
    .finally(() => {
        input.disabled = false;
        if (spinner) spinner.classList.add('d-none');
    });
}

function showCartAlert(type, html) {
    let box = document.getElementById('cart-flash-box');
    if (!box) {
        box = document.createElement('div');
        box.id = 'cart-flash-box';
        box.className = 'container mb-3';
        document.querySelector('section.container')?.before(box);
    }
    box.innerHTML = `
        <div class="alert alert-${type} alert-dismissible rounded-0 fade show border-0 border-start border-4 border-${type}" role="alert">
            ${html}
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
        </div>`;
}

// ── Stock poller — checks every 8 seconds ─────────────────────────────────────
let pollerActive = true;

async function syncCartStock() {
    if (!pollerActive) return;
    try {
        const res  = await fetch('/cart/stock-sync');
        const data = await res.json();
        if (!data.ok || !data.items) return;

        let anyChange = false;

        data.items.forEach(item => {
            const productId = item.productId;

            // Find the input for this product
            const input = document.querySelector(`input[data-product-id="${productId}"]`);
            const row   = input?.closest('.d-flex.align-items-start');
            if (!input || !row) return;

            const oldQty = parseInt(input.dataset.original, 10);

            // Update max attribute
input.max = Math.min(item.stock, 6);

// ── Re-render the stock badge based on current stock ──────────────────
if (!item.blocked && !item.outOfstock) {
    const existingBadge = row.querySelector('.stock-badge');
    if (item.stock <= 5) {
        // Stock is low — show or update the "Only X left" badge
        if (existingBadge) {
            // Update existing badge in place
            existingBadge.className   = 'badge bg-warning text-dark mt-1 stock-badge';
            existingBadge.textContent = `Only ${item.stock} left`;
        } else {
            // No badge yet — create and insert it
            const badge = document.createElement('span');
            badge.className   = 'badge bg-warning text-dark mt-1 stock-badge';
            badge.textContent = `Only ${item.stock} left`;
            const catLine = row.querySelector('p.text-white-50.small');
            if (catLine) catLine.after(badge);
        }
    } else {
        // Stock is healthy (> 5) — remove any leftover low-stock badge
        const existingLowBadge = row.querySelector('.stock-badge');
        if (existingLowBadge) existingLowBadge.remove();
    }
}

// If quantity was reduced
            if (item.reduced && item.quantity !== oldQty) {
                anyChange = true;
                input.value            = item.quantity;
                input.dataset.original = item.quantity;

                // Update line total display using effective price
                const effPrice = parseFloat(input.dataset.price || 0); // data-price is now effectivePrice
                const lineEl   = row.querySelector('h4.text-danger');
                if (lineEl && effPrice) {
                    lineEl.textContent = `$${(effPrice * item.quantity).toFixed(2)}`;
                }

                // Flash the row orange to signal auto-reduction
                row.style.transition = 'background .4s';
                row.style.background = 'rgba(253,126,20,0.18)';
                setTimeout(() => { row.style.background = ''; }, 2000);
            }

            // If out of stock — show badge
            if (item.outOfstock) {
                anyChange = true;
                const stockBadge = row.querySelector('.stock-badge');
                if (!stockBadge) {
                    const nameDiv = row.querySelector('h5');
                    if (nameDiv) {
                        const badge = document.createElement('span');
                        badge.className   = 'badge bg-secondary mt-1 ms-1 stock-badge';
                        badge.textContent = 'Out of Stock';
                        nameDiv.after(badge);
                    }
                }
            }

            // If blocked by admin
            if (item.blocked) {
                anyChange = true;
                const nameEl = row.querySelector('h5 a');
                if (nameEl && !row.querySelector('.blocked-badge')) {
                    const badge = document.createElement('span');
                    badge.className   = 'badge bg-danger mt-1 ms-1 blocked-badge';
                    badge.innerHTML   = '<i class="fas fa-ban me-1"></i>Blocked by Admin';
                    nameEl.closest('h5').after(badge);
                }
            }

            // ── If product became premium and user is not premium ─────────────
            // Server already removed it from DB; disable checkout and fade row
            if (item.isPremiumLocked) {
                anyChange = true;
                cartPremiumLockedIds.add(item.productId);
                updateCartCheckoutBtn();

                const cartRow = row.closest('li') || row.closest('[data-cart-item]') || row.parentElement;
                if (cartRow && !cartRow.querySelector('.premium-locked-badge')) {
                    // Badge on the product name
                    const badge = document.createElement('span');
                    badge.className   = 'badge bg-warning text-dark mt-1 ms-1 premium-locked-badge';
                    badge.innerHTML   = '<i class="fas fa-crown me-1"></i>Premium Only — Remove to Proceed';
                    row.querySelector('h5')?.after(badge);
                    // Dim the row like blocked items — do NOT auto-remove,
                    // force the user to manually remove it (same UX as blocked)
                    cartRow.style.opacity = '0.55';
                    showCartAlert('warning',
                        '<i class="fas fa-crown me-2"></i>A product in your cart became <strong>Premium Only</strong>. ' +
                        'Remove it to proceed to checkout, or upgrade your membership.'
                    );
                }
            } else {
                // Product is no longer premium-locked (e.g. admin reverted it)
                if (cartPremiumLockedIds.has(item.productId)) {
                    cartPremiumLockedIds.delete(item.productId);
                    updateCartCheckoutBtn();
                    // Remove badge and restore opacity
                    const badge = row.querySelector('.premium-locked-badge');
                    if (badge) badge.remove();
                    const cartRow = row.closest('li') || row.closest('[data-cart-item]') || row.parentElement;
                    if (cartRow) cartRow.style.opacity = '';
                }
            }
            // ────────────────────────────────────────────────────────────────
        });

        // Recalculate summary if anything changed
        if (anyChange) {
            recalcSummary();
            showCartAlert('warning',
                '<i class="fas fa-exclamation-triangle me-2"></i>Some item quantities were adjusted due to stock changes.'
            );
        }

    } catch (e) {
        // silent fail — poller runs again in 8s
    }
}

// ── Cart checkout button gating ───────────────────────────────────────────────
const cartPremiumLockedIds = new Set();

function updateCartCheckoutBtn() {
    const btn = document.getElementById('cartCheckoutBtn');
    const msg = document.getElementById('cartCheckoutMsg');
    if (!btn) return;

    // Count remaining blocked items (server-rendered, still in DOM)
    const hasBlockedInDOM  = !!document.querySelector('.blocked-badge');
    const hasPremiumInDOM  = cartPremiumLockedIds.size > 0;
    const shouldDisable    = hasBlockedInDOM || hasPremiumInDOM;

    if (shouldDisable) {
        // Replace the <a> tag with a disabled <button> if it's currently a link
        if (btn.tagName === 'A') {
            const disabledBtn = document.createElement('button');
            disabledBtn.id        = 'cartCheckoutBtn';
            disabledBtn.className = 'btn btn-secondary w-100 py-3 fw-bold rounded-0 mb-3 text-uppercase';
            disabledBtn.disabled  = true;
            disabledBtn.title     = 'Remove restricted items before proceeding';
            disabledBtn.innerHTML = '<i class="fas fa-ban me-2"></i>Checkout Unavailable';
            btn.replaceWith(disabledBtn);
        } else {
            btn.disabled  = true;
            btn.className = 'btn btn-secondary w-100 py-3 fw-bold rounded-0 mb-3 text-uppercase';
            btn.innerHTML = '<i class="fas fa-ban me-2"></i>Checkout Unavailable';
        }
        if (msg) msg.classList.remove('d-none');
    } else {
        if (msg) msg.classList.add('d-none');
        // Re-enable — only matters if it was dynamically disabled (was a button, not a link)
        const currentBtn = document.getElementById('cartCheckoutBtn');
        if (currentBtn && currentBtn.tagName === 'BUTTON') {
            const link    = document.createElement('a');
            link.id       = 'cartCheckoutBtn';
            link.href     = '/checkout';
            link.className = 'btn btn-danger w-100 py-3 fw-bold rounded-0 mb-3 text-uppercase';
            link.innerHTML = '<i class="fas fa-lock me-2"></i>Proceed to Checkout';
            currentBtn.replaceWith(link);
        }
    }
}
// ─────────────────────────────────────────────────────────────────────────────



function recalcSummary() {
    let subtotal = 0;
    let itemCount = 0;

    document.querySelectorAll('input[data-product-id]').forEach(input => {
        const qty   = parseInt(input.value, 10) || 0;
        const price = parseFloat(input.dataset.price || 0);
        subtotal  += qty * price;
        itemCount += qty;
    });

    const shipping = subtotal === 0 ? 0 : subtotal >= 500 ? 0 : 5;
    const total    = subtotal + shipping;

    const setEl = (sel, val) => { const el = document.querySelector(sel); if (el) el.textContent = val; };
    setEl('#summary-subtotal',  `$${subtotal.toFixed(2)}`);
    setEl('#summary-shipping',  shipping === 0 ? 'FREE' : `$${shipping.toFixed(2)}`);
    setEl('#summary-total',     `$${total.toFixed(2)}`);
    setEl('#summary-itemcount', itemCount);
}
let offerPollerActive = true;

async function syncOfferPrices() {
    if (!offerPollerActive) return;
    try {
        const res  = await fetch('/cart/offer-prices');
        const data = await res.json();
        if (!data.ok || !data.items?.length) return;

        let anyChange       = false;
        const addedOffers   = [];   // product names where offer was newly added
        const removedOffers = [];   // product names where offer was removed
        const changedOffers = [];   // product names where offer price changed

        data.items.forEach(item => {
            const input = document.querySelector(`input[data-product-id="${item.productId}"]`);
            if (!input) return;

            const row = input.closest('.d-flex.align-items-start');
            if (!row) return;

            const oldEffective = parseFloat(input.dataset.price || 0);
            const priceChanged = Math.abs(item.effectivePrice - oldEffective) > 0.001;

            // ── Collect product name for toast messages ───────────────────────
            const productName = row.querySelector('h5 a')?.textContent?.trim() || 'A product';

            // ── Detect offer state transitions ────────────────────────────────
            const infoDiv    = row.querySelector('.flex-grow-1 > .d-flex.justify-content-between > div');
            const badgeEl    = infoDiv?.querySelector('.offer-sync-badge');
            const hadOffer   = badgeEl && !badgeEl.dataset.nooffer;
            const nowHasOffer = item.hasOffer;

            if (!hadOffer && nowHasOffer)           addedOffers.push(productName);
            else if (hadOffer && !nowHasOffer)      removedOffers.push(productName);
            else if (hadOffer && priceChanged)      changedOffers.push(productName);

            // ── Update effective price on the input ───────────────────────────
            if (priceChanged) {
                anyChange = true;
                input.dataset.price = item.effectivePrice;
            }

            // ── Update line total display ─────────────────────────────────────
            const lineEl = row.querySelector('h4.text-danger');
            if (lineEl) {
                const serverLineTotal = item.lineTotal.toFixed(2);
                if (lineEl.textContent.trim() !== `$${serverLineTotal}`) {
                    anyChange = true;
                    lineEl.textContent = `$${serverLineTotal}`;
                }
            }

            // ── Update offer badge area ───────────────────────────────────────
            // Works whether badgeEl exists or not — find the anchor point
            if (infoDiv) {
                if (nowHasOffer) {
                    const newBadge = document.createElement('div');
                    newBadge.className = 'mt-1 d-flex align-items-center gap-2 flex-wrap offer-sync-badge';
                    newBadge.innerHTML = `
                        <span class="text-white-50 text-decoration-line-through small">$${Number(item.originalPrice).toFixed(2)} each</span>
                        <span class="small fw-bold" style="color:${item.badgeColor}; font-size:.72rem;">
                            <i class="fas fa-tag me-1"></i>${item.offerBadge}
                        </span>`;
                    if (badgeEl) {
                        badgeEl.replaceWith(newBadge);
                    } else {
                        // No badge yet — insert after the category line (p.text-white-50.small)
                        const catLine = infoDiv.querySelector('p.text-white-50.small');
                        if (catLine) catLine.after(newBadge);
                        else infoDiv.appendChild(newBadge);
                    }
                    anyChange = true;
                } else {
                    // No offer now — show plain price line
                    const newLine = document.createElement('p');
                    newLine.className = 'text-white-50 small mb-0 offer-sync-badge';
                    newLine.dataset.nooffer = '1';
                    newLine.textContent = `$${Number(item.originalPrice).toFixed(2)} each`;
                    if (badgeEl) {
                        badgeEl.replaceWith(newLine);
                        anyChange = true;
                    }
                    // If no badge and no offer — nothing to do, already showing plain price
                }
            }
        });

        if (anyChange) recalcSummary();

        // ── Inform the user about what changed ────────────────────────────────
        if (addedOffers.length) {
            showCartAlert('success',
                `<i class="fas fa-tag me-2"></i><strong>New offer applied!</strong> ` +
                `${addedOffers.join(', ')} now has a discount — your total has been updated.`
            );
        }
        if (removedOffers.length) {
            showCartAlert('warning',
                `<i class="fas fa-exclamation-triangle me-2"></i><strong>Offer removed.</strong> ` +
                `The discount on ${removedOffers.join(', ')} has ended. ` +
                `Your cart total has been updated to reflect the original price.`
            );
        }
        if (changedOffers.length) {
            showCartAlert('warning',
                `<i class="fas fa-info-circle me-2"></i><strong>Offer price changed.</strong> ` +
                `The discount on ${changedOffers.join(', ')} was updated by the store. ` +
                `Your cart total reflects the new price.`
            );
        }

    } catch (e) {
        // silent fail — poller runs again
    }
}

// Run immediately on page load, then every 30 seconds
syncOfferPrices();
const offerPollInterval = setInterval(syncOfferPrices, 30000);

// Start polling every 8 seconds
const stockPollInterval = setInterval(syncCartStock, 8000);

// Stop polling when tab is hidden to save resources
document.addEventListener('visibilitychange', () => {
    pollerActive      = !document.hidden;
    offerPollerActive = !document.hidden;
    if (!document.hidden) {
        syncCartStock();
        syncOfferPrices(); // immediate offer sync when tab becomes visible again
    }
});

function stepQty(btn, delta) {
    const wrapper = btn.closest('.qty-wrapper');
    const input   = wrapper.querySelector('input[type="number"]');
    const min     = parseInt(input.min, 10) || 1;
    const max     = parseInt(input.max, 10) || Infinity;
    const newVal  = Math.min(max, Math.max(min, parseInt(input.value, 10) + delta));
    input.value   = newVal;
    updateQty(input);
}
</script>
