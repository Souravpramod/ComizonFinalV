<%- include('../partials/user-head', { title: 'Your Cart' }) %>

<body class="bg-black text-light">

    <%- include('../partials/header') %>

    <style>
        .cart-item {
            background-color: #1A1A1A;
            border: 1px solid #333;
            transition: border-color 0.2s;
        }
        .cart-item:hover {
            border-color: #555;
        }
        .cart-img {
            width: 100px;
            height: 150px;
            object-fit: cover;
            flex-shrink: 0;
        }
        .cart-img-placeholder {
            width: 100px;
            height: 150px;
            background-color: #2a2a2a;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        .quantity-input {
            width: 65px;
            background-color: #000;
            border: 1px solid #444;
            color: white;
            text-align: center;
        }
        .quantity-input:focus {
            background-color: #000;
            color: white;
            border-color: var(--primary-red);
            box-shadow: none;
        }
        .summary-card {
            background-color: #1A1A1A;
            border: 1px solid #333;
            position: sticky;
            top: 100px;
        }
        .page-header {
            margin-top: 90px;
            padding-top: 2rem;
            padding-bottom: 1.5rem;
        }
        .empty-state {
            min-height: 50vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }
        .empty-icon {
            font-size: 5rem;
            color: #333;
        }
        .btn-remove {
            background: transparent;
            border: 1px solid #555;
            color: #aaa;
            transition: all 0.2s;
        }
        .btn-remove:hover {
            background-color: var(--primary-red);
            border-color: var(--primary-red);
            color: white;
        }

        /* Hide native number arrows */
            .quantity-input::-webkit-outer-spin-button,
            .quantity-input::-webkit-inner-spin-button {
                -webkit-appearance: none;
                margin: 0;
            }
            .quantity-input[type=number] {
                -moz-appearance: textfield;
            }

            .qty-btn:hover {
                color: #FFFFFF !important;
                background-color: #cc0000 !important;
            }
    </style>

    <!-- Page Header -->
    <header class="container page-header mb-4">
        <h1 class="display-4 text-uppercase border-start border-4 border-danger ps-3">
            Your <span class="text-danger">Cart</span>
        </h1>
        <%
            const cartItems = Array.isArray(locals.cartItems) ? locals.cartItems : [];
            const subtotal  = typeof locals.subtotal === 'number'  ? locals.subtotal  : 0;
            const shipping  = typeof locals.shipping === 'number'  ? locals.shipping  : 0;
            const total     = typeof locals.total    === 'number'  ? locals.total     : 0;
            const itemCount = typeof locals.itemCount === 'number' ? locals.itemCount : 0;
        %>
        <p class="text-white-50 mt-2 ps-3"><%= itemCount %> item<%= itemCount !== 1 ? 's' : '' %> in your cart</p>
    </header>

   
    <!-- Blocked Products Warning Banner -->
    <% const blockedItems = cartItems.filter(i => !i.isActive); %>
    <% if (blockedItems.length > 0) { %>
        <div class="container mb-3">
            <div class="alert alert-danger rounded-0 border-0 border-start border-4 border-danger" role="alert">
                <i class="fas fa-ban me-2"></i>
                <strong>Action Required:</strong>
                The following item<%= blockedItems.length > 1 ? 's have' : ' has' %> been <strong>blocked by the admin</strong> and cannot be purchased:
                <ul class="mb-0 mt-1">
                    <% blockedItems.forEach(b => { %>
                        <li><strong><%= b.name %></strong> — please remove it to proceed to checkout.</li>
                    <% }) %>
                </ul>
            </div>
        </div>
    <% } %>

    <!-- Flash Messages -->
    <% if (locals.success) { %>
        <div class="container mb-3">
            <div class="alert alert-success alert-dismissible rounded-0 fade show border-0 border-start border-4 border-success" role="alert">
                <i class="fas fa-check-circle me-2"></i><%= locals.success %>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
            </div>
        </div>
    <% } %>
    <% if (locals.error) { %>
        <div class="container mb-3">
            <div class="alert alert-danger alert-dismissible rounded-0 fade show border-0 border-start border-4 border-danger" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i><%= locals.error %>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
            </div>
        </div>
    <% } %>

    <!-- Cart Content -->
    <section class="container pb-5">

        <% if (cartItems.length === 0) { %>

            <!-- Empty State -->
            <div class="empty-state text-center py-5">
                <div class="empty-icon"><i class="fas fa-shopping-cart"></i></div>
                <h3 class="text-white-50 mt-3">Your cart is empty</h3>
                <p class="text-white-50">Looks like you haven't added anything yet.</p>
                <a href="/" class="btn btn-danger px-4 py-2 rounded-0 fw-bold mt-2">
                    <i class="fas fa-book-open me-2"></i>Browse Comics
                </a>
            </div>

        <% } else { %>

            <div class="row g-4">

                <!-- ── Cart Items ─────────────────────────────── -->
                <div class="col-lg-8">

                    <% cartItems.forEach(item => { %>
                        <div class="d-flex align-items-start p-3 mb-3 cart-item rounded-0">

                            <!-- Product Image -->
                            <a href="/product/<%= item._id %>" class="me-3 flex-shrink-0">
                                <% if (item.image) { %>
                                    <img src="<%= item.image %>" alt="<%= item.name %>" class="cart-img">
                                <% } else { %>
                                    <div class="cart-img-placeholder">
                                        <i class="fas fa-book fa-2x text-white-50"></i>
                                    </div>
                                <% } %>
                            </a>

                            <!-- Product Info -->
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h5 class="fw-bold mb-1">
                                            <a href="/product/<%= item._id %>" class="text-decoration-none text-white"><%= item.name %></a>
                                        </h5>
                                        <p class="text-white-50 small mb-0">Category: <%= item.category %></p>
                                        <% if (!item.isActive) { %>
                                            <span class="badge bg-danger mt-1"><i class="fas fa-ban me-1"></i>Blocked by Admin</span>
                                        <% } else if (item.outOfstock) { %>
                                            <span class="badge bg-secondary mt-1">Out of Stock</span>
                                        <% } else if (item.stock <= 5) { %>
                                            <span class="badge bg-warning text-dark mt-1">Only <%= item.stock %> left</span>
                                        <% } %>
                                    </div>
                                    <h4 class="text-danger fw-bold ms-3 flex-shrink-0">
                                        $<%= item.lineTotal.toFixed(2) %>
                                    </h4>
                                </div>

                                <!-- Qty + Remove -->
                                <div class="d-flex justify-content-between align-items-center mt-3">

                                    
                                    <!-- Quantity Form -->
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="text-white-50 small">Qty:</span>
                                        <div class="qty-wrapper d-flex align-items-center rounded-0" style="border:1px solid #444; background:#000;">
                                            <button
                                                type="button"
                                                class="qty-btn"
                                                style="background:transparent; border:none; color:#FFFFFF; font-size:1.1rem; font-weight:700; width:30px; height:32px; cursor:pointer; line-height:1; display:flex; align-items:center; justify-content:center;"
                                                onclick="stepQty(this, -1)"
                                            >&#8722;</button>

                                            <input
                                                type="number"
                                                name="quantity"
                                                class="form-control form-control-sm quantity-input rounded-0"
                                                value="<%= item.quantity %>"
                                                min="1"
                                                max="<%= item.stock %>"
                                                data-product-id="<%= item._id %>"
                                                data-original="<%= item.quantity %>"
                                                onchange="updateQty(this)"
                                                style="width:40px; background:#000; border:none; border-left:1px solid #444; border-right:1px solid #444; color:#FFFFFF; text-align:center; -moz-appearance:textfield;"
                                            >

                                            <button
                                                type="button"
                                                class="qty-btn"
                                                style="background:transparent; border:none; color:#FFFFFF; font-size:1.1rem; font-weight:700; width:30px; height:32px; cursor:pointer; line-height:1; display:flex; align-items:center; justify-content:center;"
                                                onclick="stepQty(this, +1)"
                                            >&#43;</button>
                                        </div>
                                        <span class="qty-spinner spinner-border spinner-border-sm text-danger d-none" data-spinner="<%= item._id %>"></span>
                                    </div>

                                    <!-- Remove Form -->
                                    <form action="/cart/remove/<%= item._id %>" method="POST" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-remove rounded-0 px-3">
                                            <i class="fas fa-trash-alt me-1"></i>Remove
                                        </button>
                                    </form>

                                </div>
                            </div>

                        </div>
                    <% }) %>

                    <!-- Continue Shopping -->
                    <div class="mt-3">
                        <a href="/" class="text-decoration-none text-white-50">
                            <i class="fas fa-arrow-left me-2"></i>Continue Shopping
                        </a>
                    </div>

                </div>

                <!-- ── Order Summary ───────────────────────────── -->
                <div class="col-lg-4">
                    <div class="summary-card p-4 rounded-0">
                        <h4 class="text-uppercase fw-bold mb-4 border-bottom border-secondary pb-3">
                            Order Summary
                        </h4>

                        <div class="d-flex justify-content-between mb-2 text-white-50">
                            <span>Subtotal (<%= itemCount %> item<%= itemCount !== 1 ? 's' : '' %>)</span>
                            <span>$<%= subtotal.toFixed(2) %></span>
                        </div>

                        <div class="d-flex justify-content-between mb-3 text-white-50">
                            <span>Shipping</span>
                            <% if (shipping === 0) { %>
                                <span class="text-success">FREE</span>
                            <% } else { %>
                                <span>$<%= shipping.toFixed(2) %></span>
                            <% } %>
                        </div>

                        <% if (shipping > 0) { %>
                            <p class="text-white-50 small mb-3">
                                <i class="fas fa-info-circle me-1"></i>
                                Add $<%= (500 - subtotal).toFixed(2) %> more for free shipping
                            </p>
                        <% } %>

                        <!-- Promo Code -->
                        <div class="input-group mb-4">
                            <input
                                type="text"
                                class="form-control bg-black border-secondary text-white rounded-0"
                                placeholder="Promo Code"
                            >
                            <button class="btn btn-outline-secondary rounded-0 px-3">APPLY</button>
                        </div>

                        <hr class="border-secondary">

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h4 class="fw-bold mb-0">Total</h4>
                            <h4 class="text-danger fw-bold mb-0">$<%= total.toFixed(2) %></h4>
                        </div>

                        <a href="/checkout" class="btn btn-danger w-100 py-3 fw-bold rounded-0 mb-3 text-uppercase">
                            <i class="fas fa-lock me-2"></i>Proceed to Checkout
                        </a>

                        <div class="text-center my-2">
                            <span class="text-muted small">or</span>
                        </div>

                        <a href="/profile/orders" class="btn btn-outline-light w-100 py-2 rounded-0 text-uppercase fw-bold">
                            <i class="fas fa-history me-2"></i>View Order History
                        </a>
                    </div>
                </div>

            </div>
        <% } %>

    </section>

    <%- include('../partials/footer') %>
<script>
function updateQty(input) {
    const productId = input.dataset.productId;
    const qty       = parseInt(input.value, 10);
    const spinner   = document.querySelector(`[data-spinner="${productId}"]`);

    if (isNaN(qty) || qty < 1) {
        input.value = input.dataset.original;
        return;
    }

    input.disabled = true;
    if (spinner) spinner.classList.remove('d-none');

    fetch(`/cart/update/${productId}`, {
        method:  'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body:    `quantity=${qty}`,
    })
    .then(r => r.json())
    .then(data => {
        if (!data.ok) {
            if (data.blocked) {
                showCartAlert('danger',
                    `<i class="fas fa-ban me-2"></i><strong>Product Blocked:</strong> "${input.closest('.cart-item')?.querySelector('h5 a')?.textContent?.trim() || 'This item'}" has been blocked by the admin and cannot be purchased. Please remove it from your cart.`
                );
                input.value = input.dataset.original;
            } else {
                showCartAlert('warning', `<i class="fas fa-exclamation-triangle me-2"></i>${data.message}`);
                input.value = input.dataset.original;
            }
        } else {
            input.dataset.original = data.updatedItem.quantity;
            input.value            = data.updatedItem.quantity;

            // update line total for this row
            const row = input.closest('.d-flex.align-items-start');
            if (row) {
                const lineEl = row.querySelector('h4.text-danger');
                if (lineEl) lineEl.textContent = `$${data.updatedItem.lineTotal.toFixed(2)}`;
            }

            // update summary panel
            const setEl = (sel, val) => { const el = document.querySelector(sel); if (el) el.textContent = val; };
            setEl('#summary-subtotal', `$${data.subtotal.toFixed(2)}`);
            setEl('#summary-shipping', data.shipping === 0 ? 'FREE' : `$${data.shipping.toFixed(2)}`);
            setEl('#summary-total',    `$${data.total.toFixed(2)}`);
            setEl('#summary-itemcount', data.itemCount);

            // header item count
            const countBadge = document.querySelector('.cart-count-badge');
            if (countBadge) countBadge.textContent = data.itemCount;
        }
    })
    .catch(() => {
        showCartAlert('danger', '<i class="fas fa-exclamation-circle me-2"></i>Network error. Please try again.');
        input.value = input.dataset.original;
    })
    .finally(() => {
        input.disabled = false;
        if (spinner) spinner.classList.add('d-none');
    });
}

function showCartAlert(type, html) {
    let box = document.getElementById('cart-flash-box');
    if (!box) {
        box = document.createElement('div');
        box.id = 'cart-flash-box';
        box.className = 'container mb-3';
        document.querySelector('section.container')?.before(box);
    }
    box.innerHTML = `
        <div class="alert alert-${type} alert-dismissible rounded-0 fade show border-0 border-start border-4 border-${type}" role="alert">
            ${html}
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
        </div>`;
}

function stepQty(btn, delta) {
    const wrapper = btn.closest('.qty-wrapper');
    const input   = wrapper.querySelector('input[type="number"]');
    const min     = parseInt(input.min, 10) || 1;
    const max     = parseInt(input.max, 10) || Infinity;
    const newVal  = Math.min(max, Math.max(min, parseInt(input.value, 10) + delta));
    input.value   = newVal;
    updateQty(input);
}
</script>
</body>
</html>
