<%- include('../partials/user-head') %>
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #1a1a1a 0%, #000000 100%);
            color: white;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .forgot-container {
            background-color: #121212;
            border: 1px solid var(--border-color);
            border-top: 4px solid var(--primary-red);
            width: 100%;
            max-width: 480px;
            padding: 3rem 2.5rem;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.7);
        }

        .forgot-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, var(--primary-red) 0%, #c92a36 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 2rem;
            font-size: 2.5rem;
            color: white;
        }

        .form-control {
            background-color: #1E1E1E;
            border: 1px solid #444;
            color: white;
            padding: 0.9rem;
            border-radius: 0;
        }

        .btn-submit {
            background-color: var(--primary-red);
            color: white;
            border: none;
            padding: 0.9rem;
            font-weight: 800;
            letter-spacing: 0.5px;
            transition: all 0.3s;
            border-radius: 0;
            text-transform: uppercase;
            width: 100%;
        }
    </style>

    <body class="bg-black text-light">
        <div class="forgot-container">
            <div class="text-center mb-4">
                <h2 class="logo-text mb-1">COMIZON<span class="text-danger">.</span></h2>
            </div>

            <div class="forgot-icon">
                <i class="fas fa-lock"></i>
            </div>

            <div class="text-center mb-4">
                <h4 class="fw-bold text-uppercase">Forgot Password?</h4>
                <p class="text-muted small">No worries! Enter your email and we'll send you a reset link.</p>
            </div>

            <% if (locals.message) { %>
                <div class="alert alert-success rounded-0 small py-2 mb-3">
                    <%= message %>
                </div>
            <% } %>
            <% if (locals.error) { %>
                <div class="alert alert-danger rounded-0 small py-2 mb-3">
                    <%= error %>
                    <div class="mt-1">
                        <a href="/signup" class="text-danger fw-bold"><i class="fas fa-user-plus me-1"></i>Create an account</a>
                    </div>
                </div>
            <% } %>

                            <form action="/forgot-password" method="POST">
                                <div class="mb-3">
                                    <label class="form-label text-muted small fw-bold">EMAIL ADDRESS</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-dark border-secondary text-danger">
                                            <i class="fas fa-envelope"></i>
                                        </span>
                                        <input type="email" name="email" class="form-control"
                                            placeholder="Enter your email address" required>
                                    </div>
                                </div>

                                <button type="submit" class="btn btn-submit">
                                    <i class="fas fa-paper-plane me-2"></i>Send Reset Link
                                </button>
                            </form>

                            <div class="text-center mt-4">
                                <a href="/login" class="text-danger text-decoration-none fw-bold">
                                    <i class="fas fa-arrow-left me-1"></i>Back to Login
                                </a>
                            </div>
        </div>
    </body>

    </html>

