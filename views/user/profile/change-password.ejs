<%- include('../../partials/user-head', { title: 'Change Password' }) %>

  <body class="bg-black text-light">
    <%- include('../../partials/header') %>

      <div class="container" style="margin-top:100px; margin-bottom:4rem; max-width:600px;">
        <div class="bg-dark border border-secondary p-4" style="border-top:4px solid var(--primary-red) !important;">
          <div class="d-flex align-items-center gap-3 mb-4">
            <div class="rounded-circle bg-danger d-flex align-items-center justify-content-center"
              style="width:50px;height:50px;">
              <i class="fas fa-lock text-white fs-5"></i>
            </div>
            <div>
              <h4 class="mb-0 fw-bold text-uppercase">Change Password</h4>
              <p class="text-muted small mb-0">Keep your account secure</p>
            </div>
          </div>

          <% if (locals.error) { %>
            <div class="alert alert-danger rounded-0 small">
              <%= error %>
            </div>
            <% } %>
              <% if (locals.message) { %>
                <div class="alert alert-success rounded-0 small">
                  <%= message %>
                </div>
                <% } %>

                  <form action="/profile/change-password" method="POST">
                    <div class="mb-3">
                      <label class="form-label text-danger small fw-bold">CURRENT PASSWORD</label>
                      <div class="input-group">
                        <input type="password" name="currentPassword"
                          class="form-control bg-black border-secondary text-white rounded-0 password-field"
                          placeholder="Enter current password" required>
                        <button class="btn btn-outline-secondary border-secondary rounded-0 toggle-password"
                          type="button"><i class="fas fa-eye text-white"></i></button>
                      </div>
                    </div>
                    <div class="mb-3">
                      <label class="form-label text-danger small fw-bold">NEW PASSWORD</label>
                      <div class="input-group">
                        <input type="password" name="newPassword" id="newPwd"
                          class="form-control bg-black border-secondary text-white rounded-0 password-field"
                          placeholder="Minimum 8 characters" required minlength="8">
                        <button class="btn btn-outline-secondary border-secondary rounded-0 toggle-password"
                          type="button"><i class="fas fa-eye text-white"></i></button>
                      </div>
                    </div>
                    <div class="mb-4">
                      <label class="form-label text-danger small fw-bold">CONFIRM NEW PASSWORD</label>
                      <div class="input-group">
                        <input type="password" name="confirmPassword" id="confPwd"
                          class="form-control bg-black border-secondary text-white rounded-0 password-field"
                          placeholder="Repeat new password" required>
                        <button class="btn btn-outline-secondary border-secondary rounded-0 toggle-password"
                          type="button"><i class="fas fa-eye text-white"></i></button>
                      </div>
                      <div id="matchPwdMsg" class="small mt-1"></div>
                    </div>
                    <div class="d-flex gap-2">
                      <button type="submit" class="btn btn-danger rounded-0 px-4 fw-bold">Update Password</button>
                      <a href="/profile" class="btn btn-outline-secondary rounded-0 px-4">Cancel</a>
                    </div>
                  </form>
        </div>
      </div>

      <%- include('../../partials/footer') %>
        <script>
          document.querySelectorAll('.toggle-password').forEach(button => {
            button.addEventListener('click', function () {
              const input = this.previousElementSibling;
              const icon = this.querySelector('i');

              if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
              } else {
                input.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
              }
            });
          });

          document.getElementById('confPwd').addEventListener('input', function () {
            const msg = document.getElementById('matchPwdMsg');
            msg.innerHTML = this.value === document.getElementById('newPwd').value
              ? '<span class="text-success"><i class="fas fa-check me-1"></i>Passwords match</span>'
              : '<span class="text-danger"><i class="fas fa-times me-1"></i>Passwords do not match</span>';
          });
        </script>
  </body>

  </html>