<%- include('../../partials/user-head') %>

    <body class="bg-black text-light">

        <%- include('../../partials/header') %>

            <div class="container profile-container" style="margin-top: 100px; margin-bottom: 4rem;">
                <div class="row g-4">
                    <!-- Sidebar -->
                    <div class="col-lg-3">
                        <%- include('../../partials/profile-sidebar', { activePage: 'profile' }) %>
                    </div>

                    <!-- Main Content -->
                    <div class="col-lg-9">
                        <div class="section-card p-4 bg-dark border border-secondary mb-3"
                                    style="border-top: 4px solid <%= user.isPremium ? '#FFD700' : '#aaa' %>;">
                                    
                                    <div class="d-flex justify-content-between align-items-center">
                                        
                                        <div>
                                            <div class="usertype-label text-danger small fw-bold text-uppercase mb-1">
                                                Account Type
                                            </div>

                                            <div class="fw-bold h5 mb-0"
                                                style="color:<%= user.isPremium ? '#FFD700' : '#aaa' %>;">
                                                
                                                <%= user.isPremium ? 'Premium Member' : 'Regular Member' %>

                                            </div>

                                            <small style="color:#aaaaaa;">
                                                This field is managed by Comizon.
                                            </small>
                                        </div>


                                        <div class="premium-badge p-2 rounded fw-bold 
                                            <%= user.isPremium ? 'bg-warning text-black' : 'bg-secondary text-white' %>">

                                            <% if (user.isPremium) { %>
                                                <i class="fas fa-crown me-1"></i> PREMIUM
                                            <% } else { %>
                                                <i class="fas fa-user me-1"></i> REGULAR
                                            <% } %>

                                        </div>

                                    </div>

                                </div>

                        <div class="section-card p-4 bg-dark border border-secondary mb-4">
                            <div class="section-title text-uppercase fw-bold mb-4 border-start border-4 border-danger ps-3">
                                Personal Information</div>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label text-danger small fw-bold">FIRST NAME</label>
                                    <input type="text"
                                        class="form-control bg-black border-secondary text-white rounded-0"
                                        value="<%= locals.user ? user.firstName : '' %>" readonly>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label text-danger small fw-bold">LAST NAME</label>
                                    <input type="text"
                                        class="form-control bg-black border-secondary text-white rounded-0"
                                        value="<%= locals.user ? user.lastName : '' %>" readonly>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label text-danger small fw-bold">GENDER</label>
                                    <input type="text"
                                        class="form-control bg-black border-secondary text-white rounded-0"
                                        value="<%= locals.user ? user.gender : '' %>" readonly>
                                </div>
                            </div>
                        </div>

                        <div class="section-card p-4 bg-dark border border-secondary mb-4">
                            <div class="section-title text-uppercase fw-bold mb-4 border-start border-4 border-danger ps-3">
                                Account Details</div>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label text-danger small fw-bold">USERNAME</label>
                                    <input type="text"
                                        class="form-control bg-black border-secondary text-white rounded-0"
                                        value="<%= locals.user ? user.username : '' %>" readonly>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-warning small fw-bold">EMAIL ADDRESS <i class="fas fa-lock ms-1"></i></label>
                                    <input type="email"
                                        class="form-control rounded-0 border-secondary"
                                        style="background-color:#1a1a1a; color:#ffffff;"
                                        value="<%= locals.user ? user.email : '' %>" readonly>
                                </div>
                            </div>
                        </div>

                        <!-- REFERRAL CODE CARD -->
                        <div class="section-card p-4 bg-dark border border-secondary mb-4"
                             style="border-top:3px solid #FFD700;">
                            <div class="section-title text-uppercase fw-bold mb-3 border-start border-4 ps-3"
                                 style="border-color:#FFD700 !important; color:#FFD700;">
                                <i class="fas fa-ticket-alt me-2"></i>Your Referral Code
                            </div>
                            <p class="text-white-50 small mb-3">
                                Share this code with friends. When they sign up using it, you receive
                                <strong class="text-warning">$20</strong> in your wallet automatically.
                            </p>
                            <div class="d-flex align-items-center gap-3 flex-wrap">
                                <div class="px-4 py-2 fw-bold"
                                     style="background:#111; border:2px dashed #FFD700; color:#FFD700; font-family:monospace; font-size:1.4rem; letter-spacing:4px;">
                                    <%= user.referralCode || 'Not assigned yet' %>
                                </div>
                                <% if (user.referralCode) { %>
                                    <button type="button"
                                        class="btn btn-outline-warning rounded-0 fw-semibold px-3"
                                        onclick="copyReferralCode('<%= user.referralCode %>')"
                                        id="copyBtn">
                                        <i class="fas fa-copy me-2"></i>Copy Code
                                    </button>
                                    <button type="button"
                                        class="btn rounded-0 fw-semibold px-3"
                                        style="background:#FFD700; color:#000; border:none;"
                                        onclick="shareReferralLink('<%= user.referralCode %>')">
                                        <i class="fas fa-share-alt me-2"></i>Share Link
                                    </button>
                                <% } %>
                            </div>
                            <% if (user.referredBy) { %>
                                <p class="text-white-50 small mt-3 mb-0">
                                    <i class="fas fa-user-friends me-1 text-warning"></i>
                                    You joined using referral code <code class="text-warning"><%= user.referredBy %></code>
                                </p>
                            <% } %>
                        </div>

                        <% if (locals.query && query.emailUpdated) { %>
                          <div class="alert alert-success rounded-0 small mb-3">
                            <i class="fas fa-check-circle me-2"></i>Your email address has been updated successfully.
          </div>
                        <% } %>
                        <div class="d-flex gap-3">
                            <a href="/profile/edit" class="btn btn-danger rounded-0 fw-bold px-4">EDIT PROFILE</a>
                            <a href="/profile/address" class="btn btn-outline-warning rounded-0 fw-bold px-4">MANAGE ADDRESSES</a>
                        </div>

<script>
function copyReferralCode(code) {
    navigator.clipboard.writeText(code).then(() => {
        const btn = document.getElementById('copyBtn');
        const orig = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-check me-2"></i>Copied!';
        btn.classList.replace('btn-outline-warning', 'btn-warning');
        setTimeout(() => {
            btn.innerHTML = orig;
            btn.classList.replace('btn-warning', 'btn-outline-warning');
        }, 2000);
    });
}
function shareReferralLink(code) {
    const url = `${window.location.origin}/signup?ref=${code}`;
    if (navigator.share) {
        navigator.share({ title: 'Join Comizon!', text: 'Use my referral code to sign up and I get $20!', url });
    } else {
        navigator.clipboard.writeText(url).then(() => alert('Referral link copied to clipboard!'));
    }
}
</script>
                    </div>
                </div>
            </div>

            <%- include('../../partials/footer') %>
    </body>

    </html>
