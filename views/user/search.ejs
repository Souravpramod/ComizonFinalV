<%
  const products        = Array.isArray(locals.products)           ? locals.products           : [];
  const totalProducts   = typeof locals.totalProducts === 'number' ? locals.totalProducts       : products.length;
  const totalPages      = typeof locals.totalPages    === 'number' ? locals.totalPages          : 1;
  const currentPage     = typeof locals.currentPage   === 'number' ? locals.currentPage         : 1;
  const activeCategory  = typeof locals.activeCategory === 'string' ? locals.activeCategory     : 'all';
  const sort            = typeof locals.sort           === 'string' ? locals.sort               : 'featured';
  const search          = typeof locals.search         === 'string' ? locals.search             : '';
  const dbCats          = Array.isArray(locals.dbCategories)        ? locals.dbCategories        : [];
  const relevantIds     = Array.isArray(locals.relevantCategoryIds) ? locals.relevantCategoryIds : [];
  const relevantSet     = new Set(relevantIds.map(String));

  // Pills: All + every active category
  // When searching, only show categories that have results; when not searching, show all non-premium active ones
  // Only show categories that are in relevantSet when searching.
  // When not searching, dbCats is already pre-filtered to active+non-premium by controller.
  // Either way, never show a category that isn't in dbCats.
  const categories = [
    { key: 'all', label: 'All', isRelevant: true },
    ...dbCats
      .filter(c => {
        const id = c._id ? c._id.toString() : '';
        // If searching: only show if relevant. If not searching: show all dbCats (already safe).
        return !search || relevantSet.has(id);
      })
      .map(c => ({
        key:        c._id.toString(),
        label:      c.categoryName,
        isRelevant: true,
      }))
  ];
%>

<%- include('../partials/user-head', { title: 'Search' }) %>

<body class="bg-black text-light">
  <%- include('../partials/header') %>

  <!-- SEARCH HERO BANNER -->
  <header class="d-flex align-items-center border-bottom border-danger"
    style="height:220px; background: linear-gradient(135deg,#0d0d0d 60%,#1a0505); margin-top:76px;">
    <div class="container">
      <h1 class="display-4 fw-bold text-uppercase mb-2">
        <i class="fas fa-search text-danger me-3"></i>Search
        <% if (search) { %>
          <span class="text-danger fs-3 fw-normal ms-2">"<%= search %>"</span>
        <% } %>
      </h1>
      <p class="text-white-50 mb-0">
        <% if (search) { %>
          Found <strong class="text-white"><%= totalProducts %></strong> result<%= totalProducts !== 1 ? 's' : '' %> across all categories
        <% } else { %>
          Browse all products or type something to search
        <% } %>
      </p>
    </div>
  </header>

  

  <!-- MAIN CONTENT -->
  <section class="container py-5">
    <div class="row">

      <!-- ── Sidebar ────────────────────────────────────────────────────── -->
      <aside class="col-lg-3 mb-4">
        <div class="filter-card bg-dark p-4 rounded-0 border border-secondary">

          <h4 class="text-uppercase fw-bold mb-4">
            <i class="fas fa-filter text-danger me-2"></i>Categories
          </h4>

          <ul class="list-unstyled category-list">
            <% categories.forEach(cat => { %>
              <li>
                <a href="/search?category=<%= cat.key %>&page=1&sort=<%= sort %>&search=<%= encodeURIComponent(search) %>"
                   class="<%= activeCategory === cat.key ? 'active' : '' %>"
                   style="<%= (!cat.isRelevant && search && cat.key !== 'all') ? 'opacity:0.45;' : '' %>">
                  <%= cat.label %>
                  <% if (search && cat.isRelevant && cat.key !== 'all') { %>
                    <i class="fas fa-circle text-danger ms-1" style="font-size:.45rem;vertical-align:middle;"></i>
                  <% } %>
                </a>
              </li>
            <% }) %>
          </ul>

          <hr class="border-secondary my-4">

          <!-- Search box -->
          <h5 class="fw-bold mb-3">Search</h5>
          <form action="/search" method="GET" id="search-form">
            <input type="hidden" name="category" value="<%= activeCategory %>">
            <input type="hidden" name="sort"     value="<%= sort %>">
            <input type="hidden" name="page"     value="1">
            <div class="input-group">
              <input type="text"
                     class="form-control bg-black text-light border-secondary rounded-0 shadow-none"
                     id="search-input"
                     name="search"
                     placeholder="Search products..."
                     value="<%= search %>">
              <button class="btn btn-danger rounded-0" type="submit">
                <i class="fas fa-search"></i>
              </button>
            </div>
          </form>

          <hr class="border-secondary my-4">

          <!-- Price range -->
          <h5 class="fw-bold mb-3">Price Range</h5>
          <form action="/search" method="GET" id="price-form">
            <input type="hidden" name="category" value="<%= activeCategory %>">
            <input type="hidden" name="sort"     value="<%= sort %>">
            <input type="hidden" name="search"   value="<%= search %>">
            <input type="hidden" name="page"     value="1">

            <div class="mb-2">
              <input type="range"
                     class="form-range"
                     id="price-range"
                     name="maxPrice"
                     min="0" max="1000" step="5"
                     value="<%= typeof locals.maxPrice !== 'undefined' ? locals.maxPrice : 1000 %>"
                     oninput="document.getElementById('priceValue').innerText=this.value">
            </div>
            <div class="d-flex justify-content-between text-white small mb-3">
              <span>$0</span>
              <span>$<span id="priceValue"><%= typeof locals.maxPrice !== 'undefined' ? locals.maxPrice : 1000 %></span></span>
            </div>
            <button class="btn btn-danger btn-sm w-100">Apply</button>
          </form>

        </div>
      </aside>

      <!-- ── Product Grid ───────────────────────────────────────────────── -->
      <main class="col-lg-9">

        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-secondary pb-3">
          <h2 class="text-white fw-bold text-uppercase border-start border-4 border-danger ps-3 mb-0">
            <% if (search) { %>
              Results
              <span class="text-white fs-6 ms-2 text-lowercase fw-normal">"<%= search %>"</span>
            <% } else { %>
              All Products
            <% } %>
            <% if (activeCategory !== 'all') { %>
              <span class="text-danger ms-2 fs-5">—
                <%= categories.find(c => c.key === activeCategory)?.label || activeCategory %>
              </span>
            <% } %>
          </h2>

          <div class="d-flex align-items-center gap-3">
            <span class="text-white small" id="showing-count">
              Showing <%= products.length %> of <%= totalProducts %>
            </span>
            <select class="form-select form-select-sm bg-black text-light border-secondary rounded-0 shadow-none"
                    id="sort-select">
              <option value="featured" <%= sort === 'featured' ? 'selected' : '' %>>Sort: Featured</option>
              <option value="az"       <%= sort === 'az'       ? 'selected' : '' %>>A–Z</option>
              <option value="za"       <%= sort === 'za'       ? 'selected' : '' %>>Z–A</option>
              <option value="low"      <%= sort === 'low'      ? 'selected' : '' %>>Price: Low–High</option>
              <option value="high"     <%= sort === 'high'     ? 'selected' : '' %>>Price: High–Low</option>
            </select>
          </div>
        </div>

        <!-- Product cards -->
        <div class="row g-4" id="product-grid">
          <% if (products.length > 0) { %>
            <% products.forEach(p => { %>
              <div class="col-md-4" data-product-id="<%= p._id %>">
                <div class="card product-card h-100 bg-transparent border border-secondary rounded-0"
                     onclick="location.href='/product/<%= p._id %>'" style="cursor:pointer;">
                  <div class="card-img-wrapper position-relative overflow-hidden">
                    <img src="<%= p.image %>"
                         onerror="this.src='https://placehold.co/300x450/1a1a1a/E63946?text=No+Image'"
                         class="card-img-top" alt="<%= p.name %>">
                    <% const inWishlist = (locals.wishlistIds || []).includes(p._id.toString()); %>
                    <form action="/wishlist/add/<%= p._id %>" method="POST" onclick="event.stopPropagation()">
                      <button type="submit"
                              class="btn btn-light btn-sm position-absolute top-0 end-0 m-2 rounded-circle wishlist-btn"
                              title="<%= inWishlist ? 'In Wishlist' : 'Add to Wishlist' %>">
                        <i class="<%= inWishlist ? 'fas' : 'far' %> fa-heart text-danger"></i>
                      </button>
                    </form>
                    <% if (p.badge) { %>
                      <span class="badge <%= p.badge === 'PREMIUM' ? 'bg-warning text-dark' : 'bg-danger' %> position-absolute top-0 start-0 m-2 rounded-0">
                        <%= p.badge %>
                      </span>
                    <% } %>
                  </div>
                  <div class="card-body">
                    <div class="text-white small mb-1"><%= p.category %></div>
                    <h5 class="card-title fw-bold text-truncate text-white" data-product-name><%= p.name %></h5>
                    <div class="d-flex align-items-center mb-2">
                      <% const full = Math.floor(p.rating || 0);
                         const half = (p.rating || 0) % 1 >= 0.25 && (p.rating || 0) % 1 < 0.75; %>
                      <div class="text-warning small me-2">
                        <% for (let i = 0; i < full; i++) { %><i class="fas fa-star"></i><% } %>
                        <% if (half) { %><i class="fas fa-star-half-alt"></i><% } %>
                        <% for (let i = 0; i < (5 - full - (half ? 1 : 0)); i++) { %><i class="far fa-star"></i><% } %>
                      </div>
                      <span class="text-white small">(<%= p.reviews || 0 %>)</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                      <div>
                        <% const hasOff = p.effectivePrice && p.effectivePrice < p.price; %>
                        <div class="text-white-50 text-decoration-line-through"
                             data-original-price
                             style="font-size:.8rem; line-height:1.2; <%= hasOff ? '' : 'display:none;' %>">
                          $<%= Number(p.price).toFixed(2) %>
                        </div>
                        <h4 class="mb-0 text-white"
                            data-price
                            data-effective-price="<%= hasOff ? p.effectivePrice : p.price %>">
                          $<%= Number(hasOff ? p.effectivePrice : p.price).toFixed(2) %>
                        </h4>
                        <div class="mt-1">
                          <span class="fw-bold"
                                data-offer-badge
                                style="font-size:.72rem; color:<%= p.badgeColorListing || '#E63946' %>; <%= hasOff ? '' : 'display:none;' %>">
                            <% if (hasOff) { %><i class="fas fa-tag me-1"></i><%= p.offerBadge %><% } %>
                          </span>
                        </div>
                      </div>
                      <form action="/cart/add/<%= p._id %>" method="POST" onclick="event.stopPropagation()">
                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-0" data-add-cart-btn>
                          <i class="fas fa-cart-plus"></i> Add
                        </button>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="col-12 text-center py-5">
              <i class="fas fa-search fa-3x text-secondary mb-3"></i>
              <p class="text-white fs-5">
                <% if (search) { %>
                  No products found for "<strong class="text-white"><%= search %></strong>"
                <% } else { %>
                  No products available.
                <% } %>
              </p>
              <% if (search) { %>
                <a href="/search" class="btn btn-outline-danger rounded-0 mt-2">Clear Search</a>
              <% } %>
            </div>
          <% } %>
        </div>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
          <nav aria-label="Page navigation" class="mt-5 d-flex justify-content-center" id="pagination-wrap">
            <ul class="pagination">
              <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                <a class="page-link bg-dark text-white border-secondary"
                   href="/search?page=<%= currentPage - 1 %>&category=<%= activeCategory %>&sort=<%= sort %>&search=<%= encodeURIComponent(search) %>"
                   data-page="<%= currentPage - 1 %>"
                   <%= currentPage === 1 ? 'tabindex="-1" aria-disabled="true"' : '' %>>Previous</a>
              </li>
              <% for (let i = 1; i <= totalPages; i++) { %>
                <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                  <a class="page-link <%= i === currentPage ? 'bg-danger text-white border-danger' : 'bg-dark text-white border-secondary hover-danger' %>"
                     href="/search?page=<%= i %>&category=<%= activeCategory %>&sort=<%= sort %>&search=<%= encodeURIComponent(search) %>"
                     data-page="<%= i %>">
                    <%= i %>
                  </a>
                </li>
              <% } %>
              <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                <a class="page-link bg-dark text-white border-secondary"
                   href="/search?page=<%= currentPage + 1 %>&category=<%= activeCategory %>&sort=<%= sort %>&search=<%= encodeURIComponent(search) %>"
                   data-page="<%= currentPage + 1 %>"
                   <%= currentPage === totalPages ? 'tabindex="-1" aria-disabled="true"' : '' %>>Next</a>
              </li>
            </ul>
          </nav>
        <% } %>

      </main>
    </div>
  </section>

  <%- include('../partials/footer') %>

  <script>
    window.LISTING_BASE  = '/search';
    window.LISTING_STATE = {
      category : '<%= activeCategory %>',
      sort     : '<%= sort %>',
      search   : '<%= search %>',
      minPrice : <%= typeof locals.minPrice !== 'undefined' ? locals.minPrice : 0 %>,
      maxPrice : <%= typeof locals.maxPrice !== 'undefined' ? locals.maxPrice : 1000 %>,
      page     : <%= currentPage %>
    };
  </script>
  <script src="/js/user/listing-ajax.js"></script>
  <%- include('../partials/offer-poller') %>

</body>
</html>
