<%
  /* ── locals ─────────────────────────────────────────────── */
  const p               = locals.product || {};
  const status          = locals.status  || 'available';
  const discount        = locals.discount || 0;
  const originalPrice   = locals.originalPrice || null;
  const listingUrl      = locals.listingUrl || '/';
  const recs            = Array.isArray(locals.recommendations) ? locals.recommendations : [];
  const reviews         = Array.isArray(locals.reviews) ? locals.reviews : [];
 const reviewTotal     = locals.reviewTotal || 0;
  const listingLabel    = locals.listingLabel  || 'Home';
  const categoryUrl     = locals.categoryUrl   || listingUrl;
  const reviewPages     = locals.reviewPages || 1;
  const reviewPage      = locals.reviewPage  || 1;
  const ratingBreakdown = Array.isArray(locals.ratingBreakdown) ? locals.ratingBreakdown : [];
  const userHasReviewed = locals.userHasReviewed || false;
  const isLoggedIn      = locals.isLoggedIn      || false;
  const avg             = p.reviewStat?.averageRating || 0;
  const totalReviews    = p.reviewStat?.totalReviews  || 0;
  const catName         = p.categoryId?.categoryName  || '';
  const isOutOfStock    = status === 'outofstock';
  const isLowStock      = status === 'low';

  /* star helper */
  function stars(rating, size = '') {
    const full  = Math.floor(rating);
    const half  = rating % 1 >= 0.25 && rating % 1 < 0.75;
    const empty = 5 - full - (half ? 1 : 0);
    let html = '';
    for (let i = 0; i < full;  i++) html += `<i class="fas fa-star text-warning ${size}"></i>`;
    if (half)                        html += `<i class="fas fa-star-half-alt text-warning ${size}"></i>`;
    for (let i = 0; i < empty; i++) html += `<i class="far fa-star text-warning ${size}"></i>`;
    return html;
  }
%>

<%- include('../partials/user-head', { title: p.productName || 'Product' }) %>
<style>
.thumb-img {
  width: 70px;
  height: 90px;
  object-fit: cover;
  cursor: pointer;
  opacity: 0.7;
  transition: 0.2s;
}

.thumb-img:hover {
  opacity: 1;
  border: 1px solid #E63946;
}
</style>

<body class="bg-black text-light">
<%- include('../partials/header') %>

<div style="margin-top:76px;">

<!-- ── BREADCRUMB ─────────────────────────────────────────── -->
  <div style="background:#0d0d0d; border-bottom:1px solid #333;" class="py-2">
    <div class="container">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0 small" style="--bs-breadcrumb-divider-color:#666;">

          <%# Crumb 1 — the listing page (Home / American Comics / Manga / Toys) %>
          <li class="breadcrumb-item">
            <a href="<%= listingUrl %>" class="text-white text-decoration-none"><%= listingLabel %></a>
          </li>

          <%# Crumb 2 — the specific category, pre-filtered URL %>
          <% if (catName) { %>
            <li class="breadcrumb-item">
              <a href="<%= categoryUrl %>" class="text-white text-decoration-none"><%= catName %></a>
            </li>
          <% } %>

          <%# Crumb 3 — current product (not a link) %>
          <li class="breadcrumb-item active text-white" aria-current="page"
    style="max-width:260px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"
    title="<%= p.productName %>">
  <%= p.productName %>
</li>

        </ol>
      </nav>
    </div>
  </div>

  <!-- ── STOCK ALERT BANNER ──────────────────────────────────── -->
  <% if (isOutOfStock) { %>
    <div class="alert alert-danger rounded-0 mb-0 border-0 py-2 text-center small fw-bold" role="alert"
         style="background:rgba(230,57,70,0.15); border-bottom:2px solid #E63946 !important;">
      <i class="fas fa-exclamation-triangle me-2"></i>
      This item is currently out of stock. You can still browse or check back later.
    </div>
  <% } else if (isLowStock) { %>
    <div class="alert alert-warning rounded-0 mb-0 border-0 py-2 text-center small fw-bold text-dark" role="alert"
         style="background:#ffc107;">
      <i class="fas fa-fire me-2"></i>
      Only <%= p.stockQuantity %> left in stock — order soon!
    </div>
  <% } %>

  <!-- ── MAIN PRODUCT SECTION ───────────────────────────────── -->
  <section class="container py-5">
    <div class="row g-5">

      <!-- LEFT: Multi Image (3 vertical + zoom) -->
<div class="col-lg-5">
  <div class="d-flex gap-3">

    <!-- Thumbnails (LEFT) -->
    <div class="d-flex flex-column gap-2">
      <% 
        const imgs = (p.images && p.images.length > 0)
          ? p.images
          : [
              'https://placehold.co/500x700/1a1a1a/E63946?text=No+Image',
              'https://placehold.co/500x700/1a1a1a/E63946?text=No+Image',
              'https://placehold.co/500x700/1a1a1a/E63946?text=No+Image'
            ];

        const img1 = imgs[0] || imgs[0];
        const img2 = imgs[1] || imgs[0];
        const img3 = imgs[2] || imgs[0];
      %>

      <img src="<%= img1 %>" class="thumb-img border border-secondary" onclick="changeImage('<%= img1 %>')">
      <img src="<%= img2 %>" class="thumb-img border border-secondary" onclick="changeImage('<%= img2 %>')">
      <img src="<%= img3 %>" class="thumb-img border border-secondary" onclick="changeImage('<%= img3 %>')">
    </div>

    <!-- Main Image -->
    <div class="flex-grow-1 border border-secondary position-relative overflow-hidden"
         style="background:#111; cursor:zoom-in;"
         id="zoom-container">

      <!-- Badge -->
      <% if (p.isPremium) { %>
        <span class="badge bg-warning text-dark position-absolute top-0 start-0 m-3 rounded-0 fw-bold"
              style="z-index:2; font-size:0.75rem; letter-spacing:1px;">PREMIUM</span>
      <% } else if (isLowStock) { %>
        <span class="badge bg-danger position-absolute top-0 start-0 m-3 rounded-0 fw-bold"
              style="z-index:2; font-size:0.75rem; letter-spacing:1px;">HOT</span>
      <% } %>

      <% if (isOutOfStock) { %>
        <div class="position-absolute w-100 h-100 d-flex align-items-center justify-content-center"
             style="z-index:3; background:rgba(0,0,0,0.6);">
          <span class="text-white fw-bold text-uppercase fs-4"
                style="border:2px solid #E63946; padding:8px 24px; letter-spacing:2px;">
            Out of Stock
          </span>
        </div>
      <% } %>

      <img id="zoom-img"
           src="<%= img1 %>"
           onerror="this.src='https://placehold.co/500x700/1a1a1a/E63946?text=No+Image'"
           alt="<%= p.productName %>"
           class="w-100"
           style="height:520px; object-fit:cover; transition:transform 0.3s ease; display:block;">
    </div>

  </div>

  <p class="text-white small mt-2 text-center">
    <i class="fas fa-search-plus me-1"></i>Hover to zoom
  </p>

  <!-- DESCRIPTION — inside left col, below image -->
  <div class="mt-4 p-4 border border-secondary rounded-0" style="background:#111; border-left:4px solid #E63946 !important;">
    <h6 class="text-uppercase fw-bold text-white mb-3"
        style="letter-spacing:1.5px; font-size:0.8rem;">
      <i class="fas fa-align-left me-2 text-danger"></i>Description
    </h6>
    <% if (p.description && p.description.trim().length > 0) { %>
      <p class="text-white-50 lh-lg mb-0" style="font-size:0.95rem;">
        <%= p.description %>
      </p>
    <% } else { %>
      <p class="text-white mb-1" style="font-size:0.9rem;">
        <i class="fas fa-clock me-2 text-danger"></i>Description not yet added — coming soon.
      </p>
    <% } %>
  </div>

</div>

     
      <!-- RIGHT: Product Info -->
      <div class="col-lg-7">

        <!-- Category + SKU -->
        <div class="d-flex align-items-center gap-3 mb-2">
          <% if (catName) { %>
            <span class="text-danger small fw-bold text-uppercase" style="letter-spacing:1px;"><%= catName %></span>
          <% } %>
          <% if (p.sku) { %>
            <span class="text-white small">SKU: <%= p.sku %></span>
          <% } %>
        </div>

        <!-- Title -->
        <h1 class="fw-bold text-white mb-1" style="font-family:'Anton',sans-serif; font-size:2.2rem; line-height:1.1;">
          <%= p.productName %>
        </h1>

        <!-- Author -->
        <% if (p.author) { %>
          <p class="text-white mb-3">By <span class="text-white-50"><%= p.author %></span></p>
        <% } %>

        <!-- Rating row -->
        <div class="d-flex align-items-center gap-3 mb-4">
          <div><%- stars(avg) %></div>
          <span class="text-warning fw-bold"><%= avg.toFixed(1) %></span>
          <a href="#reviews" class="text-white small text-decoration-none">
            (<%= totalReviews %> <%= totalReviews === 1 ? 'Review' : 'Reviews' %>)
          </a>
          <% if (!userHasReviewed && isLoggedIn) { %>
            <a href="/product/<%= p._id %>/review"
               class="btn btn-outline-light btn-sm rounded-0 ms-auto"
               style="font-size:0.75rem; letter-spacing:0.5px;">
              <i class="fas fa-pen me-1"></i> Write a Review
            </a>
          <% } %>
        </div>

        <!-- Price block -->
        <div class="mb-4">
          <div class="d-flex align-items-center gap-3">
            <span class="fw-bold text-white" style="font-size:2.2rem;">
              $<%= Number(p.price).toFixed(2) %>
            </span>
            <% if (originalPrice) { %>
              <span class="text-white text-decoration-line-through fs-5">$<%= originalPrice.toFixed(2) %></span>
              <span class="badge bg-danger rounded-0 fw-bold" style="font-size:0.8rem;">SAVE <%= discount %>%</span>
            <% } %>
          </div>
          <% if (p.isPremium) { %>
            <small class="text-warning"><i class="fas fa-crown me-1"></i>Premium exclusive pricing</small>
          <% } %>
        </div>

        <!-- Add to Cart / Wishlist -->
        
            <div class="d-flex gap-3 mb-4">
              <% if (!isOutOfStock) { %>

                <form action="/cart/add/<%= p._id %>" method="POST" class="flex-grow-1">
                  <button type="submit"
                          class="btn btn-danger btn-lg rounded-0 fw-bold w-100"
                          style="letter-spacing:1px;">
                    <i class="fas fa-shopping-cart me-2"></i>ADD TO CART
                  </button>
                </form>
          <% } else { %>
            <button class="btn btn-secondary btn-lg rounded-0 fw-bold flex-grow-1" disabled
                    style="letter-spacing:1px;">
              <i class="fas fa-ban me-2"></i>OUT OF STOCK
            </button>
          <% } %>
          <form action="/wishlist/add/<%= p._id %>" method="POST" onclick="event.stopPropagation()">
            <button type="submit"
                    class="btn btn-outline-light btn-lg rounded-0"
                    title="Add to Wishlist">
              <i class="far fa-heart text-danger"></i>
            </button>
          </form>
        </div>

        <!-- Delivery -->
        <div class="border border-secondary p-3 mb-4 rounded-0" style="background:#111;">
          <h6 class="text-uppercase fw-bold mb-3 small" style="letter-spacing:1px;">
            <i class="fas fa-truck text-danger me-2"></i>Delivery Options
          </h6>
          <div class="input-group input-group-sm">
            <input type="text" class="form-control bg-black text-light border-secondary rounded-0"
                   placeholder="Enter pincode..." id="pincode-input">
            <button class="btn btn-outline-danger rounded-0" onclick="checkDelivery()">Check</button>
          </div>
          <div id="delivery-result" class="mt-2"></div>
          <p class="text-white small mb-0 mt-2">
            <i class="fas fa-tag text-danger me-1"></i> Free delivery over $35
          </p>
        </div>

        <!-- Product Highlights -->
        <div class="border border-secondary p-3 mb-4 rounded-0" style="background:#111;">
          <h6 class="text-uppercase fw-bold mb-3 small" style="letter-spacing:1px;">
            <i class="fas fa-list text-danger me-2"></i>Product Highlights
          </h6>
          <ul class="list-unstyled mb-0 small text-white-50">
            <% if (p.publisher) { %><li class="mb-1"><i class="fas fa-check text-danger me-2"></i>Publisher: <span class="text-white"><%= p.publisher %></span></li><% } %>
            <% if (p.author)    { %><li class="mb-1"><i class="fas fa-check text-danger me-2"></i>Author: <span class="text-white"><%= p.author %></span></li><% } %>
            <li class="mb-1"><i class="fas fa-check text-danger me-2"></i>Language: <span class="text-white">English</span></li>
            <li class="mb-1"><i class="fas fa-check text-danger me-2"></i>Format: <span class="text-white">Trade Paperback</span></li>
            <% if (p.isPremium) { %><li class="mb-1"><i class="fas fa-crown text-warning me-2"></i><span class="text-warning">Premium Collector's Edition</span></li><% } %>
            <li class="mb-1">
              <i class="fas fa-<%= isOutOfStock ? 'times-circle text-danger' : (isLowStock ? 'exclamation-circle text-warning' : 'check-circle text-success') %> me-2"></i>
              <span class="<%= isOutOfStock ? 'text-danger' : (isLowStock ? 'text-warning' : 'text-success') %>">
                <%= isOutOfStock ? 'Out of Stock' : (isLowStock ? `Only ${p.stockQuantity} left` : 'In Stock') %>
              </span>
            </li>
          </ul>
        </div>

        <!-- Overview -->
        <% if (p.description) { %>
          <div class="mb-4">
            <h5 class="text-uppercase fw-bold mb-3 border-start border-3 border-danger ps-3" style="font-size:0.9rem; letter-spacing:1px;">Overview</h5>
            <p class="text-white-50 small lh-lg"><%= p.description %></p>
          </div>
        <% } %>

        <!-- Product Details Table -->
        <div>
          <h5 class="text-uppercase fw-bold mb-3 border-start border-3 border-danger ps-3" style="font-size:0.9rem; letter-spacing:1px;">Product Details</h5>
          <table class="table table-sm table-dark table-borderless small" style="background:transparent;">
            <tbody>
              <% if (p.publisher) { %><tr><td class="text-danger" style="width:120px;">Publisher</td><td class="text-white"><%= p.publisher %></td></tr><% } %>
              <tr><td class="text-danger">Language</td><td class="text-white">English</td></tr>
              <tr><td class="text-danger">Format</td><td class="text-white">Trade Paperback</td></tr>
              <% if (p.sku) { %><tr><td class="text-danger">ISBN / SKU</td><td class="text-white"><%= p.sku %></td></tr><% } %>
              <% if (p.categoryId?.categoryName) { %><tr><td class="text-danger">Category</td><td class="text-white"><%= p.categoryId.categoryName %></td></tr><% } %>
            </tbody>
          </table>
        </div>

      </div><!-- /col right -->
    </div><!-- /row -->
  </section>

  <!-- ── RATINGS & REVIEWS ───────────────────────────────────── -->
  <section class="container py-4" id="reviews">
    <div class="border-top border-secondary pt-5 mb-5">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-uppercase border-start border-4 border-danger ps-3 mb-0" style="font-size:1.2rem; letter-spacing:1px;">
          Customer Reviews
        </h3>
        <% if (!userHasReviewed && isLoggedIn) { %>
          <a href="/product/<%= p._id %>/review" class="btn btn-outline-danger btn-sm rounded-0 fw-bold">
            <i class="fas fa-pen me-1"></i> Write a Review
          </a>
        <% } else if (!isLoggedIn) { %>
          <a href="/login" class="btn btn-outline-secondary btn-sm rounded-0">Login to Review</a>
        <% } %>
      </div>

      <div class="row g-4">
        <!-- Rating Summary -->
        <div class="col-lg-3">
          <div class="text-center border border-secondary p-4 rounded-0" style="background:#111;">
            <div class="display-3 fw-bold text-white mb-1"><%= avg.toFixed(1) %></div>
            <div class="mb-2"><%- stars(avg) %></div>
            <div class="text-white small"><%= totalReviews %> <%= totalReviews === 1 ? 'review' : 'reviews' %></div>
          </div>
          <!-- Star breakdown -->
          <div class="mt-3">
            <% ratingBreakdown.forEach(r => { %>
              <div class="d-flex align-items-center gap-2 mb-1 small">
                <span class="text-white" style="min-width:14px;"><%= r.star %></span>
                <i class="fas fa-star text-warning" style="font-size:0.7rem;"></i>
                <div class="flex-grow-1 bg-dark rounded-0" style="height:6px;">
                  <div class="bg-warning rounded-0" style="height:100%; width:<%= r.pct %>%;"></div>
                </div>
                <span class="text-white" style="min-width:28px;"><%= r.pct %>%</span>
              </div>
            <% }) %>
          </div>
        </div>

        <!-- Review List -->
        <div class="col-lg-9">
          <% if (reviews.length > 0) { %>
            <% reviews.forEach(r => { %>
              <div class="border border-secondary p-4 rounded-0 mb-3" style="background:#111;">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <div>
                    <div class="mb-1"><%- stars(r.rating) %></div>
                    <% if (r.title) { %>
                      <strong class="text-white"><%= r.title %></strong>
                    <% } %>
                  </div>
                  <small class="text-white"><%= new Date(r.createdAt).toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' }) %></small>
                </div>
                <p class="text-white-50 small mb-1 lh-lg"><%= r.body || '' %></p>
                <small class="text-white">
                  — <%= r.userId?.name || r.userId?.email?.split('@')[0] || 'Anonymous' %>
                </small>
              </div>
            <% }) %>

            <!-- Review Pagination -->
            <% if (reviewPages > 1) { %>
              <nav class="mt-3">
                <ul class="pagination pagination-sm">
                  <% for (let i = 1; i <= reviewPages; i++) { %>
                    <li class="page-item <%= i === reviewPage ? 'active' : '' %>">
                      <a class="page-link rounded-0 bg-dark text-white border-secondary <%= i === reviewPage ? 'bg-danger border-danger' : '' %>"
                         href="/product/<%= p._id %>?reviewPage=<%= i %>#reviews"><%= i %></a>
                    </li>
                  <% } %>
                </ul>
              </nav>
            <% } %>
          <% } else { %>
            <div class="border border-secondary p-5 text-center rounded-0" style="background:#111;">
              <i class="far fa-comment-alt text-white mb-3" style="font-size:2rem;"></i>
              <p class="text-white mb-3">No reviews yet. Be the first to share your thoughts!</p>
              <% if (isLoggedIn && !userHasReviewed) { %>
                <a href="/product/<%= p._id %>/review" class="btn btn-danger rounded-0 btn-sm fw-bold">
                  <i class="fas fa-pen me-1"></i> Write a Review
                </a>
              <% } else if (!isLoggedIn) { %>
                <a href="/login" class="btn btn-outline-secondary rounded-0 btn-sm">Login to Review</a>
              <% } %>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </section>

  <!-- ── RECOMMENDATIONS ────────────────────────────────────── -->
  <% if (recs.length > 0) { %>
    <section style="background:#0d0d0d; border-top:1px solid #333;" class="py-5">
      <div class="container">
        <h3 class="fw-bold text-uppercase mb-4" style="font-family:'Anton',sans-serif; letter-spacing:1px;">
          You May Also <span class="text-danger">Like</span>
        </h3>
        <div class="row g-3">
          <% recs.forEach(r => { %>
            <div class="col-6 col-md-3">
  <div class="card product-card h-100 bg-transparent border border-secondary rounded-0"
       onclick="location.href='/product/<%= r._id %>'" style="cursor:pointer;">

    <div class="card-img-wrapper position-relative overflow-hidden">

      <!-- Image -->
      <img src="<%= r.image %>"
           onerror="this.src='https://placehold.co/300x450/1a1a1a/E63946?text=No+Image'"
           class="card-img-top" alt="<%= r.name %>">

      <!-- Wishlist -->
      <form action="/wishlist/add/<%= r._id %>" method="POST" onclick="event.stopPropagation()">
        <button type="submit"
                class="btn btn-light btn-sm position-absolute top-0 end-0 m-2 rounded-circle"
                title="Add to Wishlist">
          <i class="far fa-heart text-danger"></i>
        </button>
      </form>

      <!-- Badge -->
      <% if (r.badge) { %>
        <span class="badge <%= r.badge==='PREMIUM' ? 'bg-warning text-dark' : 'bg-danger' %>
                     position-absolute top-0 start-0 m-2 rounded-0">
          <%= r.badge %>
        </span>
      <% } %>

    </div>

    <div class="card-body">

      <!-- Category -->
      <div class="text-white small mb-1"><%= r.category %></div>

      <!-- Title -->
      <h5 class="card-title fw-bold text-truncate text-white">
        <%= r.name %>
      </h5>

      <!-- Rating -->
      <div class="d-flex align-items-center mb-2">
        <% 
          const full = Math.floor(r.rating || 0);
          const half = (r.rating || 0) % 1 >= 0.25 && (r.rating || 0) % 1 < 0.75;
        %>
        <div class="text-warning small me-2">
          <% for(let i=0;i<full;i++){ %><i class="fas fa-star"></i><% } %>
          <% if(half){ %><i class="fas fa-star-half-alt"></i><% } %>
          <% for(let i=0;i<(5-full-(half?1:0));i++){ %><i class="far fa-star"></i><% } %>
        </div>
        <span class="text-white small">(<%= r.reviews || 0 %>)</span>
      </div>

      <!-- Price + Cart -->
      <div class="d-flex justify-content-between align-items-center mt-3">
        <h4 class="text-white mb-0">$<%= Number(r.price).toFixed(2) %></h4>

        <form action="/cart/add/<%= r._id %>" method="POST" onclick="event.stopPropagation()">
          <button type="submit" class="btn btn-outline-danger btn-sm rounded-0">
            <i class="fas fa-cart-plus"></i> Add
          </button>
        </form>
      </div>

    </div>
  </div>
</div>
          <% }) %>
        </div>
      </div>
    </section>
  <% } %>

</div><!-- /margin-top -->

<%- include('../partials/footer') %>

<script>
/* ── Zoom on hover ────────────────────────────────── */
const container = document.getElementById('zoom-container');
const img       = document.getElementById('zoom-img');
if (container && img) {
  container.addEventListener('mousemove', e => {
    const rect = container.getBoundingClientRect();
    const x = ((e.clientX - rect.left) / rect.width)  * 100;
    const y = ((e.clientY - rect.top)  / rect.height) * 100;
    img.style.transformOrigin = `${x}% ${y}%`;
    img.style.transform = 'scale(2)';
  });
  container.addEventListener('mouseleave', () => {
    img.style.transform = 'scale(1)';
    img.style.transformOrigin = 'center center';
  });
}

/* ── Delivery check ────────────────────────────────── */
function checkDelivery() {
  const pin    = document.getElementById('pincode-input').value.trim();
  const result = document.getElementById('delivery-result');
  if (!pin || pin.length < 5) {
    result.innerHTML = '<small class="text-danger">Please enter a valid pincode.</small>';
    return;
  }
  result.innerHTML = '<small class="text-success"><i class="fas fa-check me-1"></i>Delivery available! Estimated 3–5 business days.</small>';
}

/* ── Toast if just reviewed ─────────────────────────── */
const urlParams = new URLSearchParams(window.location.search);
if (urlParams.get('reviewed') === '1') {
  const toastEl = document.createElement('div');
  toastEl.style.cssText = 'position:fixed;bottom:24px;right:24px;z-index:9999;';
  toastEl.innerHTML = `
    <div class="toast show align-items-center text-white border-0 rounded-0"
         style="background:#E63946; min-width:280px;">
      <div class="d-flex">
        <div class="toast-body fw-bold"><i class="fas fa-check me-2"></i>Review submitted! Thank you.</div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto"
                onclick="this.closest('[style]').remove()"></button>
      </div>
    </div>`;
  document.body.appendChild(toastEl);
  setTimeout(() => toastEl.remove(), 4000);
  history.replaceState({}, '', window.location.pathname + '#reviews');
}
</script>

<script>
function changeImage(src) {
  const img = document.getElementById('zoom-img');
  if (img) img.src = src;
}
</script>

</body>
</html>
